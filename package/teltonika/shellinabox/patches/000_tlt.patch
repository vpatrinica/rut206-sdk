+static void registerPtyFd(struct Session *session)
+{
+	if (session->pty < 0) {
+		return;
+	}
+	
+	int flags = fcntl(session->pty, F_GETFL, 0);
+	if (flags >= 0) {
+		fcntl(session->pty, F_SETFL, flags | O_NONBLOCK);
+	}
+	
+	// Register with uloop
+	session->pty_fd_uloop.fd = session->pty;
+	session->pty_fd_uloop.cb = pty_read_cb;
+	uloop_fd_add(&session->pty_fd_uloop, ULOOP_READ);
+}
+
+int launchChild(struct Service *service, struct Session *session, const char *url)
+{
+	if (launcher < 0) {
+		errno = EINVAL;
+		return -1;
+	}
+
+	struct in_addr peer_addr = session->client->peer_addr.in;
+
+	char *u;
+	check(u = strdup(url));
+	for (int i; u[i = strcspn(u, "\\\"'`${};() \r\n\t\v\f")];) {
+		static const char hex[] = "0123456789ABCDEF";
+		check(u = realloc(u, strlen(u) + 4));
+		memmove(u + i + 3, u + i + 1, strlen(u + i));
+		u[i + 2] = hex[u[i] & 0xF];
+		u[i + 1] = hex[(u[i] >> 4) & 0xF];
+		u[i]	 = '%';
+	}
+
+	struct LaunchRequest *request;
+	ssize_t len = sizeof(struct LaunchRequest) + strlen(u) + 1;
+	check(request = calloc(1, len));
+	request->service	 = service;
+	request->terminate	 = -1;
+	request->port		 = session->port;
+	request->width		 = session->width;
+	request->height		 = session->height;
+
+	const char *peerName	 = inet_ntoa(peer_addr);
+	strncat(request->peerName, peerName, sizeof(request->peerName) - 1);
+	struct in_addr srv_addr = session->client->srv_addr.in;
+	const char *realIP	= inet_ntoa(srv_addr);
+	if (realIP && *realIP) {
+		strncat(request->realIP, realIP, sizeof(request->realIP) - 1);
+	}
+	request->urlLength = strlen(u);
+	memcpy(&request->url, u, request->urlLength);
+	free(u);
+	if (NOINTR(write(launcher, request, len)) != len) {
+		free(request);
+		return -1;
+	}
+	free(request);
+	pid_t pid;
+	char cmsg_buf[CMSG_SPACE(sizeof(int))];
+	struct iovec iov   = { 0 };
+	struct msghdr msg  = { 0 };
+	iov.iov_base	   = &pid;
+	iov.iov_len	   = sizeof(pid);
+	msg.msg_iov	   = &iov;
+	msg.msg_iovlen	   = 1;
+	msg.msg_control	   = &cmsg_buf;
+	msg.msg_controllen = sizeof(cmsg_buf);
+	int bytes	   = NOINTR(recvmsg(launcher, &msg, 0));
+	if (bytes < 0) {
+		return -1;
+	}
+	check(bytes == sizeof(pid));
+	check(session->pid = pid);
+	struct cmsghdr *cmsg = CMSG_FIRSTHDR(&msg);
+	check(cmsg);
+	check(cmsg->cmsg_level == SOL_SOCKET);
+	check(cmsg->cmsg_type == SCM_RIGHTS);
+	memcpy(&session->pty, CMSG_DATA(cmsg), sizeof(int));
+
+	registerPtyFd(session);
+	return pid;
+}
+
+int terminateChild(struct Session *session)
+{
+	if (launcher < 0) {
+		errno = EINVAL;
+		return -1;
+	}
+
+	if (session->pid < 1) {
+		debug("[server] Child pid for termination not valid!");
+		return -1;
+	}
+
+	// Send terminate request to launcher process
+	struct LaunchRequest *request;
+	ssize_t len = sizeof(struct LaunchRequest);
+	check(request = calloc(1, len));
+	request->terminate = session->pid;
+	if (NOINTR(write(launcher, request, len)) != len) {
+		debug("[server] Child %d termination request failed!", request->terminate);
+		free(request);
+		return -1;
+	}
+
+	free(request);
+	session->pid	 = 0;
+	session->cleanup = 0;
+	return 0;
 }
 
