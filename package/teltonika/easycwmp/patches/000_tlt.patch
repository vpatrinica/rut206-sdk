+#!/bin/sh
+
+RESULT_FILE="/var/run/easycwmp/tr143_dd_result$1"
+interface="$2"
+url="$3"
+
+print_time() {
+	local curr_sec="$1"
+	local curr_microsec="$2"
+	local time_curl="$3"
+	local key="$4"
+
+	local seconds=$(echo $time_curl | awk -F'.' '{print $1}')
+	local microseconds=$(echo $time_curl | awk -F'.' '{print $2}' | sed 's/^0*//')
+
+	seconds=$((curr_sec + seconds))
+	microseconds=$((curr_microsec + microseconds))
+	# Handle potential overflow of microseconds (more than 999999)
+	if [ $microseconds -ge 1000000 ]; then
+		microseconds=$((microseconds - 1000000))
+		seconds=$((seconds + 1)) # Increment seconds if overflow occurs
+	fi
+
+	local date_fmt=$(date -d @$seconds '+%Y-%m-%dT%H:%M:%S')
+	date_fmt="$date_fmt.$(printf "%06d" $microseconds)Z"
+
+	echo "$key $date_fmt" >>"$RESULT_FILE"
+}
+
+# Setup before initializing curl
+curr_seconds=$(adjtimex | grep "time.tv_sec" | awk '{print $2}')
+curr_microseconds=$(adjtimex | grep "time.tv_usec" | awk '{print $2}')
+total_bytes_before=$(cat /sys/class/net/${interface}/statistics/rx_bytes)
+
+# Curl
+time_res=$(curl -s \
+	   --connect-timeout 60 \
+	   -o /dev/null \
+	   -w "%{size_download}:%{time_connect}:%{time_starttransfer}:%{time_total}" \
+	   --interface "$interface" "$url")
+
+# After curl is finished
+res="$?"
+[ "$res" -ne 0 ] && {
+	if [ "$res" -eq 28 ]; then
+		echo "state Error_NoResponse" >>"$RESULT_FILE"
+	else
+		echo "state Error_TransferFailed" >>"$RESULT_FILE"
+	fi
+	return
+}
+
+total_bytes_after=$(cat /sys/class/net/${interface}/statistics/rx_bytes)
+test_bytes=$(echo "$time_res" | awk -F':' '{print $1}')
+romtime_curl=$(echo "$time_res" | awk -F':' '{print $2}')
+bomtime_curl=$(echo "$time_res" | awk -F':' '{print $3}')
+eomtime_curl=$(echo "$time_res" | awk -F':' '{print $4}')
+
+print_time "$curr_seconds" "$curr_microseconds" "$romtime_curl" "rom_time"
+print_time "$curr_seconds" "$curr_microseconds" "$bomtime_curl" "bom_time"
+print_time "$curr_seconds" "$curr_microseconds" "$eomtime_curl" "eom_time"
+
+total_bytes=$((total_bytes_after - total_bytes_before))
+
+echo "test_bytes $test_bytes" >>"$RESULT_FILE"
+echo "total_bytes $total_bytes" >>"$RESULT_FILE"
+
+echo "state Completed" >>"$RESULT_FILE"
