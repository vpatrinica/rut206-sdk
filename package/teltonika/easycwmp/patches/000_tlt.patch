+	json_select http_body
+	json_select data
+	json_get_keys keys
+	for var in $keys; do
+		json_select "$var"
+		json_get_vars modem_id free
+		[ "$modem_id" = "$usb_id" ] && {
+			echo "$free"
+			return 0
+		}
+		json_select ..
+	done
+}
+
+set_iface_sms_incoming_limit() {
+	local usb_id="$1"
+	local input="$2"
+
+	json_load "$(ubus call api get '{"path":"/messages/storage/config"}')"
+	json_select http_body
+	json_select data
+	json_get_keys keys
+	for var in $keys; do
+		json_select "$var"
+		json_get_vars modem_id id
+		[ "$modem_id" = "$usb_id" ] && break
+		json_select ..
+	done
+
+	[ -z "$id" ] && return $E_INVALID_PARAMETER_VALUE
+
+	json_load "$(ubus call api put '{"path":"/messages/storage/config/'$id'","body":
+		     {"data":{"free":"'$input'"}}}')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
