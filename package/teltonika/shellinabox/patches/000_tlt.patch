+static int read_uci_config(void)
+{
+	struct uci_package *pkg = NULL;
+	struct uci_section *sect;
+	struct uci_element *e;
+	const char *value;
+	int banner_enabled	   = 0;
+	const char *banner_title   = NULL;
+	const char *banner_message = NULL;
+
+	if (!uci_ctx) {
+		uci_ctx = uci_alloc_context();
+		if (!uci_ctx) {
+			return -1;
+		}
+	}
+
+	if (uci_load(uci_ctx, "cli", &pkg) != UCI_OK) {
+		return 0;
+	}
+
+	uci_foreach_element (&pkg->sections, e) {
+		sect = uci_to_section(e);
+		if (strcmp(sect->type, "status")) {
+			continue;
+		}
+		value = uci_lookup_option_string(uci_ctx, sect, "enable");
+		if (value) {
+			cli_enabled = (strcmp(value, "1") == 0);
+		}
+
+		value = uci_lookup_option_string(uci_ctx, sect, "shell_limit");
+		if (!value) {
+			break;
+		}
+		char *endptr;
+		long temp_sessions = strtol(value, &endptr, 10);
+		if (endptr == value || *endptr != '\0' || temp_sessions <= 0) {
+			max_sessions = 5; // Fallback
+			break;
+		}
+		max_sessions = temp_sessions;
+		break;
+	}
+	uci_unload(uci_ctx, pkg);
+	pkg = NULL;
+
+	if (uci_load(uci_ctx, "system", &pkg) != UCI_OK) {
+		return -1;
+	}
+
+	uci_foreach_element (&pkg->sections, e) {
+		sect = uci_to_section(e);
+		if (strcmp(sect->type, "banner") == 0) {
+			value = uci_lookup_option_string(uci_ctx, sect, "enabled");
+			if (value) {
+				banner_enabled = (strcmp(value, "1") == 0);
+			}
+
+			if (!banner_enabled) {
+				break;
+			}
+			banner_title   = uci_lookup_option_string(uci_ctx, sect, "title");
+			banner_message = uci_lookup_option_string(uci_ctx, sect, "message");
+
+			if (!(banner_title && *banner_title) && !(banner_message && *banner_message)) {
+				break;
+			}
+
+			size_t banner_size = 0;
+			if (banner_title && *banner_title) {
+				banner_size += strlen(banner_title) + 10;
+			}
+			if (banner_message && *banner_message) {
+				banner_size += strlen(banner_message) + 2;
+			}
+
+			if (system_banner) {
+				free(system_banner);
+				system_banner = NULL;
+			}
+
+			system_banner = calloc(1, banner_size + 1);
+			if (!system_banner) {
+				break;
+			}
+			char *ptr = system_banner;
+
+			if (banner_title && *banner_title) {
+				ptr += snprintf(ptr, banner_size, "*** %s ***",
+						banner_title);
+			}
+
+			if (banner_message && *banner_message) {
+				if (banner_title && *banner_title) {
+					ptr += snprintf(ptr,
+							banner_size -
+								(ptr - system_banner),
+							"\n\n%s", banner_message);
+				} else {
+					ptr += snprintf(ptr, banner_size, "%s",
+							banner_message);
+				}
+			}
+
+			if (ptr > system_banner) {
+				*ptr++ = '\n';
+				*ptr   = '\0';
+			}
+		}
+	}
+	uci_unload(uci_ctx, pkg);
+
+	return 0;
+}
+
+static void cleanup_uci(void)
+{
+	if (uci_ctx) {
+		uci_free_context(uci_ctx);
+		uci_ctx = NULL;
+	}
+	if (system_banner) {
+		free(system_banner);
+		system_banner = NULL;
+	}
+}
