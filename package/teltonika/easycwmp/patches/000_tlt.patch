+			options="${options}\"${value}\","
+		fi
+		i=$((i + 1))
+	done
+
+	options="${options%?}]"
+
+	json_load "$(ubus call api put '{"path":"/dhcp/servers/ipv4/config/'$iface'",
+		     "body":{"data":{"dhcp_option":'$options'}}}')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+#########################################
+#  Device.DHCPv4.Server.Pool.{i}.Client #
+#########################################
+
+count_dhcpv4_server_pool_client() {
+	local iface="$2"
+	local i="$3"
+	local j=1
+	local clients="$(ubus call api get '{"path":"/dhcp/leases/ipv4/status"}' | \
+			 jsonfilter -e '@.http_body.data[*]')"
+
+	OLD_IFS="$IFS"
+	IFS=$'\n'
+	for table in $clients; do
+		IFS="$OLD_IFS"
+		[ "$(echo "$table" | jsonfilter -e '@.interface')" = "$iface" ] && {
+			sub_entry_dhcpv4_server_pool_client "$1" "$i" "$j" "$table"
+			j=$((j + 1))
+		}
+		IFS=$'\n'
+	done
+	IFS="$OLD_IFS"
+}
+
+sub_entry_dhcpv4_server_pool_client() {
+	local i="$2"
+	local j="$3"
+	local table="$4"
+
+	case_param "$1" belongto "$DMROOT.DHCPv4.Server.Pool.$i.Client.$j." && {
+		local chaddr="$(echo "$table" | jsonfilter -e '@.macaddr')"
+		local ipaddress="$(echo "$table" | jsonfilter -e '@.ipaddr')"
+		local lease="$(echo "$table" | jsonfilter -e '@.expires')"
+
+		local now=$(date +%s)
+		lease=$((now + lease))
+		lease=$(date -u -d "@$lease" +"%Y-%m-%dT%H:%M:%SZ")
+
+		common_execute_method_obj "$DMROOT.DHCPv4.Server.Pool.$i.Client.$j." "0"
+		common_execute_method_param "$DMROOT.DHCPv4.Server.Pool.$i.Client.$j.Chaddr" "0" \
+			"echo $chaddr" "" "xsd:string"
+		common_execute_method_param "$DMROOT.DHCPv4.Server.Pool.$i.Client.$j.Active" "0" \
+			"echo 1" "" "xsd:boolean"
+		common_execute_method_param "$DMROOT.DHCPv4.Server.Pool.$i.Client.$j.IPv4AddressNumberOfEntries" "0" \
+			"echo 1" "" "xsd:unsignedInt"
+		common_execute_method_obj "$DMROOT.DHCPv4.Server.Pool.$i.Client.$j.IPv4Address." "0"
+		common_execute_method_obj "$DMROOT.DHCPv4.Server.Pool.$i.Client.$j.IPv4Address.1." "0"
+		common_execute_method_param "$DMROOT.DHCPv4.Server.Pool.$i.Client.$j.IPv4Address.1.IPAddress" "0" \
+			"echo $ipaddress" "" "xsd:string"
+		common_execute_method_param "$DMROOT.DHCPv4.Server.Pool.$i.Client.$j.IPv4Address.1.LeaseTimeRemaining" "0" \
+			"echo $lease" "" "xsd:dateTime"
+		return 0;
+	}
+
+	return $E_INVALID_PARAMETER_NAME;
+}
diff --recursive --unified --new-file --no-dereference --exclude .gitver upstream/ext/openwrt/scripts/functions/tr181/ethernet src/ext/openwrt/scripts/functions/tr181/ethernet
--- upstream/ext/openwrt/scripts/functions/tr181/ethernet	1970-01-01 00:00:00.000000000 +0000
+++ src/ext/openwrt/scripts/functions/tr181/ethernet	2026-03-25 10:23:48.000000000 +0000
@@ -0,0 +1,305 @@
+#!/bin/sh
+
+#common_execute_method_param "$parameter" "$permission" "$get_cmd" "$set_cmd" "xsd:$type" "$forcedinform"
+#  $forcedinform should be set to 1 if the parameter is included in the inform message otherwise empty
+#  Default of $type = string
+
+#############################
+#   Entry point functuons   #
+#############################
+
+prefix_list="$prefix_list $DMROOT.Ethernet."
+entry_execute_method_list="$entry_execute_method_list entry_execute_method_root_Ethernet"
+entry_execute_method_list_forcedinform="$entry_execute_method_list_forcedinform  entry_execute_method_root_Ethernet"
+
+####################
+#  Device.Ethernet #
+####################
+
+entry_execute_method_root_Ethernet() {
+	case "$1" in ""|"$DMROOT."|"$DMROOT.Ethernet."*)
+		common_execute_method_obj "$DMROOT.Ethernet." "0"
+		common_execute_method_param "$DMROOT.Ethernet.InterfaceNumberOfEntries" "0" \
+			"get_ethernet_iface_noe" "" "xsd:unsignedInt"
+		common_execute_method_obj "$DMROOT.Ethernet.Interface." "0" \
+			"" "" "count_ethernet_iface_obj $1"
+		return 0;
+		;;
+	esac
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+get_ethernet_iface_noe() {
+	json_load "$(ubus call api get '{"path":"/ports_settings/config"}')"
+	json_select http_body
+	json_select data
+	json_get_keys keys
+
+	keys="${keys##* }"
+	if [ -n "$keys" ]; then
+		echo "$keys"
+	else
+		echo "0"
+	fi
+}
+
+##############################
+#  Device.Ethernet.Interface #
+##############################
+
+count_ethernet_iface_obj() {
+	local i=1
+	local ifaces="$(ubus call api get '{"path":"/ports_settings/status"}' | \
+			jsonfilter -e '@.http_body.data[*]')"
+
+	OLD_IFS="$IFS"
+	IFS=$'\n'
+	for table in $ifaces; do
+		IFS="$OLD_IFS"
+		sub_entry_ethernet_iface "$1" "$i" "$table"
+		i=$((i + 1))
+		IFS=$'\n'
+	done
+	IFS="$OLD_IFS"
+}
+
+sub_entry_ethernet_iface() {
+	local i="$2"
+	local table="$3"
+
+	case_param "$1" belongto "$DMROOT.Ethernet.Interface.$i." && {
+		local id="$(echo "$table" | jsonfilter -e '@.id')"
+		local config="$(ubus call api get '{"path":"/ports_settings/config/'$id'"}' | \
+				jsonfilter -e '@.http_body.data')"
+
+		local enable="$(echo "$config" | jsonfilter -e '@.enabled')"
+		local status="$(echo "$table" | jsonfilter -e '@.state')"
+		local autoneg="$(echo "$config" | jsonfilter -e '@.autoneg')"
+		local speed="$(echo "$config" | jsonfilter -e '@.speed')"
+		local mac="$(echo "$table" | jsonfilter -e '@.mac')"
+		local links="$(echo "$config" | jsonfilter -e '@.advert[*]')"
+		local bitrate="$(echo "$table" | jsonfilter -e '@.speed')"
+		local duplex="$(echo "$config" | jsonfilter -e '@.duplex')"
+		local duplex_curr="$(echo "$table" | jsonfilter -e '@.duplex')"
+
+		local links_supported="10mh 10mf 100mh 100mf"
+		local boardjson="$(cat /etc/board.json)"
+		if [ "$(echo "$boardjson" | jsonfilter -e '@.hwinfo.dsa')" = "true" ]; then
+			links_supported="$(echo "$table" | jsonfilter -e '@.link_supported[*]')"
+		else
+			[ "$(echo "$boardjson" | jsonfilter -e '@.hwinfo.gigabit_port')" = "true" ] &&
+				links_supported="${links_supported} 1000mf"
+			[ "$(echo "$boardjson" | jsonfilter -e '@.hwinfo.2_5_gigabit_port')" = "true" ] &&
+				links_supported="${links_supported} 2500mf"
+		fi
+
+		if [ "$enable" -eq 0 ]; then
+			status="Down"
+		elif [ "$status" = "down" ]; then
+			status="Dormant"
+		else
+			status="Up"
+		fi
+
+		links_supported="$(get_ethernet_iface_links "$links_supported")"
+		links="$(get_ethernet_iface_links "$links")"
+
+		[ -z "$bitrate" ] && bitrate="0"
+
+		if [ -z "$duplex" ]; then
+			duplex="Auto"
+		elif [ "$duplex" = "full" ]; then
+			duplex="Full"
+		else
+			duplex="Half"
+		fi
+
+		if [ "$duplex_curr" = "true" ]; then
+			duplex_curr="$duplex"
+		else
+			duplex_curr="Unknown"
+		fi
+
+		common_execute_method_obj "$DMROOT.Ethernet.Interface.$i." "0"
+		common_execute_method_param "$DMROOT.Ethernet.Interface.$i.Enable" "1" \
+			"echo $enable" "set_ethernet_iface_enable $id" "xsd:boolean"
+		common_execute_method_param "$DMROOT.Ethernet.Interface.$i.Status" "0" \
+			"echo $status" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Ethernet.Interface.$i.Name" "0" \
+			"echo $id" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Ethernet.Interface.$i.MaxBitRate" "1" \
+			"get_ethernet_iface_speed $autoneg '$speed'" "set_ethernet_iface_speed $id" "xsd:int"
+		common_execute_method_param "$DMROOT.Ethernet.Interface.$i.MACAddress" "0" \
+			"echo $mac" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Ethernet.Interface.$i.SupportedLinkModes" "0" \
+			"echo $links_supported" "" "xsd:unsignedInt[]"
+		common_execute_method_param "$DMROOT.Ethernet.Interface.$i.AdvertisedLinkModes" "1" \
+			"echo $links" "set_ethernet_iface_links $id" "xsd:unsignedInt[]"
+		common_execute_method_param "$DMROOT.Ethernet.Interface.$i.CurrentBitRate" "0" \
+			"echo $bitrate" "" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.Ethernet.Interface.$i.DuplexMode" "1" \
+			"echo $duplex" "set_ethernet_iface_duplex $id '$speed'" "xsd:string"
+		common_execute_method_param "$DMROOT.Ethernet.Interface.$i.CurrentDuplexMode" "0" \
+			"echo $duplex_curr" "" "xsd:string"
+		return 0;
+	}
+
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+set_ethernet_iface_enable() {
+	local id="$1"
+	local input="$2"
+
+	if [ "$input" = "true" ]; then
+		input="1"
+	elif [ "$input" = "false" ]; then
+		input="0"
+	elif [ "$input" != "0" -a "$input" != "1" ]; then
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+
+	json_load "$(ubus call api put '{
+		     "path":"/ports_settings/config/'$id'",
+		     "body":{"data":{"enabled":"'$input'"}}
+		     }')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+get_ethernet_iface_speed() {
+	local autoneg="$1"
+	local speed="$2"
+
+	[ "$autoneg" = "on" ] && speed="-1"
+
+	echo "$speed"
+}
+
+set_ethernet_iface_speed() {
+	local id="$1"
+	local input="$2"
+
+	case "$input" in
+		-1) input="on" ;;
+		10|100) ;;
+		*) return $E_INVALID_PARAMETER_VALUE ;;
+	esac
+
+	if [ "$input" = "on" ]; then
+		json_load "$(ubus call api put '{
+			     "path":"/ports_settings/config/'$id'",
+			     "body":{"data":{"autoneg":"'$input'","speed":""}}
+			     }')"
+	else
+		json_load "$(ubus call api put '{
+			     "path":"/ports_settings/config/'$id'",
+			     "body":{"data":{"autoneg":"off","speed":"'$input'"}}
+			     }')"
+	fi
+
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+get_ethernet_iface_links() {
+	local links="$1"
+	local array=""
+
+	for link in $links; do
+		case "$link" in
+			10mh) array="${array}10," ;;
+			10mf) array="${array}11," ;;
+			100mh) array="${array}15," ;;
+			100mf) array="${array}16," ;;
+			1000mf) array="${array}29," ;;
+			2500mf) array="${array}103," ;;
+		esac
+	done
+
+	echo "${array%?}"
+}
+
+set_ethernet_iface_links() {
+	local id="$1"
+	local input="${2//,/ }"
+	local links="["
+
+	for link in $input; do
+		case "$link" in
+			10) links="${links}\"10mh\"," ;;
+			11) links="${links}\"10mf\"," ;;
+			15) links="${links}\"100mh\"," ;;
+			16) links="${links}\"100mf\"," ;;
+			29) links="${links}\"1000mf\"," ;;
+			103) links="${links}\"2500mf\"," ;;
+			*) return $E_INVALID_PARAMETER_VALUE ;;
+		esac
+	done
+
+	if [ -z "$input" ]; then
+		links="${links}]"
+	else
+		links="${links%?}]"
+	fi
+
+	json_load "$(ubus call api put '{
+		     "path":"/ports_settings/config/'$id'",
+		     "body":{"data":{"advert":'$links'}}
+		     }')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+set_ethernet_iface_duplex() {
+	local id="$1"
+	local speed="$2"
+	local input="$3"
+
+	case "$input" in
+		Auto) input="" ;;
+		Half|Full) ;;
+		*) return $E_INVALID_PARAMETER_VALUE ;;
+	esac
+
+	input=$(echo "$input" | tr 'A-Z' 'a-z')
+
+	# Setting default speed 10 if it is not present and
+	# half/full duplex mode is defined
+	[ -z "$speed" ] && speed=10
+
+	if [ -z "$input" ]; then
+		json_load "$(ubus call api put '{
+			     "path":"/ports_settings/config/'$id'",
+			     "body":{"data":{"autoneg":"on","duplex":""}}
+			     }')"
+	else
+		json_load "$(ubus call api put '{
+			     "path":"/ports_settings/config/'$id'",
+			     "body":{"data":{"autoneg":"off","speed":"'$speed'","duplex":"'$input'"}}
+			     }')"
+	fi
+
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
diff --recursive --unified --new-file --no-dereference --exclude .gitver upstream/ext/openwrt/scripts/functions/tr181/hosts src/ext/openwrt/scripts/functions/tr181/hosts
--- upstream/ext/openwrt/scripts/functions/tr181/hosts	1970-01-01 00:00:00.000000000 +0000
+++ src/ext/openwrt/scripts/functions/tr181/hosts	2026-03-25 10:23:48.000000000 +0000
@@ -0,0 +1,232 @@
+#!/bin/sh
+
+#common_execute_method_param "$parameter" "$permission" "$get_cmd" "$set_cmd" "xsd:$type" "$forcedinform"
+#  $forcedinform should be set to 1 if the parameter is included in the inform message otherwise empty
+#  Default of $type = string
+
+#############################
+#   Entry point functuons   #
+#############################
+
+prefix_list="$prefix_list $DMROOT.Hosts."
+entry_execute_method_list="$entry_execute_method_list entry_execute_method_root_Hosts"
+entry_execute_method_list_forcedinform="$entry_execute_method_list_forcedinform  entry_execute_method_root_Hosts"
+
+#################
+#  Device.Hosts #
+#################
+
+g_hosts_scan=""
+g_easycwmp_eth_ifaces=""
+g_easycwmp_ip_ifaces=""
+g_cache_limit=20
+
+entry_execute_method_root_Hosts() {
+	case "$1" in ""|"$DMROOT."|"$DMROOT.Hosts."*)
+		load_hosts_data
+
+		common_execute_method_obj "$DMROOT.Hosts." "0"
+		common_execute_method_param "$DMROOT.Hosts.HostNumberOfEntries" "0" \
+			"get_hosts_host_noe" "" "xsd:unsignedInt"
+		common_execute_method_obj "$DMROOT.Hosts.Host." "0" \
+			"" "" "count_hosts_host_obj $1"
+		return 0;
+		;;
+	esac
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+# Create data cache because when ACS queries data with GetParameterValue command it calls
+# this script for each node - then 500+ nodes are retrieved in more than 40 minutes
+# TODO: improve and optimize handling of ACS queries in easycwmp itself
+load_hosts_data() {
+	local now="$(date +%s)"
+	local cache="/var/run/easycwmp/cache_hosts"
+	local cache_time="$(head -n 1 "$cache" 2>/dev/null)"
+
+	# Time how long the cache should be kept is determined by the amount of entries
+	# received from device_scan API call raised by 10
+	# 2 entries - cache is kept for 20 seconds
+	# 40 entries - cache is kept for 400 seconds
+	[ -f "$cache" ] && g_cache_limit=$(($(wc -l < "$cache") * 10))
+	if [ -f "$cache" ] && [ $((now - cache_time)) -lt "$g_cache_limit" ]; then
+		g_hosts_scan="$(tail -n +2 "$cache")"
+	else
+		g_hosts_scan="$(ubus call api post \
+		     '{"path":"/topology/actions/devices_scan","body":{"data":{"scan_type":"all"}}}' | \
+		     jsonfilter -e '@.http_body.data.devices[*]')"
+		date +%s > "$cache"
+		echo "$g_hosts_scan" >> "$cache"
+		g_cache_limit=0
+	fi
+}
+
+get_hosts_host_noe() {
+	local count=0
+
+	OLD_IFS="$IFS"
+	IFS=$'\n'
+	for table in $g_hosts_scan; do
+		IFS="$OLD_IFS"
+		count=$((count + 1))
+		IFS=$'\n'
+	done
+	IFS="$OLD_IFS"
+
+	echo "$count"
+}
+
+######################
+#  Device.Hosts.Host #
+######################
+
+prepare_easycwmp_scans() {
+	local i=1
+	local res=""
+	local command="/usr/sbin/easycwmp"
+	local cache_eth="/var/run/easycwmp/cache_ethernet"
+	local cache_ip="/var/run/easycwmp/cache_ip"
+
+	[ ! -f "$command" ] && command="/usr/local$command"
+
+	if [ -f "$cache_eth" ]; then
+		g_easycwmp_eth_ifaces="$(cat "$cache_eth")"
+	else
+		g_easycwmp_eth_ifaces="$($command get Device.Ethernet.Interface. | grep .Name)"
+		echo "$g_easycwmp_eth_ifaces" >> "$cache_eth"
+	fi
+
+	if [ -f "$cache_ip" ] && [ "$g_cache_limit" -gt 0 ]; then
+		g_easycwmp_ip_ifaces="$(cat "$cache_ip")"
+	else
+		while res="$($command get Device.IP.Interface.$i.Name)" &&
+		      ! echo "$res" | grep -q 'fault_code'; do
+			g_easycwmp_ip_ifaces="${g_easycwmp_ip_ifaces}${res}
+"
+			i=$((i + 1))
+		done
+		echo "$g_easycwmp_ip_ifaces" >> "$cache_ip"
+	fi
+}
+
+count_hosts_host_obj() {
+	local i=1
+	local hosts_status_scan="$(ubus call api get '{"path":"/network_usage/metrics/total/status"}')"
+	local status_table=""
+
+	prepare_easycwmp_scans
+
+	OLD_IFS="$IFS"
+	IFS=$'\n'
+	for table in $g_hosts_scan; do
+		IFS="$OLD_IFS"
+		local ip="$(echo "$table" | jsonfilter -e '@.ip')"
+		local mac="$(echo "$table" | jsonfilter -e '@.mac')"
+		status_table="$(echo "$hosts_status_scan" | \
+				jsonfilter -e "@.http_body.data[@.src_ip=\"$ip\" && @.src_mac=\"$mac\"]")"
+		sub_entry_hosts_host "$1" "$i" "$table" "$ip" "$mac" "$status_table"
+		i=$((i + 1))
+		IFS=$'\n'
+	done
+	IFS="$OLD_IFS"
+}
+
+sub_entry_hosts_host() {
+	local i="$2"
+	local table="$3"
+	local ip="$4"
+	local mac="$5"
+	local status_table="$6"
+
+	case_param "$1" belongto "$DMROOT.Hosts.Host.$i." && {
+		local port="$(echo "$table" | jsonfilter -e '@.port' | sed 's/[[:space:]]//g')"
+		local interface="$(echo "$table" | jsonfilter -e '@.interface')"
+		local type="$(echo "$table" | jsonfilter -e '@.type')"
+		local hostname="$(echo "$table" | jsonfilter -e '@.hostname')"
+		local active="$(echo "$table" | jsonfilter -e '@.active')"
+		local tx_bytes=0
+		local rx_bytes=0
+		local tx_pkts=0
+		local rx_pkts=0
+
+		[ -n "$status_table" ] && {
+			tx_bytes="$(echo "$status_table" | jsonfilter -e '@.tx_bytes')"
+			rx_bytes="$(echo "$status_table" | jsonfilter -e '@.rx_bytes')"
+			tx_pkts="$(echo "$status_table" | jsonfilter -e '@.tx_pkts')"
+			rx_pkts="$(echo "$status_table" | jsonfilter -e '@.rx_pkts')"
+		}
+
+		if [ "$type" = "wired" ]; then
+			type="Ethernet"
+		elif [ "$type" = "wifi" ]; then
+			type="Wi-Fi"
+		else
+			type="Other"
+		fi
+
+		common_execute_method_obj "$DMROOT.Hosts.Host.$i." "0"
+		common_execute_method_param "$DMROOT.Hosts.Host.$i.PhysAddress" "0" \
+			"echo $mac" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Hosts.Host.$i.IPAddress" "0" \
+			"echo $ip" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Hosts.Host.$i.Layer1Interface" "0" \
+			"get_hosts_host_layer1iface $port" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Hosts.Host.$i.Layer3Interface" "0" \
+			"get_hosts_host_layer3iface $interface" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Hosts.Host.$i.InterfaceType" "0" \
+			"echo $type" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Hosts.Host.$i.HostName" "0" \
+			"echo $hostname" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Hosts.Host.$i.Active" "0" \
+			"echo $active" "" "xsd:boolean"
+		common_execute_method_obj "$DMROOT.Hosts.Host.$i.WANStats." "0"
+		common_execute_method_param "$DMROOT.Hosts.Host.$i.WANStats.BytesSent" "0" \
+			"echo $tx_bytes" "" "xsd:unsignedLong"
+		common_execute_method_param "$DMROOT.Hosts.Host.$i.WANStats.BytesReceived" "0" \
+			"echo $rx_bytes" "" "xsd:unsignedLong"
+		common_execute_method_param "$DMROOT.Hosts.Host.$i.WANStats.PacketsSent" "0" \
+			"echo $tx_pkts" "" "xsd:unsignedLong"
