--- libazure-iot-sdk-c-2024-11-05.orig/c-utility/adapters/x509_openssl.c
+++ libazure-iot-sdk-c-2024-11-05/c-utility/adapters/x509_openssl.c
@@ -15,6 +15,10 @@
 #include "openssl/engine.h"
 #endif // OPENSSL_NO_ENGINE
 
+#ifdef AZ_TPM_SUPPORT
+#include <openssl/store.h>
+#endif //AZ_TPM_SUPPORT
+
 #ifdef __APPLE__
     #ifndef EVP_PKEY_id
         #define EVP_PKEY_id(evp_key) evp_key->type
@@ -260,6 +264,84 @@ int x509_openssl_add_engine_key(SSL_CTX*
 }
 #endif // OPENSSL_NO_ENGINE
 
+
+#ifdef AZ_TPM_SUPPORT
+int x509_openssl_add_provider_key(SSL_CTX* ssl_ctx, OSSL_LIB_CTX *libctx, const char* uri)
+{
+    UI_METHOD *ui_pkey_method = NULL;
+    OSSL_STORE_CTX *store_ctx = NULL;
+    OSSL_STORE_INFO *store_info = NULL;
+    EVP_PKEY *pkey = NULL;
+    int ret = 1;
+
+    store_ctx = OSSL_STORE_open_ex(uri, libctx, NULL, NULL, NULL, NULL, NULL, NULL);
+    if (!store_ctx) {
+        log_ERR_get_error("Error: Unable to open private key store ctx");
+
+        goto err;
+    }
+
+    if (OSSL_STORE_expect(store_ctx, OSSL_STORE_INFO_PKEY) != 1) {
+        log_ERR_get_error("Error: Unable to find private key in store");
+
+        goto err;
+    }
+
+    store_info = OSSL_STORE_load(store_ctx);
+    if (!store_info) {
+        log_ERR_get_error("Error: Unable to load private key from store");
+
+        goto err;
+    }
+
+    pkey = OSSL_STORE_INFO_get1_PKEY(store_info);
+    if (!pkey) {
+        log_ERR_get_error("Error: Unable to get private key from store");
+
+        goto err;
+    }
+
+    if (SSL_CTX_use_PrivateKey(ssl_ctx, pkey) != 1) {
+        log_ERR_get_error("Error: Unable to use private key from store");
+
+        pkey = NULL;
+        goto err;
+    }
+
+    ret = 0;
+
+err:
+    OSSL_STORE_INFO_free(store_info);
+    OSSL_STORE_close(store_ctx);
+
+    return ret;
+}
+
+int x509_openssl_add_credentials_prov(SSL_CTX* ssl_ctx, OSSL_LIB_CTX *libctx, const char* x509certificate, const char* x509privatekey)
+{
+    int result;
+
+    if (ssl_ctx == NULL || libctx == NULL || x509certificate == NULL || x509privatekey == NULL) {
+        LogError("invalid parameter detected: ssl_ctx=%p, libctx=%p, x509certificate=%p, x509privatekey=%p",
+                    ssl_ctx, libctx, x509certificate, x509privatekey);
+        return MU_FAILURE;
+    }
+
+    result = x509_openssl_add_provider_key(ssl_ctx, libctx, x509privatekey);
+    if (result == 0) {
+        if (load_certificate_chain(ssl_ctx, x509certificate) != 0)
+        {
+            LogError("failure loading public cert or chain");
+            result = MU_FAILURE;
+        }
+    }
+
+    return result;
+}
+
+#endif //AZ_TPM_SUPPORT
+
+
 #ifndef OPENSSL_NO_ENGINE
 int x509_openssl_add_credentials(
     SSL_CTX* ssl_ctx,
