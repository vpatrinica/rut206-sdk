-		{
-		nodes = display.childNodes;
-		for(t=nodes.length-1; t>=0; t--)
-			stash.appendChild(nodes[t]);
-		}
-	var wrapper = document.getElementById("contentWrapper");
-	if(!title)
-		title = "PageTemplate";
-	var html = store.getRecursiveTiddlerText(title,null,10);
