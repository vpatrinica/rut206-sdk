+set_wifi_ap_value() {
+	local id="$1"
+	local key="$2"
+	local value="$3"
+
+	json_load "$(ubus call api put '{
+			"path":"/wireless/interfaces/config/'$id'",
+			"body":{"data":{"'$key'":"'$value'"}}
+		     }')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+set_wifi_ap_boolean() {
+	local id="$1"
+	local key="$2"
+	local input="$3"
+
+	if [ "$input" = "true" ]; then
+		input="1"
+	elif [ "$input" = "false" ]; then
+		input="0"
+	elif [ "$input" != "0" -a "$input" != "1" ]; then
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+
+	set_wifi_ap_value "$id" "$key" "$input"
+}
+
+set_wifi_ap_ssidadvert() {
+	local id="$1"
+	local input="$2"
+
+	case "$input" in
+		true|1) input="0" ;;
+		false|0) input="1" ;;
+		*) return $E_INVALID_PARAMETER_VALUE ;;
+	esac
+
+	set_wifi_ap_value "$id" "hidden" "$input"
+}
+
+set_wifi_ap_macaddrcontrol() {
+	local id="$1"
+	local input="$2"
+
+	case "$input" in
+		Allow) input="allow" ;;
+		Deny) input="deny" ;;
+		Disabled) input="" ;;
+		*) return $E_INVALID_PARAMETER_VALUE ;;
+	esac
+
+	set_wifi_ap_value "$id" "macfilter" "$input"
+}
+
+set_wifi_ap_allowedmac() {
+	local id="$1"
+	local input="$2"
+
+	input=$(echo "$input" | sed 's/,/","/g')
+	input="[\"$input\"]"
+
+	json_load "$(ubus call api put '{
+		     	"path":"/wireless/interfaces/config/'$id'",
+		     	"body":{"data":{"maclist":'$input'}}
+		     }')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
