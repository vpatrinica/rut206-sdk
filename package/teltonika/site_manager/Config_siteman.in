
menu "Advanced configuration"
	depends on PACKAGE_siteman

config SITEMAN_MAX_CLIENTS
    int "Maximum number of clients"
    default 32
    help
        Maximum number of clients that can be connected to the server

config SITEMAN_DEFAULT_API_VERSION
    int "Default API version"
    default 10
    help
        Default API version to use when the client does not specify one

config SITEMAN_DEBUG
    bool "Include extended debug messages"
    default n
    help
        include extended debug messages

endmenu
