+static void serve_static_file(struct client *cl, const char *content_type, const char *start, const char *end)
+{
+	size_t content_length = end - start;
+
+	ustream_printf(cl->us, "HTTP/1.1 200 OK\r\n");
+	ustream_printf(cl->us, "Content-Type: %s\r\n", content_type);
+	ustream_printf(cl->us, "Content-Length: %zu\r\n", content_length);
+	ustream_printf(cl->us, "\r\n");
+
+	if (cl->request.method != UH_HTTP_MSG_HEAD) {
+		ustream_write(cl->us, (void *)start, content_length, false);
+	}
+
+	ops->request_done(cl);
+}
