-          group, PORTNUM,
-          !serverSupportsSSL() ? "" :
-          "  -t, --disable-ssl           disable transparent SSL support\n"
-          "      --disable-ssl-menu      disallow changing transport mode\n",
-          user, supportsPAM() ? "'AUTH' | " : "");
