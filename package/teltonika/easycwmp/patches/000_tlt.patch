+				# kill "$pid" 2>/dev/null
+				kill "$pid"
+			done
+			cleanup "Error_Timeout" "$port" "$dscp_id" "$interface"
+			return
+		}
+		sleep 1
+	done
+	i=$((i + 1))
+done
+
+result_file="/var/run/easycwmp/tr143_ud_result0"
+state=$(grep "^state" "$result_file" | awk '{print $2}')
+[ "$state" != "Completed" ] && {
+	cleanup "$state" "$port" "$dscp_id" "$interface"
+	return
+}
+romtime_final=$(grep "^rom_time" "$result_file" | awk '{print $2}')
+bomtime_final=$(grep "^bom_time" "$result_file" | awk '{print $2}')
+eomtime_final=$(grep "^eom_time" "$result_file" | awk '{print $2}')
+test_bytes_total=$(grep "^test_bytes" "$result_file" | awk '{print $2}')
+total_bytes_total=$(grep "^total_bytes" "$result_file" | awk '{print $2}')
+
+i=1
+
+while [ "$i" -lt "$connections" ]; do
+	result_file="/var/run/easycwmp/tr143_ud_result$i"
+
+	state=$(grep "^state" "$result_file" | awk '{print $2}')
+	[ "$state" != "Completed" ] && {
+		cleanup "$state" "$port" "$dscp_id" "$interface"
+		return
+	}
+
+	romtime=$(grep "^rom_time" "$result_file" | awk '{print $2}')
+	romtime_final=$(compare_time "$romtime_final" "$romtime" 1)
+
+	bomtime=$(grep "^bom_time" "$result_file" | awk '{print $2}')
+	bomtime_final=$(compare_time "$bomtime_final" "$bomtime" 1)
+
+	eomtime=$(grep "^eom_time" "$result_file" | awk '{print $2}')
+	eomtime_final=$(compare_time "$eomtime_final" "$eomtime" 0)
+
+	test_bytes=$(grep "^test_bytes" "$result_file" | awk '{print $2}')
+	test_bytes_total=$((test_bytes_total + test_bytes))
+
+	total_bytes=$(grep "^total_bytes" "$result_file" | awk '{print $2}')
+	total_bytes_total=$((total_bytes_total + total_bytes))
+
+	i=$((i + 1))
+done
+
+sed -i "s/^rom_time .*/rom_time $romtime_final/" "$CONFIG_FILE"
+sed -i "s/^bom_time .*/bom_time $bomtime_final/" "$CONFIG_FILE"
+sed -i "s/^eom_time .*/eom_time $eomtime_final/" "$CONFIG_FILE"
+sed -i "s/^test_bytes .*/test_bytes $test_bytes_total/" "$CONFIG_FILE"
+sed -i "s/^total_bytes .*/total_bytes $total_bytes_total/" "$CONFIG_FILE"
+
+cleanup "Completed" "$port" "$dscp_id" "$interface"
diff --recursive --unified --new-file --no-dereference --exclude .gitver upstream/ext/openwrt/scripts/functions/gps/gps_information src/ext/openwrt/scripts/functions/gps/gps_information
