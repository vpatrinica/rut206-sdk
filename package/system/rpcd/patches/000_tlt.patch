+static int change_user_and_group(int uid, int gid) {
+	uid = (uid == NO_USER) ? NOBODY_UID : uid;
+	gid = (gid == NO_GROUP) ? NOBODY_GID : gid;
+
+	if (setgid(gid))
+		return -1;
+
+	struct passwd *pw = getpwuid(uid);
+	if (pw && initgroups(pw->pw_name, gid))
+		return -1;
+
