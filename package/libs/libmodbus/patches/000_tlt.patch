diff --recursive --unified --new-file --no-dereference --exclude .gitver upstream/doc/modbus_read_input_registers.txt src/doc/modbus_read_input_registers.txt
--- upstream/doc/modbus_read_input_registers.txt	2019-07-31 21:17:38.000000000 +0000
