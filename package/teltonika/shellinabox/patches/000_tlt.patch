-static int httpGetChar(struct HttpConnection *http, const char *buf,
-                       int size, int *offset) {
-  if (*offset < 0) {
-    return (unsigned char)http->partial[http->partialLength + (*offset)++];
-  } else if (*offset < size) {
-    return (unsigned char)buf[(*offset)++];
-  } else {
-    return -1;
-  }
-}
