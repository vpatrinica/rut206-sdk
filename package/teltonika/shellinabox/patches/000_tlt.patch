+	check(service->cwd);
+	if (!*service->cwd || *service->cwd != '/' || chdir(service->cwd)) {
+		check(service->cwd = realloc((char *)service->cwd, 2));
+		*(char *)service->cwd = '\000';
+		strncat((char *)service->cwd, "/", 1);
+		puts("No directory, logging in with HOME=/");
+		check(!chdir("/"));
+		for (int i = 0; environment[i]; i++) {
+			if (!strncmp(environment[i], "HOME=", 5)) {
+				free(environment[i]);
+				check(environment[i] = strdup("HOME=/"));
+				break;
+			}
+		}
+	}
+
+	// Reset the sigaction for HUP to the default, so the child does not inherit the action of SIG_IGN from us.
+	// We need the child to be able to get HUP's because we send HUP if the session times out/closes.
+	signal(SIGHUP, SIG_DFL);
+
+	// Finally, launch the child process.
+	if (service->useLogin == 1) {
+		// At login service launch, we try to pass real IP in '-h' parameter. Real
+		// IP is provided in HTTP header field 'X-Real-IP', if ShellInABox is used
+		// behind properly configured HTTP proxy.
+
+		if (service->bannerContent) {
+			fputs(service->bannerContent, stdout);
+			fputs("\n", stdout);
+		}
+
+		debug("[server] Executing login for remote host: %s", peerName);
+
+		if (port) {
+			char portStr[16];
+			snprintf(portStr, sizeof(portStr), "%d", port);
+			execle("/bin/login", "login", "-p", "-h", peerName, "-P", portStr, "-R", "CLI",
+			       (void *)0, environment);
+			execle("/usr/bin/login", "login", "-p", "-h", peerName, "-P", portStr, "-R", "CLI",
+			       (void *)0, environment);
+		} else {
+			execle("/bin/login", "login", "-p", "-h", peerName, "-R", "CLI", (void *)0,
+			       environment);
+			execle("/usr/bin/login", "login", "-p", "-h", peerName, "-R", "CLI", (void *)0,
+			       environment);
+		}
+		debug("[server] Failed to exec login: %s", strerror(errno));
+	} else {
+		// Launch user provied service
+		execService(width, height, service, peerName, realIP, environment, url);
+	}
+	_exit(1);
