+// (encoded_len * 3) / 4 is the maximum decoded base64 size, +4 for safety margin
+#define BASE64_DECODED_BUFSIZE(encoded_len) (((encoded_len) * 3) / 4 + 4)
+
+static int base64url_decode(const char *src, unsigned char *dest, size_t dest_len)
+{
+	size_t len         = strlen(src);
+	size_t padding_len = (4 - (len % 4)) % 4;
+	size_t temp_len    = len + padding_len;
+	char *temp         = calloc(temp_len + 1, sizeof(char));
+	if (!temp)
+		return -1;
+	memcpy(temp, src, len);
+
+	for (size_t i = 0; i < len; i++) {
+		if (temp[i] == '-') {
+			temp[i] = '+';
+		} else if (temp[i] == '_') {
+			temp[i] = '/';
+		}
+	}
+
+	if (padding_len > 0) {
+		memset(temp + len, '=', padding_len);
+	}
+	temp[temp_len] = '\0';
+
+	int ret = b64_decode(temp, dest, dest_len);
+	free(temp);
+	return ret;
+}
+
+static size_t write_callback(void *contents, size_t size, size_t nmemb, void *resp)
+{
+	size_t realsize           = size * nmemb;
+	struct memory_struct *mem = (struct memory_struct *)resp;
+
+	char *ptr = realloc(mem->memory, mem->size + realsize + 1);
+	if (!ptr) {
+		return 0;
+	}
+
+	mem->memory = ptr;
+	memcpy(mem->memory + mem->size, contents, realsize);
+	mem->size += realsize;
+	mem->memory[mem->size] = 0;
+
+	return realsize;
+}
+
+static int oauth2_get_jwk_by_kid(_oauth2_session *session, const char *kid)
+{
+	CURL *curl;
+	CURLcode res;
+	long http_code;
+	char *url                  = session->jwks_uri;
+	struct memory_struct chunk = { 0 };
+	int ret                    = OAUTH2_ERR;
+
+	if (!url || url[0] == '\0') {
+		return OAUTH2_ERR;
+	}
+
+	curl_global_init(CURL_GLOBAL_ALL);
+	curl = curl_easy_init();
+	if (!curl) {
+		return OAUTH2_ERR;
+	}
+
+	curl_easy_setopt(curl, CURLOPT_URL, url);
+	curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, write_callback);
+	curl_easy_setopt(curl, CURLOPT_WRITEDATA, (void *)&chunk);
+	res = curl_easy_perform(curl);
+	if (res != CURLE_OK) {
+		goto free_all;
+	}
+
+	curl_easy_getinfo(curl, CURLINFO_RESPONSE_CODE, &http_code);
+	if (http_code != 200) {
+		goto free_all;
+	}
+
+	curl_easy_cleanup(curl);
+	curl_global_cleanup();
+
+	struct json_object *root_obj = json_tokener_parse(chunk.memory);
+	if (root_obj == NULL) {
+		goto free_chunk;
+	}
+
+	struct json_object *keys_obj;
+	if (!json_object_object_get_ex(root_obj, "keys", &keys_obj)) {
+		goto free_json;
+	}
+
+	int keys_len                = json_object_array_length(keys_obj);
+	struct json_object *key_obj = NULL;
+	const char *key_kid         = NULL;
+
+	for (int i = 0; i < keys_len; i++) {
+		key_obj                     = json_object_array_get_idx(keys_obj, i);
+		struct json_object *kid_obj = NULL;
+		if (json_object_object_get_ex(key_obj, "kid", &kid_obj))
+			key_kid = json_object_get_string(kid_obj);
+
+		if (key_kid != NULL && !strcmp(kid, key_kid))
+			break;
+
+		key_obj = NULL;
+		key_kid = NULL;
+	}
+
+	if (key_obj == NULL) {
+		goto free_json;
+	}
+
+	struct json_object *n_obj = NULL;
+	struct json_object *e_obj = NULL;
+	if (json_object_object_get_ex(key_obj, "n", &n_obj) &&
+	    json_object_object_get_ex(key_obj, "e", &e_obj)) {
+		const char *n_value = json_object_get_string(n_obj);
+		const char *e_value = json_object_get_string(e_obj);
+		if (!n_value || !e_value) {
+			goto free_json;
+		}
+
+		session->jwks_n = strdup(n_value);
+		session->jwks_e = strdup(e_value);
+		if (!session->jwks_n || !session->jwks_e) {
+			goto free_json;
+		}
+
+		ret = OAUTH2_OK;
+	}
+
+free_json:
+	json_object_put(root_obj);
+free_chunk:
+	free(chunk.memory);
+	return ret;
+
+free_all:
+	curl_easy_cleanup(curl);
+	curl_global_cleanup();
+	free(chunk.memory);
+	return OAUTH2_ERR;
+}
