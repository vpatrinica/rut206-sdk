+static void serve_javascript(struct client *cl)
+{
+	char *userCSSString = strdup("[]");
+
+	char state_vars[1024];
+	snprintf(state_vars, sizeof(state_vars),
+		 "serverSupportsSSL = %s;\n"
+		 "disableSSLMenu    = %s;\n"
+		 "linkifyURLs       = %d;\n"
+		 "userCSSList       = %s;\n"
+		 "serverMessagesOrigin = false;\n\n",
+		 cl->tls ? "true" : "false", cl->tls ? "true" : "false", linkifyURLs, userCSSString);
+
+	free(userCSSString);
+
+	size_t state_vars_len = strlen(state_vars);
+	size_t content_length = state_vars_len + (sizeof(vt100Start) - 1) + (sizeof(shellInABoxStart) - 1);
+
+	ustream_printf(cl->us, "HTTP/1.1 200 OK\r\n");
+	ustream_printf(cl->us, "Content-Type: text/javascript; charset=utf-8\r\n");
+	ustream_printf(cl->us, "Content-Length: %zu\r\n", content_length);
+	ustream_printf(cl->us, "\r\n");
+
+	if (cl->request.method != UH_HTTP_MSG_HEAD) {
+		ustream_write(cl->us, state_vars, state_vars_len, false);
+		ustream_write(cl->us, vt100Start, sizeof(vt100Start) - 1, false);
+		ustream_write(cl->us, shellInABoxStart, sizeof(shellInABoxStart) - 1, false);
+	}
+
+	ops->request_done(cl);
+}
+
+static void serve_stylesheet(struct client *cl)
+{
+	if (!cssStyleSheet) {
+		serve_static_file(cl, "text/css; charset=utf-8", stylesStart,
+				  stylesStart + sizeof(stylesStart) - 1);
+	} else {
+		size_t css_len = strlen(cssStyleSheet);
+		ustream_printf(cl->us, "HTTP/1.1 200 OK\r\n");
+		ustream_printf(cl->us, "Content-Type: text/css; charset=utf-8\r\n");
+		ustream_printf(cl->us, "Content-Length: %zu\r\n", css_len);
+		ustream_printf(cl->us, "\r\n");
+
+		if (cl->request.method != UH_HTTP_MSG_HEAD) {
+			ustream_write(cl->us, cssStyleSheet, css_len, false);
+		}
+
+		ops->request_done(cl);
+	}
+}
+
+static int shell_data_send(struct client *cl, const char *data, int len)
+{
+	struct dispatch *d	       = &cl->dispatch;
+	struct shell_dispatch_data *dd = (struct shell_dispatch_data *)d->req_data;
+
+	if (!dd) {
+		return 0;
+	}
+
+	dd->post_data = realloc(dd->post_data, dd->post_len + len + 1);
+	if (!dd->post_data) {
+		return 0;
+	}
+
+	memcpy(dd->post_data + dd->post_len, data, len);
+	dd->post_len += len;
+	dd->post_data[dd->post_len] = '\0';
+
+	return len;
+}
+
+static void shell_data_done(struct client *cl)
+{
+	struct dispatch *d	       = &cl->dispatch;
+	struct shell_dispatch_data *dd = (struct shell_dispatch_data *)d->req_data;
+
+	if (!dd) {
+		ops->client_error(cl, 500, "Internal Error", "No dispatch data");
+		return;
+	}
+
+	process_ajax_request(cl, dd->post_data);
+}
+
+static void shell_request_free(struct client *cl)
+{
+	struct dispatch *d	       = &cl->dispatch;
+	struct shell_dispatch_data *dd = (struct shell_dispatch_data *)d->req_data;
+
+	if (dd) {
+		if (dd->session && dd->session->client == cl) {
+			dd->session->client = NULL;
+		}
+		if (dd->url_path) {
+			SAFE_FREE(dd->url_path);
+		}
+		if (dd->post_data) {
+			SAFE_FREE(dd->post_data);
+		}
+		free(dd);
+		d->req_data = NULL;
+	}
+}
+
+static void serve_root_page(struct client *cl)
+{
+	char *userCSSString = strdup("[]");
+	char state_vars[2048];
+	snprintf(state_vars, sizeof(state_vars),
+		 "<script>\n"
+		 "serverSupportsSSL = %s;\n"
+		 "disableSSLMenu    = %s;\n"
+		 "linkifyURLs       = %d;\n"
+		 "userCSSList       = %s;\n"
+		 "serverMessagesOrigin = false;\n"
+		 "</script>\n",
+		 cl->tls ? "true" : "false", cl->tls ? "true" : "false", linkifyURLs, userCSSString);
+	free(userCSSString);
+
+	size_t html_size = strlen(rootPageStart) + strlen(state_vars) + 1;
+	char *html   = calloc(html_size, sizeof(char));
+	if (!html) {
+		ops->client_error(cl, 500, "Internal Error", "Out of memory");
+		return;
+	}
+	snprintf(html, html_size, rootPageStart, state_vars);
+
+	size_t content_length = strlen(html);
+
+	ustream_printf(cl->us, "HTTP/1.1 200 OK\r\n");
+	ustream_printf(cl->us, "Content-Type: text/html; charset=utf-8\r\n");
+	ustream_printf(cl->us, "Content-Length: %zu\r\n", content_length);
+	ustream_printf(cl->us, "\r\n");
+
+	if (cl->request.method != UH_HTTP_MSG_HEAD) {
+		ustream_write(cl->us, html, content_length, false);
+	}
+
+	free(html);
+	ops->request_done(cl);
+}
+
+static void handle_shell_request(struct client *cl, const char *path)
+{
+	if (!path) {
+		ops->client_error(cl, 400, "Bad Request", "Invalid path");
+		return;
+	}
+	int path_len = strlen(path);
+
+	if (path_len == 0 || strcasecmp(path, "/cgi-bin/cli") == 0 ||
+	    strcasecmp(path, "/cgi-bin/cli/") == 0 || strcasecmp(path, "/cli") == 0 ||
+	    strcasecmp(path, "/cli/") == 0 || (path_len == 5 && !strncasecmp(path, "plain", 5)) ||
+	    (path_len == 6 && !strncasecmp(path, "secure", 6))) {
+		serve_root_page(cl);
+		return;
+	}
+
+	if (strcasestr(path, "/shellinabox.js")) {
+		serve_javascript(cl);
+		return;
+	}
+	if (strcasestr(path, "/styles.css")) {
+		serve_stylesheet(cl);
+		return;
+	}
+	if (strcasestr(path, "/print-styles.css")) {
+		serve_static_file(cl, "text/css; charset=utf-8", printStylesStart,
+				  printStylesStart + printStylesSize - 1);
+		return;
+	}
+	if (strcasestr(path, "/enabled.gif")) {
+		extern const char enabledStart[];
+		extern const int enabledSize;
+		serve_static_file(cl, "image/gif", enabledStart, enabledStart + enabledSize - 1);
+		return;
+	}
+
+	ops->client_error(cl, 404, "Not Found", "File not found");
+}
+
+static void shell_handle_request(struct client *cl, char *url, struct path_info *pi)
+{
+	struct dispatch *d = &cl->dispatch;
+	(void)pi;
+
+	char *path = url;
+
+	char *query = strchr(path, '?');
+	if (query) {
+		*query = '\0';
+	}
+	switch (cl->request.method) {
+	case UH_HTTP_MSG_GET:
+		handle_shell_request(cl, url);
+		break;
+	case UH_HTTP_MSG_POST: {
+		struct shell_dispatch_data *dd = calloc(1, sizeof(struct shell_dispatch_data));
+		if (!dd) {
+			ops->client_error(cl, 500, "Internal Error", "Out of memory");
+			return;
+		}
+		dd->url_path = strdup(url);
+		dd->session = NULL;  // Will be set if used for long-polling
+		d->req_data  = dd;
+		d->data_send = shell_data_send;
+		d->data_done = shell_data_done;
+		d->req_free  = shell_request_free;
+		return;
+	}
+	case UH_HTTP_MSG_HEAD:
+		break;
+	default:
+		ops->client_error(cl, 405, "Method Not Allowed", "Unsupported method");
+		return;
+	}
+}
+
+static bool shell_check_url(const char *url)
+{
+	return ops->path_match(conf.cli_prefix, url);
+}
+
+static int shell_plugin_init(const struct uhttpd_ops *o, struct config *c)
+{
+	ops   = o;
+	_conf = c;
+
+	if (read_uci_config() < 0) {
+		fatal("Failed to read UCI configuration\n");
+		return -1;
+	}
+
+	if (!cli_enabled) {
+		warn("CLI access is disabled in configuration\n");
+		return 0;
+	}
+
+	if (numServices == 0) {
+		serviceTable = newHashMap(destroyServiceHashEntry, NULL);
+		if (!getHashmapSize(serviceTable)) {
+			addToHashMap(serviceTable, "/", (char *)newService(":LOGIN", system_banner));
+		}
+
+		enumerateServices(serviceTable);
+	}
+
+	cgi_session_key	 = newSessionKey();
+	cleanup_timer.cb = cleanup_timeout;
+	uloop_timeout_set(&cleanup_timer, 30000);
+
+	cssStyleSheet = strdup(stylesStart);
+
+	shell_dispatch.check_url      = shell_check_url;
+	shell_dispatch.handle_request = shell_handle_request;
+	ops->dispatch_add(&shell_dispatch);
+
+	return 0;
+}
+
+static void shell_post_init(void)
+{
+	return;
+}
+
+static void shell_plugin_free(void)
+{
+	if (ops && ops->dispatch_remove) {
+		ops->dispatch_remove(&shell_dispatch);
+	}
+
+	uloop_timeout_cancel(&cleanup_timer);
+
+	terminateLauncher();
+
+	cleanup_uci();
+
+	// Free resources
+	if (cssStyleSheet) {
+		free(cssStyleSheet);
+		cssStyleSheet = NULL;
+	}
+
+	if (system_banner) {
+		free(system_banner);
+		system_banner = NULL;
+	}
+}
+
+struct uhttpd_plugin uhttpd_plugin = {
+	.init	   = shell_plugin_init,
+	.post_init = shell_post_init,
+	.free	   = shell_plugin_free,
+};
