-void sym_init(void)
-{
-	struct symbol *sym;
-	char *p;
-	static bool inited = false;
-
-	if (inited)
-		return;
-	inited = true;
-
-	sym = sym_lookup("VERSION", 0);
-	sym->type = S_STRING;
-	sym->flags |= SYMBOL_AUTO;
-	p = getenv("VERSION");
