+get_wifi_ap_interwork_venuetype() {
+	local venue_group="$1"
+	local venue_type="$2"
+
+	if [ "$venue_group" = "Unspecified" ]; then
+		echo "Unspecified"
+	elif [ "$venue_group" = "Assembly" ]; then
+		case "$venue_type" in
+			1) echo "Arena" ;;
+			2) echo "Stadium" ;;
+			3) echo "PassengerTerminal" ;;
+			4) echo "Amphitheater" ;;
+			5) echo "AmusementPark" ;;
+			6) echo "PlaceOfWorship" ;;
+			7) echo "ConventionCenter" ;;
+			8) echo "Library" ;;
+			9) echo "Museum" ;;
+			10) echo "Restaurant" ;;
+			11) echo "Theater" ;;
+			12) echo "Bar" ;;
+			13) echo "CoffeeShop" ;;
+			14) echo "ZooOrAquarium" ;;
+			15) echo "EmergencyCoordinationCenter" ;;
+			*) echo "UnspecifiedAssembly" ;;
+		esac
+	elif [ "$venue_group" = "Business" ]; then
+		case "$venue_type" in
+			1) echo "DoctorOrDentistOffice" ;;
+			2) echo "Bank" ;;
+			3) echo "FireStation" ;;
+			4) echo "PoliceStation" ;;
+			6) echo "PostOffice" ;;
+			7) echo "ProfessionalOffice" ;;
+			8) echo "ResearchAndDevelopmentFacility" ;;
+			9) echo "AttorneyOffice" ;;
+			*) echo "UnspecifiedBusiness" ;;
+		esac
+	elif [ "$venue_group" = "Educational" ]; then
+		case "$venue_type" in
+			1) echo "SchoolPrimary" ;;
+			2) echo "SchoolSecondary" ;;
+			3) echo "UniversityOrCollege" ;;
+			*) echo "UnspecifiedEducational" ;;
+		esac
+	elif [ "$venue_group" = "Factory-Industrial" ]; then
+		case "$venue_type" in
