+
+void pty_read_cb(struct uloop_fd *fd, unsigned int events)
+{
+	struct Session *session = container_of(fd, struct Session, pty_fd_uloop);
+
+	if (!session) {
+		return;
+	}
+
+	if (events & ULOOP_READ) {
+		handle_session_data(session);
+	}
+	
+	if (fd->eof || fd->error) {
+		session->done = 1;
+
+		if (session->client) {
+			complete_pending_request(session, "", 0, 4096);
+		} else if (session->len == 0) {
+			session->dead_without_client = 1;
+			addToGraveyard(session, 0);
+			checkGraveyard();
+		}
+		
+		cleanup_session_pty(session);
+	}
+}
