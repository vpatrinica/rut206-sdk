diff --recursive --unified --new-file --no-dereference --exclude .gitver upstream/doc/modbus_set_response_timeout.txt src/doc/modbus_set_response_timeout.txt
--- upstream/doc/modbus_set_response_timeout.txt	2019-07-31 21:17:38.000000000 +0000
