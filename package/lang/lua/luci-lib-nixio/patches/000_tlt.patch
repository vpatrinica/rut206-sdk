-		title = e.getAttribute("tiddler");
-	if(!title && e.id) {	
-		var lenPrefix = store.idPrefix.length;
-		if (e.id.substr(0,lenPrefix) == store.idPrefix)
-			title = e.id.substr(lenPrefix);
