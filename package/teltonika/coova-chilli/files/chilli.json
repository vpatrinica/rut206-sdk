{
  "user": "chilli",
  "access": {
    "ip_block": {
      "methods": ["push_mac", "unblock_mac"]
    },
    "network.wireless": {
      "methods": ["status"]
    },
    "gsm.modem*": {
      "methods": ["info", "send_sms"]
    },
    "gsm": {
      "methods": ["info"]
    }
  },
  "publish": ["chilli", "chilli.*"],
  "send": ["chilli.*"],
  "subscribe": ["hostapd.*"],
  "listen": ["ubus.object.add", "ubus.object.remove"]
}
