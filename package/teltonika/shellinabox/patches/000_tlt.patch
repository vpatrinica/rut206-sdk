-          "  APP     := "
-#ifdef HAVE_BIN_LOGIN
-                        "'LOGIN' | "
-#endif
-                                   "'SSH' [ : <host> ] | "
-                        "USER ':' CWD ':' CMD\n"
-          "  USER    := %s<username> ':' <groupname>\n"
