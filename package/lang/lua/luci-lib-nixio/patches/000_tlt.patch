-static char * cgi_filetype_match(struct connstruct *cn, const char *fn)
-{
-    struct cgiextstruct *tp = cgiexts;
-
-    while (tp != NULL) 
-    {
-        char *t;
-
-        if ((t = strstr(fn, tp->ext)) != NULL)
-        {
-            t += strlen(tp->ext);
-
-            if (*t == '/' || *t == '\0')
-            {
-#ifdef CONFIG_HTTP_ENABLE_LUA
-                if (strcmp(tp->ext, ".lua") == 0 || strcmp(tp->ext, ".lp") == 0)
-                    cn->is_lua = 1;
-#endif
-
-                return t;
-            }
-            else
-                return NULL;
-
-        }
-
-        tp = tp->next;
-    }
-
-    return NULL;
-}
