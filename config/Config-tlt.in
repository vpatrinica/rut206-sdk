config WIFI_SUPPORT
	bool "WiFi"
	maintainer "Networks/Networks1"
	label "WiFi"
	imply PACKAGE_iwinfo
	imply PACKAGE_wireless-tools if USES_VENDOR_WIFI_DRIVER
	imply PACKAGE_vuci-app-channel-analysis-ui
	imply PACKAGE_wpad-openssl if !USES_VENDOR_WIFI_DRIVER
	imply PACKAGE_vuci-app-wireless-ui
	imply PACKAGE_multiple_ap if !AP_DEVICE && !USES_VENDOR_WIFI_DRIVER
	detail
		Modes: Access Point (AP)
		Access Point: WMM
		Encryptions: WPA-PSK, WPA2-PSK, WPA2-PPSK, WPA3-SAE, WPA-EAP, WPA2-EAP, WPA3-EAP, OWE
		Ciphers: Auto, CCMP (AES), TKIP
		Features: Credentials QR code generator
	detail if !USES_VENDOR_WIFI_DRIVER
		Access Point: \, Fast transition (802.11r), Radio Resource Measurement (802.11k), BSS Transition Management (802.11v), Client isolation, Hide SSID, MAC filter
		Modes: \, Mesh (802.11s)
		Features: \, WDS
	detail if ADVANCED_NETWORK && !USES_VENDOR_WIFI_DRIVER
		Modes: \, Client (STA), Multi AP
		EAP Methods: TLS (with PKCS#12 format support), TTLS, PEAP, FAST
		Features: \, Fast roaming

