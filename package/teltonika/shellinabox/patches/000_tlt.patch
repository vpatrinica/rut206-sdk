-struct Server *newCGIServer(int localhostOnly, int portMin, int portMax,
-                            int timeout) {
-  struct Server *server;
-  check(server = malloc(sizeof(struct Server)));
-  initServer(server, localhostOnly, portMin, portMax, timeout);
-  return server;
-}
