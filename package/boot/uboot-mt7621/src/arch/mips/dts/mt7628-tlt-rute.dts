/dts-v1/;

#include "mt7628a.dtsi"

/ {
	compatible = "mediatek,mt7628-rfb", "ralink,mt7628a-soc";
	model = "MediaTek MT7628 RFB";

	aliases {
		serial0 = &uart0;
		spi0 = &spi0;
	};

	chosen {
		stdout-path = &uart0;
	};
};

&pinctrl {
	state_default: pin_state {
		pleds {
			groups = "p0led", "p1led", "p2led", "p3led", "p4led";
			function = "led";
		};
	};
};

&uart0 {
	status = "okay";
};

&spi0 {
	status = "okay";
	num-cs = <2>;

	spi-flash@0 {
		#address-cells = <1>;
		#size-cells = <1>;
		compatible = "jedec,spi-nor";
		spi-max-frequency = <25000000>;
		reg = <0>;


		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			boot: boot: partition@0 {
				label = "u-boot";
				reg = <0x0 0x40000>;
			};

			config: partition@40000 {
				label = "config";
				reg = <0x040000 0x010000>;
			};

			factory: partition@50000 {
				label = "factory";
				reg = <0x050000 0x030000>;
			};

			partition@60000 {
				label = "firmware";
				reg = <0x080000 0x1ed0000>;
			};

			partition@f70000 {
				label = "event-log";
				reg = <0x1f50000 0x80000>;
			};
		};

	};
};

&eth {
	pinctrl-names = "default";
	pinctrl-0 = <&ephy_router_mode>;
};

&mmc {
	bus-width = <4>;
	cap-sd-highspeed;

	pinctrl-names = "default";
	pinctrl-0 = <&sd_router_mode>;

	status = "okay";
};

&i2c {
	status = "okay";
	sda-gpios = <&gpio0 5 1>;
	scl-gpios = <&gpio0 4 1>;

	stm_gpio: gpio@75 {
		compatible = "tlt,rut204-stm";
		reg = <0x75>;
		gpio-controller;
		#gpio-cells = <2>;
		status = "okay";
	};

};
