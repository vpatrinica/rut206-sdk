config MOBILE_UTILS_SUPPORT
	bool "Mobile Utilities"
	label "Mobile Utilities"
	maintainer "Apps/Apps1"
	depends on MOBILE_SUPPORT
	default y
	imply PACKAGE_mobutils
	imply PACKAGE_vuci-app-mobile-utilities-ui
	imply PACKAGE_mobutils-call_utilities
	imply PACKAGE_vuci-app-call-utilities-ui
	imply PACKAGE_mobutils-sms_utilities
	imply SMS_UTILS_HANDLER_IO if IO_SUPPORT
	imply SMS_UTILS_HANDLER_WIFI if WIFI_SUPPORT
	imply SMS_UTILS_HANDLER_GPS if GPS_SUPPORT
	imply CALL_UTILS_HANDLER_IO if IO_SUPPORT
	imply CALL_UTILS_HANDLER_WIFI if WIFI_SUPPORT
	detail
		SMS Utilities: Rules that perform certain actions when they are activated by SMS messages
		SMS Forwarding: To HTTP, SMS and Email
		Email To SMS: Connects to your email account and checks its inbox at the specified frequency. If it finds any new received emails with a specific subject (phone number in email subject), it sends the body of the email as an SMS message(s) to the recipient specified in the email subject field.
		Auto Reply: Automatic replying to SMS messages that the device receives
		Messages: Sending and reading of SMS messages
		Call Utilities: Rules that perform certain actions when they are activated by a call
	tooltip value
		Call Utilities: Feature availability varies by order code

