+static void send_empty_response(struct client *cl)
+{
+	if (!cl || !cl->us) return;
+	
+	char *empty_json = "{\"session\":\"\",\"data\":\"\"}";
+	ustream_printf(cl->us, "HTTP/1.1 200 OK\r\n");
+	ustream_printf(cl->us, "Content-Type: application/json; charset=utf-8\r\n");
+	ustream_printf(cl->us, "Content-Length: %d\r\n", (int)strlen(empty_json));
+	ustream_printf(cl->us, "Access-Control-Allow-Origin: *\r\n");
+	ustream_printf(cl->us, "\r\n");
+	ustream_write(cl->us, empty_json, strlen(empty_json), false);
+	ops->request_done(cl);
+}
+
+static void send_json_response(struct client *cl, const char *session_key, const char *data)
+{
+	if (!cl || !cl->us) {
+		return;
+	}
+
+	if (!session_key)
+		session_key = "";
+	if (!data)
+		data = "";
+
+	int needed = snprintf(NULL, 0, "{\"session\":\"%s\",\"data\":\"%s\"}", session_key, data);
+	char *json = calloc(1, needed + 1);
+	if (!json) {
+		ops->client_error(cl, 500, "Internal Error", "Out of memory");
+		return;
+	}
+
+	snprintf(json, needed + 1, "{\"session\":\"%s\",\"data\":\"%s\"}", session_key, data);
+
+	ustream_printf(cl->us, "HTTP/1.1 200 OK\r\n");
+	ustream_printf(cl->us, "Content-Type: application/json; charset=utf-8\r\n");
+	ustream_printf(cl->us, "Content-Length: %d\r\n", needed);
+	ustream_printf(cl->us, "Access-Control-Allow-Origin: *\r\n");
+	ustream_printf(cl->us, "\r\n");
+
+	if (cl->request.method != UH_HTTP_MSG_HEAD) {
+		ustream_write(cl->us, json, needed, false);
+	}
+
+	free(json);
+	ops->request_done(cl);
+}
+
+static void complete_pending_request(struct Session *session, const char *data, int len, int max_len)
+{
+	if (!session || !session->client)
+		return;
+
+	struct client *current_client = session->client;
+	session->client		      = NULL;
+
+	if (!current_client || !current_client->us) {
+		return;
+	}
+
+	int effective_max = session->done ? len : max_len;
+
+	char *escaped = calloc(len * 6 + 1, sizeof(char));  // Worst case
+	if (!escaped) {
+		send_json_response(current_client, session->sessionKey, "");
+		return;
+	}
+
+	int j	     = 0;
+	int send_len = (effective_max < len) ? effective_max : len;
+
+	for (int i = 0; i < send_len; i++) {
+		unsigned char c = data[i];
+		if (c == '\\' || c == '"') {
+			escaped[j++] = '\\';
+			escaped[j++] = c;
+		} else if (c == '\n') {
+			escaped[j++] = '\\';
+			escaped[j++] = 'n';
+		} else if (c == '\r') {
+			escaped[j++] = '\\';
+			escaped[j++] = 'r';
+		} else if (c == '\t') {
+			escaped[j++] = '\\';
+			escaped[j++] = 't';
+		} else if (c == '\b') {
+			escaped[j++] = '\\';
+			escaped[j++] = 'b';
+		} else if (c == '\f') {
+			escaped[j++] = '\\';
+			escaped[j++] = 'f';
+		} else if (c < 32 || c == 127) {
+			j += sprintf(&escaped[j], "\\u%04x", c);
+		} else {
+			escaped[j++] = c;
+		}
+	}
+	escaped[j] = '\0';
+
+	send_json_response(current_client, session->sessionKey, escaped);
+	free(escaped);
+
+	if (send_len < len) {
+		char *remaining = calloc(1, len - send_len + 1);
+		if (remaining) {
+			memcpy(remaining, data + send_len, len - send_len);
+			remaining[len - send_len] = '\0';
+
+			free(session->buffered);
+			session->buffered = remaining;
+			session->len	  = len - send_len;
+		}
+	} else {
+		SAFE_FREE(session->buffered);
+		session->len = 0;
+
+		if (session->done) {
+			session->cleanup	     = 1;
+			session->dead_without_client = 1;
+			cleanup_session_pty(session);
+			addToGraveyard(session, 5);
+		}
+	}
+}
+
+static void handle_session_data(struct Session *session)
+{
+	if (!session || session->pty < 0) {
+		return;
+	}
+
+	char buffer[1024];
+	ssize_t bytes = read(session->pty, buffer, sizeof(buffer) - 1);
+
+	if (bytes > 0) {
+		buffer[bytes] = '\0';
+
+		if (session->client) {
+			complete_pending_request(session, buffer, bytes, 4096);
+		} else {
+			char *new_buffered = realloc(session->buffered, session->len + bytes + 1);
+			if (new_buffered) {
+				session->buffered = new_buffered;
+				memcpy(session->buffered + session->len, buffer, bytes);
+				session->len += bytes;
+				session->buffered[session->len] = '\0';
+			}
+		}
+	} else if (bytes == 0 || (bytes < 0 && errno == EIO)) {
+		session->done = 1;
+		if (session->len > 0 && session->client) {
+				complete_pending_request(session, session->buffered, session->len, session->len);
+		} else if (session->client) {
+			complete_pending_request(session, "", 0, 4096);
+		} else {
+			session->cleanup = 1;
+			cleanup_session_pty(session);
+			addToGraveyard(session, 5);
+		}
+
+		if (session->client == NULL && session->pty >= 0) {
+			cleanup_session_pty(session);
+		}
+	}
+}
