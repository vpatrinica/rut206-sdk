menu "Target firmware features"

#
# Mobile management
#

config MOBILE_SUPPORT
	bool "Mobile Connection Management"
	label "Mobile Management"
	maintainer "Mobile"
	imply PACKAGE_gsmctl
	imply PACKAGE_mobifd
	imply PACKAGE_apn_db
	imply PACKAGE_rpcd-mod-smslimit
	imply PACKAGE_uqmi if !HAVE_QRTR_PIPE_ENDPOINTS
	imply PACKAGE_qmi-utils if HAVE_QRTR_PIPE_ENDPOINTS
	imply PACKAGE_vuci-app-mobile-ui
	imply PACKAGE_mctl
	imply PACKAGE_urcd
	imply PACKAGE_ppp if PPP_MOBILE_SUPPORT
	imply BUSYBOX_CONFIG_FEATURE_NETIFD
	detail
		Band Management: Provides mobile band locking for different network types
		Network Type Management: Offers the ability to lock different network types
		Block/Allow List: Offers operator block/allow listing by country or individual operators
		Operator Selection Modes: Module connection modes including auto, manual, and manual-auto
		APN: Implemented automatic APN selection with the option for manual APN configuration
		Multiple PDN: Enables the use of different PDNs for multiple network access and services
		VoLTE: Provides control of VoLTE service
		SMS Limit: Offers control over the number of SMS messages that can be sent within a certain period
		USSD: Ensures sending and reading Unstructured Supplementary Service Data messages
		Status: IMSI, ICCID, operator, operator state, data connection state, network type, bandwidth, connected band,
		Status: signal strength (RSSI), SINR, RSRP, RSRQ, EC/IO, RSCP, mobile signal graphs, data sent/received, LAC, TAC,
		Status: cell ID, ARFCN, UARFCN, EARFCN, MCC, and MNC
		Deny Data on Roaming: Offers mobile data prohibition when module registers on a roaming network
		Low Signal Reconnect: Ensures mobile data reconnection in case of poor signal
		Modem Debug: Enable access to modem debug with AT commands
		Bridge Mode: Direct connection (bridge) between mobile ISP and device on LAN
		Passthrough Mode: Router assigns it's mobile WAN IP address to another device on LAN
	detail if FRAMED_ROUTING
		Framed Routing: Supports an IP network behind a 5G UE
	tooltip value
		Band Management: Availability varies by order code
		Network Type Management: Availability varies by order code
		Block/Allow List: Availability varies by order code
		Operator Selection Modes: Availability varies by order code
		Multiple PDN: Availability varies by order code
		VoLTE: Availability varies by order code
		USSD: Availability varies by order code
		Low Signal Reconnect: Availability varies by order code
	tooltip value if GATEWAY_DEVICE
		Bridge Mode: Availability varies by order code
		Passthrough Mode: Availability varies by order code

