+###########################################
+# Device.NAT.PortMapping Dynamic portmaps #
+###########################################
+
+sub_entry_nat_portmap_dynamic_staticnodes() {
+	local table="$2"
+
+	case_param "$1" belongto "$DMROOT.NAT.PortMapping.Dynamic." && {
+		local table="$(ubus call api get '{"path":"/upnp/global"}' | \
+			     jsonfilter -e '@.http_body.data')"
+		local enabled="$(echo "$table" | jsonfilter -e '@.enabled')"
+		local status="Disabled"
+
+		[ "$enabled" = "1" ] && status="Enabled"
+
+		common_execute_method_obj "$DMROOT.NAT.PortMapping.Dynamic." "0" "" ""
+		common_execute_method_param "$DMROOT.NAT.PortMapping.Dynamic.Enable" "1" \
+			"echo $enabled" "set_nat_portmap_dynamic_enable" "xsd:boolean"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.Dynamic.Status" "0" \
+			"echo $status" "" "xsd:string"
+		return 0;
+	}
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+set_nat_portmap_dynamic_enable() {
+	local input="$1"
+
+	if [ "$input" = "true" ]; then
+		input="1"
+	elif [ "$input" = "false" ]; then
+		input="0"
+	elif [ "$input" != "0" -a "$input" != "1" ]; then
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+
+	json_load "$(ubus call api put '{
+		     "path":"/upnp/global",
+		     "body":{"data":{"enabled":"'$input'"}}
+		     }')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+delete_nat_portmap_dynamic() {
+	local id="$1"
+
+	json_load "$(ubus call api delete '{"path":"/upnp/redirects/config/'$id'"}')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+sub_entry_nat_portmap_dynamic_multinodes() {
+	local i="$2"
+	local lease="$3"
+	local line_num="$4"
+
+	case_param "$1" belongto "$DMROOT.NAT.PortMapping.$i." && {
+		local duration="$(echo "$lease" | awk -F: '{print $5}')"
+		local remaining="$(echo "$lease" | awk -F: -v now="$(date +%s)" '{print $5-now}')"
+		local external_port="$(echo "$lease" | awk -F: '{print $2}')"
+		local internal_port="$(echo "$lease" | awk -F: '{print $4}')"
+		local proto="$(echo "$lease" | awk -F: '{print $1}')"
+		local internal_client="$(echo "$lease" | awk -F: '{print $3}')"
+		local desc="$(echo "$lease" | awk -F: '{print $6}')"
+
+		common_execute_method_obj "$DMROOT.NAT.PortMapping.$i." "1" \
+			"" "delete_nat_portmap_dynamic $line_num"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.Origin" "0" \
+			"echo UPnP" "" "xsd:string"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.LeaseDuration" "0" \
+			"echo $duration" "" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.RemainingLeaseTime" "0" \
+			"echo $remaining" "" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.RemoteHost" "0" \
+			"" "" "xsd:string"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.ExternalPort" "0" \
+			"echo $external_port" "" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.ExternalPortEndRange" "0" \
+			"echo $external_port" "" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.InternalPort" "0" \
+			"echo $internal_port" "" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.Protocol" "0" \
+			"echo $proto" "" "xsd:string"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.InternalClient" "0" \
+			"echo $internal_client" "" "xsd:string"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.Description" "0" \
+			"echo $desc" "" "xsd:string"
+		return 0;
+	}
+	return $E_INVALID_PARAMETER_NAME;
+}
