-/* Decode string %xx -> char (in place) */
-static void urldecode(char *buf) 
-{
-    int v;
-    char *p, *s, *w;
-
-    w = p = buf;
-
-    while (*p) 
-    {
-        v = 0;
-
-        if (*p == '%') 
-        {
-            s = p;
-            s++;
-
-            if (isxdigit((int) s[0]) && isxdigit((int) s[1]))
-            {
-                v = hexit(s[0])*16 + hexit(s[1]);
-
-                if (v) 
-                { 
-                    /* do not decode %00 to null char */
-                    *w = (char)v;
-                    p = &s[1];
-                }
-            }
-
-        }
-
-        if (!v) *w=*p;
-        p++; 
-        w++;
-    }
-
-    *w='\0';
-}
-
-static int hexit(char c) 
-{
-    if (c >= '0' && c <= '9')
-        return c - '0';
-    else if (c >= 'a' && c <= 'f')
-        return c - 'a' + 10;
-    else if (c >= 'A' && c <= 'F')
-        return c - 'A' + 10;
-    else
-        return 0;
-}
