+            add_definitions(-DAZ_TPM_SUPPORT)
+        else()
+            message(WARNING, "The TPM support is only available with Openssl version >= 3.0. Your current version is ${OPENSSL_VERSION}")
+        endif()
+    endif()
+
     include_directories(${OPENSSL_INCLUDE_DIR})
 endif()
 
