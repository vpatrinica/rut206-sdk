+static void url_decode(const char *src, char *dst, size_t dst_size)
+{
+	char a, b;
+	size_t i = 0, j = 0;
+
+	if (!src || !dst)
+		return;
+
+	while (src[i] && j < dst_size - 1) {
+		if (src[i] == '%') {
+			if (src[i + 1] && src[i + 2]) {
+				a = src[i + 1];
+				b = src[i + 2];
+				if (isxdigit(a) && isxdigit(b)) {
+					if (a >= 'a')
+						a -= 'a' - 'A';
+					if (a >= 'A')
+						a -= ('A' - 10);
+					else
+						a -= '0';
+					if (b >= 'a')
+						b -= 'a' - 'A';
+					if (b >= 'A')
+						b -= ('A' - 10);
+					else
+						b -= '0';
+					dst[j++] = 16 * a + b;
+					i += 3;
+				} else {
+					dst[j++] = src[i++];
+				}
+			} else {
+				dst[j++] = src[i++];
+			}
+		} else if (src[i] == '+') {
+			dst[j++] = ' ';
+			i++;
+		} else {
+			dst[j++] = src[i++];
+		}
+	}
+	dst[j] = '\0';
+}
+
+static int safe_atoi(const char *str, int default_value)
+{
+	if (!str || !*str) {
+		return default_value;
+	}
+
+	char *endptr;
+	long value = strtol(str, &endptr, 10);
+
+	// Check if the conversion was successful and within the range of an int
+	if (*endptr != '\0' || value < INT_MIN || value > INT_MAX) {
+		return default_value;
+	}
+
+	return (int)value;
+}
+
+static void parse_url_args(struct client *cl, const char *data, char **session_key, char **keys,
+			   char **width_str, char **height_str, char **root_url)
+{
+	*session_key = NULL;
+	*keys	     = NULL;
+	*width_str   = NULL;
+	*height_str  = NULL;
+	*root_url    = NULL;
+
+	if (!data) {
+		return;
+	}
+
+	char *data_copy = strdup(data);
+	if (!data_copy) {
+		return;
+	}
+
+	// Parse the data as query string format (key=value&key=value)
+	char *query = data_copy;
+
+	char *token = strtok(query, "&");
+	while (token) {
+		char *eq = strchr(token, '=');
+		if (eq) {
+			*eq	    = '\0';
+			char *key   = token;
+			char *value = eq + 1;
+
+			// URL decode value
+			char *decoded = calloc(4096, sizeof(char));
+			if (!decoded) {
+				SAFE_FREE(data_copy);
+				return;
+			}
+			url_decode(value, decoded, 4096);
+
+			if (strcmp(key, "session") == 0) {
+				*session_key = strdup(decoded);
+			} else if (strcmp(key, "keys") == 0) {
+				*keys = strdup(decoded);
+			} else if (strcmp(key, "width") == 0) {
+				*width_str = strdup(decoded);
+			} else if (strcmp(key, "height") == 0) {
+				*height_str = strdup(decoded);
+			} else if (strcmp(key, "rooturl") == 0) {
+				*root_url = strdup(decoded);
+			}
+			SAFE_FREE(decoded);
+		}
+		token = strtok(NULL, "&");
+	}
+
+	SAFE_FREE(data_copy);
 }
