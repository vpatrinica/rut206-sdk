config FIREWALL_SUPPORT
	bool "Firewall"
	maintainer "Networks/Networks1"
	label "Firewall"
	depends on !AP_DEVICE
	default y
	imply PACKAGE_vuci-app-firewall-ui
	imply PACKAGE_iptables-mod-conntrack-extra
	imply PACKAGE_kmod-nf-nathelper-extra
	imply PACKAGE_kmod-nf-nathelper
	imply PACKAGE_kmod-ipt-raw6
	imply PACKAGE_ip6tables-mod-nat
	detail
		Firewall: IPv4, IPv6, connection tracking, routing/NAT offloading, statefull firewall, logging, zone based firewall, custom rules, DMZ, firewall statistics, rules list, tables list
		Port Forward: By port/protocol/IP address, NAT loopback
		Traffic Rules: Time-based restrictions, input/output/forward control, by protocol/port/IP address/MAC address
		Targets: Accept, drop, reject, do not track, mark, change TTL, change DSCP
		NAT Rules: Source NAT, destination NAT, PAT, static NAT, dynamic NAT, NAT mapping
		Tables: Raw, mangle, nat, filter
		Attack Prevention: DDOS prevention, SYN flood protection, SSH attack prevention, HTTP/HTTPS attack prevention, port scan prevention (SYN-FIN, SYN-RST, X-mas, NULL flags, FIN scan attacks)
		Conntrack Helpers: FTP, PPTP, SIP, SNMP, TFTP, IRC

