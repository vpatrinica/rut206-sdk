-static void httpSetState(struct HttpConnection *http, int state) {
-  if (state == (int)http->state) {
-    return;
-  }
-
-  if (state == COMMAND) {
-    if (http->state != SNIFFING_SSL) {
-      int rc                 = httpFinishCommand(http);
-      check(rc != HTTP_SUSPEND);
-      check(rc != HTTP_PARTIAL_REPLY);
-    }
-    check(!http->private);
-    free(http->url);
-    free(http->method);
-    free(http->path);
-    free(http->matchedPath);
-    free(http->pathInfo);
-    free(http->query);
-    free(http->version);
-    http->done               = 0;
-    http->url                = NULL;
-    http->method             = NULL;
-    http->path               = NULL;
-    http->matchedPath        = NULL;
-    http->pathInfo           = NULL;
-    http->query              = NULL;
-    http->version            = NULL;
-    destroyHashMap(&http->header);
-    initHashMap(&http->header, httpDestroyHeaders, NULL);
-    http->headerLength       = 0;
-    http->callback           = NULL;
-    http->arg                = NULL;
-    http->totalWritten       = 0;
-    http->code               = 200;
-  }
-  http->state                = state;
-}
