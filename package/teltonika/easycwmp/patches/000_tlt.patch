+	local parameter=""
+	local value=""
+
+	OLD_IFS="$IFS"
+	IFS=$'\n'
+	for iface in $g_easycwmp_ip_ifaces; do
+		value="$(echo "$iface" | jsonfilter -e '@.value')"
