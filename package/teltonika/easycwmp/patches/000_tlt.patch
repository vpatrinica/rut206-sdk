+#####################################
+#  Device.WiFi.AccessPoint.Security #
+#####################################
+
+get_wifi_ap_security_modes() {
+	local modes="$1"
+	local mode="None,WPA-Personal,WPA2-Personal,WPA-WPA2-Personal,"
+
+	[ "$(echo "$modes" | jsonfilter -e '@.ap_owe')" = "true" ] &&
+		mode="${mode}OWE,"
+	[ "$(echo "$modes" | jsonfilter -e '@.ap_sae')" = "true" ] &&
+		mode="${mode}WPA3-Personal,WPA3-Personal-Transition,"
+	[ "$(echo "$modes" | jsonfilter -e '@.ap_eap192')" = "true" ] &&
+		mode="${mode}WPA3-Enterprise,"
+	[ "$(echo "$modes" | jsonfilter -e '@.ap_eap')" = "true" ] &&
+		mode="${mode}WPA-Enterprise,WPA2-Enterprise,"
+
+	mode="${mode%,}"
+	echo "$mode"
+}
+
+set_wifi_ap_security_mode() {
+	local id="$1"
+	local input="$2"
+
+	case "$input" in
+		None) input="none" ;;
+		OWE) input="owe" ;;
+		WPA-Personal) input="psk" ;;
+		WPA2-Personal) input="psk2" ;;
+		WPA-WPA2-Personal) input="psk-mixed" ;;
+		WPA3-Personal) input="sae" ;;
+		WPA3-Personal-Transition) input="sae-mixed" ;;
+		WPA-Enterprise) input="wpa" ;;
+		WPA2-Enterprise) input="wpa2" ;;
+		WPA3-Enterprise) input="wpa3" ;;
+		*) return $E_INVALID_PARAMETER_VALUE ;;
+	esac
+
+	set_wifi_ap_value "$id" "encryption" "$input"
+}
+
+set_wifi_ap_security_encryption() {
+	local id="$1"
+	local encryption="$2"
+	local input="$3"
+
+	case "$input" in
+		TKIP,AES|AES,TKIP) input="tkip+ccmp" ;;
+		TKIP) input="tkip" ;;
+		AES) input="ccmp" ;;
+		*) return $E_INVALID_PARAMETER_VALUE ;;
+	esac
+
+	case "$encryption" in
+		WPA3-Personal|WPA3-Personal-Transition|WPA3-Enterprise)
+			[ "$input" != "ccmp" ] && return $E_INVALID_PARAMETER_VALUE
+			;;
+	esac
+
+	set_wifi_ap_value "$id" "cipher" "$input"
+}
+
+set_wifi_ap_security_presharedkey() {
+	local id="$1"
+	local input="$2"
+
+	[ "${#input}" -ne 64 ] && return $E_INVALID_PARAMETER_VALUE
+
+	case "$input" in
+		*[!0-9A-Fa-f]*) return $E_INVALID_PARAMETER_VALUE ;;
+	esac
+
+	set_wifi_ap_value "$id" "key" "$input"
+}
+
+set_wifi_ap_security_keypass() {
+	local id="$1"
+	local input="$2"
+
+	[ "${#input}" -lt 8 ] || [ "${#input}" -gt 63 ] && return $E_INVALID_PARAMETER_VALUE
+
+	set_wifi_ap_value "$id" "key" "$input"
+}
+
+set_wifi_ap_security_mfpconfig() {
+	local id="$1"
+	local input="$2"
+
+	case "$input" in
+		Disabled) input="0" ;;
+		Optional) input="1" ;;
+		Required) input="2" ;;
+		*) return $E_INVALID_PARAMETER_VALUE ;;
+	esac
+
+	set_wifi_ap_value "$id" "ieee80211w" "$input"
+}
