-          "  CMD     := 'SHELL' | <cmdline>\n"
-          "\n"
-          "<cmdline> supports variable expansion:\n"
-          "  ${columns} - number of columns\n"
-          "  ${gid}     - gid id\n"
-          "  ${group}   - group name\n"
-          "  ${home}    - home directory\n"
-          "  ${lines}   - number of rows\n"
-          "  ${peer}    - name of remote peer\n"
-          "  ${realip}  - value of HTTP header field 'X-Real-IP'\n"
