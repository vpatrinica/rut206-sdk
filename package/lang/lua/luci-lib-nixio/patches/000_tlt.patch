diff --recursive --unified --new-file --no-dereference --exclude .gitver upstream/files/luci-add-conffiles.sh src/files/luci-add-conffiles.sh
--- upstream/files/luci-add-conffiles.sh	1970-01-01 00:00:00.000000000 +0000
+++ src/files/luci-add-conffiles.sh	2026-01-28 11:44:37.000000000 +0000
@@ -0,0 +1,16 @@
+add_luci_conffiles()
+{
+	local filelist="$1"
+
+	# save ssl certs
+	if [ -d /etc/nixio ]; then
+		find /etc/nixio -type f >> $filelist
+	fi
+
+	# save uhttpd certs
+	[ -f "/etc/uhttpd.key" ] && echo /etc/uhttpd.key >> $filelist
+	[ -f "/etc/uhttpd.crt" ] && echo /etc/uhttpd.crt >> $filelist
+}
+
+sysupgrade_init_conffiles="$sysupgrade_init_conffiles add_luci_conffiles"
+
