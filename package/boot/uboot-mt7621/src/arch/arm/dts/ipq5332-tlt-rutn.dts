#include "ipq5332-default.dts"

/ {
	model = "Teltonika RUTN";
	compatible = "teltonika,rutn", "qcom,ipq5332";

	soc: soc {
		tlmm: pinctrl@1000000 {
			mdio_pinmux: mdio {
				mdc {
					pins = "GPIO_27";
					function = "mdc_1";
					drive-strength = <DRIVE_STRENGTH_2MA>;
					bias-pull-up;
				};

				mdio {
					pins = "GPIO_28";
					function = "mdio_1";
					drive-strength = <DRIVE_STRENGTH_2MA>;
					bias-pull-up;
				};
			};

			phy_rst_pinmux: phy_rst {
				qti_8x8x_rst {
					pins = "GPIO_51";
					drive-strength = <DRIVE_STRENGTH_8MA>;
					bias-pull-up;
				};

				qti_8081_rst {
					pins = "GPIO_22";
					drive-strength = <DRIVE_STRENGTH_8MA>;
					bias-pull-up;
				};
			};

			blsp1_i2c_pinmux: blsp1_i2c_pins {
				blsp1_scl {
					pins = "GPIO_29";
					function = "blsp1_i2c_scl0";
					drive-strength = <DRIVE_STRENGTH_8MA>;
					bias-pull-up;
				};

				blsp1_sda {
					pins = "GPIO_30";
					function = "blsp1_i2c_sda0";
					drive-strength = <DRIVE_STRENGTH_8MA>;
					bias-pull-up;
				};
			};
		};

		blsp1_i2c: i2c@78B6000 {
			pinctrl-names = "default";
			pinctrl-0 = <&blsp1_i2c_pinmux>;
			status = "okay";
		};

		mdio: mdio@90000 {
			pinctrl-names = "default";
			pinctrl-0 = <&mdio_pinmux>;
			status = "okay";

			phy0: ethernet-switch@1 {
				phy-reset-gpio = <&tlmm 51 0>;
				dev-mode = <0x1>;
				reg = <1>;
				phy_id = <QCA8x8x_SWITCH_TYPE>;
				id = <1>;
				uniphy_id = <0>;
				uniphy_type = <0>;
				max_speed = <2500>;
				force-speed;
				xgmac;
				ports {
					#address-cells = <1>;
					#size-cells = <0>;

					port0: port@0 {
						reg = <0>;
						label = "cpu";
						phy-mode = "sgmii-2500";
						fixed-link {
							speed = <2500>;
							full-duplex;
						};
					};

					port1: port@1 {
						reg = <1>;
						label = "lan";
					};

					port2: port@2 {
						reg = <2>;
						label = "lan";
					};

					port3: port@3 {
						reg = <3>;
						label = "lan";
					};

					port4: port@4 {
						reg = <4>;
						label = "lan";
					};
				};
			};

			phy1: phy@12 {
				phy-reset-gpio = <&tlmm 22 0>;
				reg = <12>;
				phy_id = <QCA8081_PHY_TYPE>;
				id = <2>;
				uniphy_id = <1>;
				uniphy_type = <0>;
				max_speed = <2500>;
				xgmac;
			};
		};

		ethernet: nss-switch {
			pinctrl-names = "default";
			pinctrl-0 = <&phy_rst_pinmux>;
			phy-handle0 = <&phy0>;
			phy-handle1 = <&phy1>;
			status = "okay";
		};
	};
};

&blsp1_spi {
	spi_nor@0 {
		#address-cells = <1>;
		#size-cells = <1>;
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <10000000>;
		
		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@00000 {
				label = "xbl";
				reg = <0x00000 0x80000>;
			};

			partition@80000 {
				label = "system-partition";
				reg = <0x80000 0x10000>;
			};

			partition@90000 {
				label = "bootconfig";
				reg = <0x90000 0x10000>;
			};

			partition@a0000 {
				label = "qsee";
				reg = <0xa0000 0x170000>;
			};

			partition@210000 {
				label = "devcfg";
				reg = <0x210000 0x10000>;
			};

			partition@220000 {
				label = "tmel";
				reg = <0x220000 0x20000>;
			};

			partition@240000 {
				label = "cdt";
				reg = <0x240000 0x10000>;
			};

			partition@250000 {
				label = "u-boot-env";
				reg = <0x250000 0x10000>;
			};

			partition@260000 {
				label = "u-boot";
				reg = <0x260000 0x90000>;
			};

			partition@2f0000 {
				label = "bootconfig1";
				reg = <0x2f0000 0x10000>;
			};

			partition@300000 {
				label = "art";
				reg = <0x300000 0x100000>;
			};

			partition@400000 {
				label = "config";
				reg = <0x400000 0x10000>;
			};

			partition@410000 {
				label = "bootconfig-a";
				reg = <0x410000 0x10000>;
			};

			partition@420000 {
				label = "bootconfig-b";
				reg = <0x420000 0x10000>;
			};

			partition@430000 {
				label = "_event-log";
				reg = <0x430000 0x90000>;
			};

			partition@4c0000 {
				label = "recovery";
				reg = <0x4c0000 0xb40000>;
			};
		};
	};
};
