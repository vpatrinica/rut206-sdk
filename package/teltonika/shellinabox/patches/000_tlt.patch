+} * graveyard;
+
+void addToGraveyard(struct Session *session, int timeout_seconds)
+{
+	// It is possible for a child process to die, but for the Session to
+	// linger around, because the browser has also navigated away and thus
+	// nobody ever calls completePendingRequest(). We put these Sessions into
+	// the graveyard and reap them after a while.
+
+	if (session->in_graveyard) {
+		return;
+	}
+	
+	struct Graveyard *g;
+	check(g = calloc(1, sizeof(struct Graveyard)));
+	g->next	      = graveyard;
+	g->timeout    = time(NULL) + timeout_seconds;
+	g->sessionKey = strdup(session->sessionKey);
+	graveyard     = g;
+	session->in_graveyard = 1;
+}
+
+static void checkGraveyardInternal(int expireAll)
+{
+	if (!graveyard) {
+		return;
+	}
+
+	time_t current_time = time(NULL);
+	time_t threshold;
+
+	if (expireAll) {
+		threshold = current_time + 2 * AJAX_TIMEOUT;
+	} else {
+		threshold = current_time;
+	}
+
+	struct Graveyard **g = &graveyard;
+	while (*g) {
+		struct Graveyard *old = *g;
+		if (old->timeout <= threshold) {
+			*g = old->next;
+			char *key = (char *)old->sessionKey;
+			old->sessionKey = NULL;
+			free(old);
+			deleteFromHashMap(sessions, key);
+			free(key);
+		} else {
+			g = &old->next;
+		}
+	}
+}
+
+void checkGraveyard(void)
+{
+	checkGraveyardInternal(0);
+}
+
+void initSession(struct Session *session, const char *sessionKey, struct client *cl, const char *peerName)
+{
+	check(session->sessionKey = strdup(sessionKey)); // CRITICAL: Must duplicate, not shallow copy!
+	session->client = cl;
+	check(session->peerName = strdup(peerName));
+	session->done	      = 0;
+	session->pty	      = -1;
+	session->ptyFirstRead = 1;
+	session->width	      = 0;
+	session->height	      = 0;
+	session->buffered     = NULL;
+	session->useLogin     = 0;
+	session->port	      = 0;
+	session->len	      = 0;
+	session->pid	      = 0;
+	session->cleanup      = 0;
+	session->dead_without_client = 0;
+	session->in_graveyard = 0;
+	memset(&session->pty_fd_uloop, 0, sizeof(session->pty_fd_uloop));
+	memset(&session->timeout, 0, sizeof(session->timeout));
+}
+
+struct Session *newSession(const char *sessionKey, struct client *cl, const char *peerName)
+{
+	struct Session *session;
+	check(session = calloc(1, sizeof(struct Session)));
+	initSession(session, sessionKey, cl, peerName);
+	return session;
+}
+
+void destroySession(struct Session *session)
+{
+	if (session) {
+		uloop_timeout_cancel(&session->timeout);
+		if (session->pty >= 0) {
+			uloop_fd_delete(&session->pty_fd_uloop);
+			NOINTR(close(session->pty));
+		}
+		free((char *)session->sessionKey);
+		free((char *)session->peerName);
+	}
+}
+
+void deleteSession(struct Session *session)
+{
+	destroySession(session);
+	free(session);
+}
+
+void abandonSession(struct Session *session)
+{
+	deleteFromHashMap(sessions, session->sessionKey);
+}
+
+void finishSession(struct Session *session)
+{
+	deleteFromHashMap(sessions, session->sessionKey);
+}
+
+void finishAllSessions(void)
+{
+	checkGraveyardInternal(1);
+	deleteHashMap(sessions);
+}
+
+static void destroySessionHashEntry(void *arg ATTR_UNUSED, char *key ATTR_UNUSED, char *value)
+{
+	UNUSED(arg);
+	UNUSED(key);
+	deleteSession((struct Session *)value);
+}
+
+char *newSessionKey(void)
+{
+	int fd;
+	check((fd = NOINTR(open("/dev/urandom", O_RDONLY))) >= 0);
+	unsigned char buf[16];
+	check(NOINTR(read(fd, buf, sizeof(buf))) == sizeof(buf));
+	NOINTR(close(fd));
+	char *sessionKey;
+	check(sessionKey = calloc(1, (8 * sizeof(buf) + 5) / 6 + 1));
+	char *ptr = sessionKey;
+	int count = 0;
+	int bits  = 0;
+	for (unsigned i = 0;;) {
+		bits = (bits << 8) | buf[i];
+		count += 8;
+drain:
+		while (count >= 6) {
+			*ptr++ = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdef"
+				 "ghijklmnopqrstuvwxyz0123456789-/"[(bits >> (count -= 6)) & 0x3F];
+		}
+		if (++i >= sizeof(buf)) {
+			if (count && i == sizeof(buf)) {
+				bits <<= 8;
+				count += 8;
+				goto drain;
+			} else {
+				break;
+			}
+		}
+	}
+	*ptr = '\000';
+	check(!sessions || !getFromHashMap(sessions, sessionKey));
+	return sessionKey;
+}
+
+struct Session *findSession(const char *sessionKey, const char *cgiSessionKey, int *sessionIsNew,
+			    struct client *cl)
+{
+	*sessionIsNew = 1;
+
+	if (!sessions) {
+		sessions = newHashMap(destroySessionHashEntry, NULL);
+	}
+
+	struct Session *session = NULL;
+
+	if (cgiSessionKey && (!sessionKey || strcmp(cgiSessionKey, sessionKey))) {
+		// In CGI mode, we only ever allow exactly one session with a
+		// pre-negotiated key.
+		// Return NULL for invalid CGI sessions
+		return NULL;
+	}
+
+	if (sessionKey && *sessionKey) {
+		session = (struct Session *)getFromHashMap(sessions, sessionKey);
+	}
+
+	if (session) {
+		*sessionIsNew = 0;
+		return session;
+	}
+
+	if (!cgiSessionKey && sessionKey && *sessionKey) {
+		*sessionIsNew = 0;
+		debug("[server] Failed to find session: %s", sessionKey);
+		return NULL;
+	}
+
+	// First contact. Create session now.
+	char *newSessionKeyStr = NULL;
+	if (!sessionKey || !*sessionKey) {
+		if (cgiSessionKey) {
+			newSessionKeyStr = strdup(cgiSessionKey);
+		} else {
+			newSessionKeyStr = newSessionKey();
+		}
+		sessionKey = newSessionKeyStr;
+	}
+
+	char ip_str[INET_ADDRSTRLEN];
+	if (cl && cl->peer_addr.family == AF_INET) {
+		struct sockaddr_in *sin = (struct sockaddr_in *)&cl->peer_addr;
+		if (!inet_ntop(AF_INET, &sin->sin_addr, ip_str, sizeof(ip_str))) {
+			snprintf(ip_str, sizeof(ip_str), "unknown");
+		}
+	} else if (cl && cl->peer_addr.family == AF_INET6) {
+		struct sockaddr_in6 *sin6 = (struct sockaddr_in6 *)&cl->peer_addr;
+		if (!inet_ntop(AF_INET6, &sin6->sin6_addr, ip_str, sizeof(ip_str))) {
+			snprintf(ip_str, sizeof(ip_str), "unknown");
+		}
+	} else {
+		snprintf(ip_str, sizeof(ip_str), "unknown");
+	}
+
+	session = newSession(sessionKey, cl, ip_str);
+	if (!session) {
+		debug("[server] Failed to create session: %s", sessionKey);
+		free(newSessionKeyStr);
+		return NULL;
+	}
+
+	// CRITICAL: Use session->sessionKey (which is a strdup) as the hashmap key, not the local sessionKey variable!
+	// The hashmap stores the key pointer directly, so it must point to memory that won't be freed.
+	addToHashMap(sessions, session->sessionKey, (const char *)session);
+	debug("[server] Creating a new session: %s", session->sessionKey);
+
+	free(newSessionKeyStr);
+	return session;
+}
+
+void iterateOverSessions(int (*fnc)(void *, const char *, char **), void *arg)
+{
+	iterateOverHashMap(sessions, fnc, arg);
+}
+
+int numSessions(void)
+{
+	if (!sessions) {
+		return 0;
+	}
+	return getHashmapSize(sessions);
 }
