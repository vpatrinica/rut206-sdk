+	Device.DeviceInfo.ProcessStatus.CPUUsage)
+	get_misc_cpu_usage
+	return 0
+	;;
+	Device.DeviceInfo.ProcessStatus.ProcessNumberOfEntries)
+	get_misc_process_number
+	return 0
+	;;
+esac
+return $E_INVALID_PARAMETER_NAME
+}
