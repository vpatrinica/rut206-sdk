+static void show_error_message_fmt(struct Session *session, struct client *cl,
+                                   const char *title, int width, int height,
+                                   const char *format, ...)
+{
+	if (!session || !cl) return;
+
+	session->client = cl;
+	session->useLogin = 0;
+	session->width = width;
+	session->height = height;
+
+	char message[256];
+	va_list args;
+	va_start(args, format);
+	vsnprintf(message, sizeof(message), format, args);
+	va_end(args);
+
+	char buffer[512];
+	int len = snprintf(buffer, sizeof(buffer),
+		"\r\n\x1b[1;31m"
+		"========================================\r\n"
+		"        %s\r\n"
+		"========================================\x1b[0m\r\n"
+		"\r\n"	
+		"%s\r\n",
+		title, message);
+
+	if (len >= sizeof(buffer)) {
+		len = sizeof(buffer) - 1;
+		buffer[len] = '\0';
+	}
+
+	free(session->buffered);
+
+	session->buffered = strdup(buffer);
+	session->len = session->buffered ? strlen(session->buffered) : 0;
+	session->done = 1;
+
+	complete_pending_request(session, session->buffered, session->len, session->len);
+	session->cleanup = 1;
+	addToGraveyard(session, 5);
+}
