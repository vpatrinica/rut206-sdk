diff --recursive --unified --new-file --no-dereference --exclude .gitver upstream/ext/openwrt/scripts/functions/tr181/nat src/ext/openwrt/scripts/functions/tr181/nat
--- upstream/ext/openwrt/scripts/functions/tr181/nat	1970-01-01 00:00:00.000000000 +0000
+++ src/ext/openwrt/scripts/functions/tr181/nat	2026-03-25 10:23:48.000000000 +0000
@@ -0,0 +1,479 @@
+#!/bin/sh
+
+#common_execute_method_param "$parameter" "$permission" "$get_cmd" "$set_cmd" "xsd:$type" "$forcedinform"
+#  $forcedinform should be set to 1 if the parameter is included in the inform message otherwise empty
+#  Default of $type = string
+
+#############################
+#   Entry point functuons   #
+#############################
+
+prefix_list="$prefix_list $DMROOT.NAT."
+entry_execute_method_list="$entry_execute_method_list entry_execute_method_root_NAT"
+entry_execute_method_list_forcedinform="$entry_execute_method_list_forcedinform  entry_execute_method_root_NAT"
+
+###############
+#  Device.NAT #
+###############
+
+entry_execute_method_root_NAT() {
+	case "$1" in ""|"$DMROOT."|"$DMROOT.NAT."*)
+		common_execute_method_obj "$DMROOT.NAT." "0"
+		common_execute_method_param "$DMROOT.NAT.PortMappingNumberOfEntries" "0" \
+			"get_nat_portmap_noe" "" "xsd:unsignedInt"
+		common_execute_method_obj "$DMROOT.NAT.PortMapping." "1" \
+			"add_nat_portmap" "" "count_nat_portmap_obj $1"
+		return 0;
+		;;
+	esac
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+get_nat_portmap_noe() {
+	json_load "$(ubus call api get '{"path":"/firewall/port_forwards/config"}')"
+	json_select http_body
+	json_select data
+	json_get_keys keys
+
+	keys="${keys##* }"
+	[ -z "$keys" ] && keys=0
+
+	[ ! -f "/etc/config/upnpd" ] && {
+		echo "$keys"
+		return 0
+	}
+
+	config_load upnpd
+	config_get lease_file config upnp_lease_file
+	local count="$(grep -c ':' < $lease_file)"
+	keys=$((keys + count))
+
+	echo "$keys"
+}
+
+###########################
+#  Device.NAT.PortMapping #
+###########################
+
+add_nat_portmap() {
+	json_load "$(ubus call api post '{
+		     "path":"/firewall/port_forwards/config",
+		     "body":{"data":{}}
+		     }')"
+	json_select http_body
+	json_get_var success success
+	[ "$success" != "1" ] && return $E_INVALID_PARAMETER_VALUE
+
+	json_load "$(ubus call api get '{"path":"/firewall/port_forwards/config"}')"
+	json_select http_body
+	json_select data
+	json_get_keys keys
+
+	keys="${keys##* }"
+	if [ -n "$keys" ]; then
+		echo "$keys"
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+delete_nat_portmap() {
+	local id="$1"
+
+	json_load "$(ubus call api delete '{"path":"/firewall/port_forwards/config/'$id'"}')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+count_nat_portmap_obj() {
+	local i=1
+	local forwards="$(ubus call api get '{"path":"/firewall/port_forwards/config"}' | \
+			  jsonfilter -e '@.http_body.data[*]')"
+
+	OLD_IFS="$IFS"
+	IFS=$'\n'
+	for table in $forwards; do
+		IFS="$OLD_IFS"
+		sub_entry_nat_portmap_static "$1" "$i" "$table"
+		i=$((i + 1))
+		IFS=$'\n'
+	done
+	IFS="$OLD_IFS"
+
+	[ ! -f "/etc/config/upnpd" ] && return 0
+
+	config_load upnpd
+	config_get lease_file config upnp_lease_file
+
+	local leases="$(cat $lease_file)"
+	local line_num=1
+	for lease in $leases; do
+		sub_entry_nat_portmap_dynamic_multinodes "$1" "$i" "$lease" "$line_num"
+		i=$((i + 1))
+		line_num=$((line_num + 1))
+	done
+
+	sub_entry_nat_portmap_dynamic_staticnodes "$1"
+}
+
+##########################################
+# Device.NAT.PortMapping Static portmaps #
+##########################################
+
+sub_entry_nat_portmap_static() {
+	local i="$2"
+	local table="$3"
+
+	case_param "$1" belongto "$DMROOT.NAT.PortMapping.$i." && {
+		local id="$(echo "$table" | jsonfilter -e '@.id')"
+		local enabled="$(echo "$table" | jsonfilter -e '@.enabled')"
+		local status="Disabled"
+		local src_ip="$(echo "$table" | jsonfilter -e '@.src_ip[0]')"
+		local src_dport="$(echo "$table" | jsonfilter -e '@.src_dport')"
+		local dest_port="$(echo "$table" | jsonfilter -e '@.dest_port')"
+		local proto="$(echo "$table" | jsonfilter -e '@.proto[0]')"
+		local dest_ip="$(echo "$table" | jsonfilter -e '@.dest_ip')"
+		local name="$(echo "$table" | jsonfilter -e '@.name')"
+
+		[ "$enabled" = "1" ] && status="Enabled"
+
+		local src_dport_start="${src_dport%-*}"
+		[ -z "$src_dport_start" ] && src_dport_start=0
+
+		local src_dport_end="${src_dport#*-}"
+		[ -z "$src_dport_end" ] || [ "$src_dport_end" = "$src_dport" ] && src_dport_end=0
+
+		dest_port="${dest_port%-*}"
+
+		if [ "$proto" = "tcp" ]; then
+			proto="TCP"
+		elif [ "$proto" = "udp" ]; then
+			proto="UDP"
+		else
+			proto="Other"
+		fi
+
+		common_execute_method_obj "$DMROOT.NAT.PortMapping.$i." "1" \
+			"" "delete_nat_portmap $id"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.Enable" "1" \
+			"echo $enabled" "set_nat_portmap_static_enable $id" "xsd:boolean"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.Origin" "0" \
+			"echo User" "" "xsd:string"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.Status" "0" \
+			"echo $status" "" "xsd:string"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.LeaseDuration" "0" \
+			"echo 0" "" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.RemainingLeaseTime" "0" \
+			"echo 0" "" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.RemoteHost" "1" \
+			"echo $src_ip" "set_nat_portmap_static_remotehost $id" "xsd:string"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.ExternalPort" "1" \
+			"echo $src_dport_start" \
+			"set_nat_portmap_static_externalport $id '$src_dport_end' '$dest_port'" \
+			"xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.ExternalPortEndRange" "1" \
+			"echo $src_dport_end" \
+			"set_nat_portmap_static_externalportend $id '$src_dport_start' '$dest_port'" \
+			"xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.InternalPort" "1" \
+			"get_nat_portmap_static_internalport $dest_port $src_dport_start" \
+			"set_nat_portmap_static_internalport $id '$src_dport_start' '$src_dport_end'" \
+			"xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.Protocol" "1" \
+			"echo $proto" "set_nat_portmap_static_proto $id" "xsd:string"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.InternalClient" "1" \
+			"echo $dest_ip" "set_nat_portmap_static_value $id dest_ip" "xsd:string"
+		common_execute_method_param "$DMROOT.NAT.PortMapping.$i.Description" "1" \
+			"echo $name" "set_nat_portmap_static_description $id" "xsd:string"
+		return 0;
+	}
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+set_nat_portmap_static_value() {
+	local id="$1"
+	local key="$2"
+	local input="$3"
+
+	json_load "$(ubus call api put '{
+		     "path":"/firewall/port_forwards/config/'$id'",
+		     "body":{"data":{"'$key'":"'"$input"'"}}
+		     }')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+set_nat_portmap_static_enable() {
+	local id="$1"
+	local input="$2"
+
+	if [ "$input" = "true" ]; then
+		input=1
+	elif [ "$input" = "false" ]; then
+		input=0
+	elif [ "$input" != "1" -a "$input" != "0" ]; then
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+
+	set_nat_portmap_static_value "$id" enabled "$input"
+}
+
+set_nat_portmap_static_remotehost() {
+	local id="$1"
+	local input="[\"$2\"]"
+
+	json_load "$(ubus call api put '{
+		     "path":"/firewall/port_forwards/config/'$id'",
+		     "body":{"data":{"src_ip":'$input'}}
+		     }')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+set_nat_portmap_static_two_values() {
+	local id="$1"
+	local key1="$2"
+	local input1="$3"
+	local key2="$4"
+	local input2="$5"
+
+	json_load "$(ubus call api put '{
+		     "path":"/firewall/port_forwards/config/'$id'",
+		     "body":{"data":{"'$key1'":"'$input1'","'$key2'":"'$input2'"}}
+		     }')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+set_nat_portmap_static_externalport() {
+	local id="$1"
+	local dport_end="$2"
+	local dest_port="$3"
+	local input="$4"
+
+	[ -z "$input" ] || [ "$input" != "${input##*[!0-9]*}" ] ||
+	[ "$input" -gt 65535 ] || [ "$input" -lt 0 ] && return $E_INVALID_PARAMETER_VALUE
+
+	[ "$input" -eq 0 ] && {
+		set_nat_portmap_static_two_values "$id" "dest_port" "$dest_port" "src_dport" ""
+		return
+	}
+
+	[ "$dport_end" -eq 0 ] && {
+		set_nat_portmap_static_two_values "$id" "dest_port" "$dest_port" "src_dport" "$input"
+		return
+	}
+
+	[ "$input" -ge "$dport_end" ] && return $E_INVALID_PARAMETER_VALUE
+
+	local diff=$((dport_end - input))
+	[ -n "$dest_port" ] && {
+		local dest_port_end=$((dest_port + diff))
+		dest_port="${dest_port}-${dest_port_end}"
+	}
+	input="${input}-${dport_end}"
+
+	set_nat_portmap_static_two_values "$id" "dest_port" "$dest_port" "src_dport" "$input"
+}
+
+set_nat_portmap_static_externalportend() {
+	local id="$1"
+	local dport_start="$2"
+	local dest_port="$3"
+	local input="$4"
+
+	[ -z "$input" ] || [ "$input" != "${input##*[!0-9]*}" ] || [ "$input" -gt 65535 ] ||
+	[ "$input" -lt 0 ] || [ "$dport_start" -eq 0 ] && return $E_INVALID_PARAMETER_VALUE
+
+	[ "$input" -eq 0 ] && {
+		set_nat_portmap_static_two_values "$id" "dest_port" "$dest_port" "src_dport" "$dport_start"
+		return
+	}
+
+	[ "$input" -le "$dport_start" ] && return $E_INVALID_PARAMETER_VALUE
+
+	local diff=$((input - dport_start))
+	[ -n "$dest_port" ] && {
+		local dest_port_end=$((dest_port + diff))
+		dest_port="${dest_port}-${dest_port_end}"
+	}
+	input="${dport_start}-${input}"
+
+	set_nat_portmap_static_two_values "$id" "dest_port" "$dest_port" "src_dport" "$input"
+}
+
+get_nat_portmap_static_internalport() {
+	echo "$1"
+}
+
+set_nat_portmap_static_internalport() {
+	local id="$1"
+	local dport_start="$2"
+	local dport_end="$3"
+	local input="$4"
+
+	[ -z "$input" ] || [ "$input" != "${input##*[!0-9]*}" ] ||
+	[ "$input" -gt 65535 ] || [ "$input" -lt 0 ] && return $E_INVALID_PARAMETER_VALUE
+
+	[ "$dport_start" -ne 0 ] && [ "$dport_end" -ne 0 ] && {
+		local diff=$((dport_end - dport_start))
+		local dest_port_end=$((input + diff))
+		input="${input}-${dest_port_end}"
+	}
+
+	set_nat_portmap_static_value "$id" "dest_port" "$input"
+}
+
+set_nat_portmap_static_proto() {
+	local id="$1"
+	local input="$2"
+
+	case "$input" in
+		TCP) input="tcp" ;;
+		UDP) input="udp" ;;
+		*) return $E_INVALID_PARAMETER_VALUE ;;
+	esac
+	input="[\"$input\"]"
+
+	json_load "$(ubus call api put '{"path":"/firewall/port_forwards/config/'$id'",
+		     "body":{"data":{"proto":'$input'}}}')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+set_nat_portmap_static_description() {
+	local id="$1"
+	local input="$2"
+
+	[ "${#input}" -gt 256 ] && return $E_INVALID_PARAMETER_VALUE
+
+	set_nat_portmap_static_value "$id" name "$input"
+}
