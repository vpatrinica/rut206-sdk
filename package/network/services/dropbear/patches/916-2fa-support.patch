+++ b/src/svr-auth2fa.c
@@ -0,0 +1,190 @@
+#include "includes.h"
+#include "session.h"
+#include "buffer.h"
+#include "dbutil.h"
+#include "auth.h"
+#include "runopts.h"
+#include "ssh.h"
+#include "packet.h"
+
+#if DROPBEAR_SVR_2FA_SUPPORT
+
+#include <libubus.h>
+#include <libubox/blobmsg.h>
+
+#define MAX_2FA_RETRY 3
+#define UBUS_TIMEOUT  10000
+
+enum {
+	_2FA_RES,
+	_2FA_ACTIVE,
+	__2FA_MAX
+};
+
+static const struct blobmsg_policy _2fa_policy[__2FA_MAX] = {
+	[_2FA_RES]    = { .name = "res", .type = BLOBMSG_TYPE_BOOL },
+	[_2FA_ACTIVE] = { .name = "active", .type = BLOBMSG_TYPE_BOOL },
+};
+
+static void check_2fa_cb(struct ubus_request *req, int type, struct blob_attr *msg)
+{
+	(void)type;
+
+	bool *res = (bool *)req->priv;
+	struct blob_attr *tb[__2FA_MAX];
+
+	blobmsg_parse(_2fa_policy, __2FA_MAX, tb, blob_data(msg), blob_len(msg));
+
+	if (tb[_2FA_RES]) {
+		*res = blobmsg_get_bool(tb[_2FA_RES]);
+	} else if (tb[_2FA_ACTIVE]) {
+		*res = blobmsg_get_bool(tb[_2FA_ACTIVE]);
+	}
+}
+
+static bool status_2fa(struct ubus_context *ctx, char const *username)
+{
+	static struct blob_buf b = { 0 };
+	uint32_t id              = 0;
+	bool active              = false;
+
+	if (!username || !ctx || ubus_lookup_id(ctx, "totp", &id)) {
+		return active;
+	}
+
+	blob_buf_init(&b, 0);
+	blobmsg_add_string(&b, "username", username);
+	ubus_invoke(ctx, id, "status", b.head, check_2fa_cb, &active, UBUS_TIMEOUT);
+	blob_buf_free(&b);
+
+	return active;
+}
+
+static bool check_2fa(struct ubus_context *ctx, char const *username, const char *otp)
+{
+	static struct blob_buf b = { 0 };
+	uint32_t id              = 0;
+	bool res                 = false;
+
+	if (!username || !ctx || ubus_lookup_id(ctx, "totp", &id)) {
+		return res;
+	}
+
+	blob_buf_init(&b, 0);
+	blobmsg_add_string(&b, "username", username);
+	blobmsg_add_string(&b, "totp", otp);
+	ubus_invoke(ctx, id, "check", b.head, check_2fa_cb, &res, UBUS_TIMEOUT);
+	blob_buf_free(&b);
+
+	return res;
+}
+
+int svr_2fa_required(const char *username)
+{
+	struct ubus_context *ctx = ubus_connect(NULL);
+	bool required            = false;
+
+	if (ctx) {
+		required = status_2fa(ctx, username);
+		ubus_free(ctx);
+	}
+
+	return required ? 1 : 0;
+}
+
+void svr_auth_2fa(int valid_user)
+{
+	char *response;
+	unsigned int num_responses;
+	struct ubus_context *ctx = NULL;
+	bool totp_valid          = false;
+
+	TRACE(("enter svr_auth_2fa"))
+
+	if (ses.authstate.authtypes & AUTH_TYPE_2FA == 0) {
+		TRACE(("leave svr_auth_2fa: 2FA not required"))
+		return;
+	}
+
+	if (!valid_user) {
+		send_msg_userauth_failure(0, 1);
+		TRACE(("leave svr_auth_2fa: invalid user"))
+		return;
+	}
+
+	buf_eatstring(ses.payload); /* language tag */
+	buf_eatstring(ses.payload); /* submethods */
+
+	TRACE(("sending 2FA keyboard-interactive request"))
+
+	CHECKCLEARTOWRITE();
+
+	buf_putbyte(ses.writepayload, SSH_MSG_USERAUTH_INFO_REQUEST);
+	buf_putstring(ses.writepayload, "", 0); /* name */
+	buf_putstring(ses.writepayload, "", 0); /* instruction */
+	buf_putstring(ses.writepayload, "en", 2); /* language */
+	buf_putint(ses.writepayload, 1); /* number of prompts */
+	buf_putstring(ses.writepayload, "Enter one time password: ", 25);
+	buf_putbyte(ses.writepayload, 0); /* echo = false */
+
+	encrypt_packet();
+
+	TRACE(("leave svr_auth_2fa: sent info request"))
+}
+
+void svr_auth_2fa_response(void)
+{
+	char *response;
+	unsigned int num_responses;
+	struct ubus_context *ctx = NULL;
+	bool totp_valid          = false;
+
+	TRACE(("enter svr_auth_2fa_response"))
+
+	if (ses.authstate.authtypes & AUTH_TYPE_2FA == 0) {
+		TRACE(("leave svr_auth_2fa_response: 2FA not required"))
+		return;
+	}
+
+	num_responses = buf_getint(ses.payload);
+	if (num_responses != 1) {
+		dropbear_log(LOG_WARNING, "Bad number of responses for 2FA from %s", svr_ses.addrstring);
+		send_msg_userauth_failure(0, 1);
+		TRACE(("leave svr_auth_2fa_response: bad response count"))
+		return;
+	}
+
+	response = buf_getstring(ses.payload, NULL);
+
+	ctx = ubus_connect(NULL);
+	if (ctx) {
+		totp_valid = check_2fa(ctx, ses.authstate.pw_name, response);
+		ubus_free(ctx);
+	}
+
+	m_burn(response, strlen(response));
+	m_free(response);
+
+	if (totp_valid) {
+		dropbear_log(LOG_NOTICE, "2FA auth succeeded for '%s' from %s", ses.authstate.pw_name,
+		             svr_ses.addrstring);
+
+		ses.authstate.authtypes &= ~AUTH_TYPE_2FA;
+
+		if (ses.authstate.authtypes) {
+			/* More auth required (shouldn't happen in typical setup) */
+			send_msg_userauth_failure(1, 0); /* partial success */
+		} else {
+			/* All auth complete */
+			send_msg_userauth_success();
+		}
+	} else {
+		dropbear_log(LOG_WARNING, "2FA auth failed for '%s' from %s", ses.authstate.pw_name,
+		             svr_ses.addrstring);
+		send_msg_userauth_failure(0, 1);
+	}
+
+	TRACE(("leave svr_auth_2fa_response"))
+}
+
+#endif /* DROPBEAR_SVR_2FA_SUPPORT */
