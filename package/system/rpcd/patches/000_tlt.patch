diff --recursive --unified --new-file --no-dereference --exclude .gitver upstream/session-totp.c src/session-totp.c
--- upstream/session-totp.c	1970-01-01 00:00:00.000000000 +0000
+++ src/session-totp.c	2026-04-13 09:41:33.000000000 +0000
@@ -0,0 +1,249 @@
+#include <libubus.h>
+#include <libubox/blobmsg.h>
+#include <uci.h>
+
+#include <stdlib.h>
+#include <string.h>
+
+#include <rpcd/session.h>
+
+#define UBUS_TIMEOUT 10000
+
+#ifdef ENABLE_2FA_SUPPORT
+int rpc_handle_2fa_login(struct ubus_context *ctx, struct ubus_object *obj,
+			 struct ubus_request_data *req, const char *method,
+			 struct blob_attr *msg);
+
+static void
+rpc_session_set_data(struct rpc_session *ses, struct blob_attr *val)
+{
+	struct rpc_session_data *data;
+
+	data = avl_find_element(&ses->data, blobmsg_name(val), data, avl);
+	if (data) {
+		avl_delete(&ses->data, &data->avl);
+		free(data);
+	}
+
+	data = calloc(1, sizeof(*data) + blob_pad_len(val));
+	if (!data)
+		return;
+
+	memcpy(data->attr, val, blob_pad_len(val));
+	data->avl.key = blobmsg_name(data->attr);
+	avl_insert(&ses->data, &data->avl);
+}
+
+enum {
+	RPC_TL_SID,
+	RPC_TL_OTP,
+	__RPC_2FA_LOGIN_POLICY_MAX,
+};
+
+const struct blobmsg_policy rpc_2fa_login_policy[__RPC_2FA_LOGIN_POLICY_MAX] = {
+	[RPC_TL_SID] = { .name = "ubus_rpc_session", .type = BLOBMSG_TYPE_STRING },
+	[RPC_TL_OTP] = { .name = "otp", .type = BLOBMSG_TYPE_STRING }
+};
+
+enum {
+	RPC_2FA_RES,
+	RPC_2FA_ACTIVE,
+	__RPC_2FA_MAX,
+};
+
+static const struct blobmsg_policy rpc_2fa_policy[__RPC_2FA_MAX] = {
+	[RPC_2FA_RES] = { .name = "res", .type = BLOBMSG_TYPE_BOOL },
+	[RPC_2FA_ACTIVE] = { .name = "active", .type = BLOBMSG_TYPE_BOOL },
+};
+
+static void rpc_2fa_check_cb(struct ubus_request *req, int type, struct blob_attr *msg)
+{
+	(void)type;
+
+	struct blob_attr *tb[__RPC_2FA_MAX] = { 0 };
+	bool *res = (bool *)req->priv;
+
+	blobmsg_parse(rpc_2fa_policy, __RPC_2FA_MAX, tb, blob_data(msg), blob_len(msg));
+
+	if (tb[RPC_2FA_RES]) {
+		*res = blobmsg_get_bool(tb[RPC_2FA_RES]);
+	} else if (tb[RPC_2FA_ACTIVE]) {
+		*res = blobmsg_get_bool(tb[RPC_2FA_ACTIVE]);
+	}
+}
+
+bool
+rpc_session_2fa_pending(struct rpc_session *ses)
+{
+	struct rpc_session_data *data;
+
+	if (!ses)
+		return false;
+
+	data = avl_find_element(&ses->data, "2fa_login", data, avl);
+
+	return !!data;
+}
+
+void
+rpc_session_2fa_mark_pending(struct rpc_session *ses)
+{
+	struct blob_buf b = { 0 };
+
+	if (!ses)
+		return;
+
+	blob_buf_init(&b, 0);
+	blobmsg_add_u8(&b, "2fa_login", 1);
+	rpc_session_set_data(ses, blob_data(b.head));
+	blob_buf_free(&b);
+}
+
+bool
+rpc_session_2fa_status(struct ubus_context *ctx, const char *username)
+{
+	static struct blob_buf b = { 0 };
+	uint32_t id = 0;
+	bool active = false;
+
+	if (!username || !ctx || ubus_lookup_id(ctx, "totp", &id))
+		return active;
+
+	blob_buf_init(&b, 0);
+	blobmsg_add_string(&b, "username", username);
+	ubus_invoke(ctx, id, "status", b.head, rpc_2fa_check_cb, &active, UBUS_TIMEOUT);
+	blob_buf_free(&b);
+
+	return active;
+}
+
+static bool
+rpc_2fa_check(struct ubus_context *ctx, struct rpc_session *ses, const char *otp)
+{
+	static struct blob_buf b = { 0 };
+	uint32_t id = 0;
+	struct rpc_session_data *username = NULL;
+	bool res = false;
+
+	if (!ctx || ubus_lookup_id(ctx, "totp", &id))
+		return false;
+
+	username = avl_find_element(&ses->data, "username", username, avl);
+	if (!username || blobmsg_type(username->attr) != BLOBMSG_TYPE_STRING)
+		return false;
+
+	blob_buf_init(&b, 0);
+	blobmsg_add_string(&b, "username", blobmsg_get_string(username->attr));
+	blobmsg_add_string(&b, "totp", otp);
+	ubus_invoke(ctx, id, "check", b.head, rpc_2fa_check_cb, &res, UBUS_TIMEOUT);
+	blob_buf_free(&b);
+
+	return res;
+}
+
+static struct uci_section *
+rpc_reclaim_uci_section(struct uci_context *uci, struct rpc_session *ses)
+{
+	struct rpc_session_data *username;
+
+	username = avl_find_element(&ses->data, "username", username, avl);
+	if (!username || blobmsg_type(username->attr) != BLOBMSG_TYPE_STRING)
+		return NULL;
+
+	return rpc_login_test_login(uci, blobmsg_get_string(username->attr), NULL, NULL);
+}
+
+int
+rpc_handle_2fa_login(struct ubus_context *ctx, struct ubus_object *obj,
+			    struct ubus_request_data *req, const char *method,
+			    struct blob_attr *msg)
+{
+	struct blob_attr *tb[__RPC_2FA_LOGIN_POLICY_MAX] = { 0 };
+	struct uci_context *uci = NULL;
+	struct uci_section *login = NULL;
+	struct rpc_session *ses = NULL;
+	const char *otp = NULL;
+	int rv = 0;
+	struct rpc_session_data *data;
+	struct blob_buf reply_buf = { 0 };
+
+	(void)obj;
+	(void)method;
+
+	blob_buf_init(&reply_buf, 0);
+
+	blobmsg_parse(rpc_2fa_login_policy, __RPC_2FA_LOGIN_POLICY_MAX, tb, blob_data(msg), blob_len(msg));
+	if (!tb[RPC_TL_SID] || !tb[RPC_TL_OTP]) {
+		rv = UBUS_STATUS_INVALID_ARGUMENT;
+		goto out;
+	}
+
+	otp = blobmsg_get_string(tb[RPC_TL_OTP]);
+	uci = uci_alloc_context();
+	if (!uci) {
+		rv = UBUS_STATUS_UNKNOWN_ERROR;
+		goto out;
+	}
+
+	ses = rpc_session_get(blobmsg_get_string(tb[RPC_TL_SID]));
+	if (!ses) {
+		rv = UBUS_STATUS_PERMISSION_DENIED;
+		goto out;
+	}
+
+	data = avl_find_element(&ses->data, "2fa_login", data, avl);
+	if (!data) {
+		rv = UBUS_STATUS_PERMISSION_DENIED;
+		goto out;
+	}
+
+	if (!rpc_2fa_check(ctx, ses, otp)) {
+		rv = UBUS_STATUS_PERMISSION_DENIED;
+		goto out;
+	}
+
+	login = rpc_reclaim_uci_section(uci, ses);
+	if (!login) {
+		rv = UBUS_STATUS_PERMISSION_DENIED;
+		goto out;
+	}
+
+	avl_delete(&ses->data, &data->avl);
+	free(data);
+
+	rpc_login_setup_acls(ses, login);
+	rpc_session_to_blob(&reply_buf, ses, true, true);
+	ubus_send_reply(ctx, req, reply_buf.head);
+
+out:
+	if (uci)
+		uci_free_context(uci);
+
+	blob_buf_free(&reply_buf);
+	return rv;
+}
+
+#else
+
+bool
+rpc_session_2fa_pending(struct rpc_session *ses)
+{
+	(void)ses;
+	return false;
+}
+
+void
+rpc_session_2fa_mark_pending(struct rpc_session *ses)
+{
+	(void)ses;
+}
+
+bool
+rpc_session_2fa_status(struct ubus_context *ctx, const char *username)
+{
+	(void)ctx;
+	(void)username;
+	return false;
+}
+
+#endif
