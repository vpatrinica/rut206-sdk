+        json_get_var received_longitude longitude
+
+        echo "$received_longitude"
+}
diff --recursive --unified --new-file --no-dereference --exclude .gitver upstream/ext/openwrt/scripts/functions/hotspot/hotspot src/ext/openwrt/scripts/functions/hotspot/hotspot
--- upstream/ext/openwrt/scripts/functions/hotspot/hotspot	1970-01-01 00:00:00.000000000 +0000
+++ src/ext/openwrt/scripts/functions/hotspot/hotspot	2026-03-25 10:23:48.000000000 +0000
@@ -0,0 +1,90 @@
+#!/bin/sh
+# Copyright (C) 2015 PIVA Software <www.pivasoftware.com>
+# 	Author: MOHAMED Kallel <mohamed.kallel@pivasoftware.com>
+
+#common_execute_method_param "$parameter" "$permission" "$get_cmd" "$set_cmd" "xsd:$type" "$forcedinform"
+#  $forcedinform should be set to 1 if the parameter is included in the inform message otherwise empty
+#  Default of $type = string
+
+#############################
+#   Entry point functuons   #
+#############################
+. /lib/functions.sh
+
+prefix_list="$prefix_list $DMROOT.Hotspot."
+entry_execute_method_list="$entry_execute_method_list entry_execute_method_root_Hotpsot"
+entry_execute_method_list_forcedinform="$entry_execute_method_list_forcedinform  entry_execute_method_root_Hotpsot"
+OPTION_LIST="IPP;uamlisten AuthMode;_mode LogoutIP;uamlogoutip Network;network \
+DNS1;dns1 DNS2;dns2 UAMPort;uamport LandingPage;_landingpage"
+
+config_load chilli
+
+list_foreach(){
+	[ "$#" -ge 2 ] || return 0
+	local list=$1; shift
+	local callback=$1; shift
+
+	for element in $list
+	do
+		$callback $element $@
+	done
+}
+
+entry_execute_method_root_Hotpsot() {
+	case "$1" in ""|"$DMROOT."|"$DMROOT.Hotspot."*)
+		common_execute_method_obj "$DMROOT.Hotspot." "0"
+		common_execute_method_obj "$DMROOT.Hotspot.General." "0" "" "" "hotspot_browse_instances $1"
+
+		return 0;
+		;;
+	esac
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+#$1 - section name, $2 - option, $3 - true value, $4 - false value
+Hotspot_Get_Bool() {
+	local val=`$UCI_GET chilli.$1.$2`
+
+	[ "$val" = "1" ] && echo "$3" || echo "$4"
+}
+#$1 - section name, $2 - option, $3 - true value, $4 - false value, $5 - value
+Hotspot_Set_Bool() {
+	common_set_bool "chilli.$1" "$4" "$2" "$3"
+	return $?
+}
+#$1 - section name, $2 - option
+Hotspot_Get() {
+	echo `$UCI_GET chilli.$1.$2`
+}
+#$1 - section name, $2 - option, $3 - value
+Hotspot_Set() {
+	$UCI_SET chilli.$1.$2=$3
+	return $?
+}
+
+
+hotspot_entry(){
+	name=$(echo $1 | awk 'BEGIN { FS = ";" }; {print $1}')
+	param=$(echo $1 | awk 'BEGIN { FS = ";" }; {print $2}')
+	common_execute_method_param "$DMROOT.Hotspot.General.$2.$name" "0" \
+				"Hotspot_Get $2 $param" "" "" "1"
+}
+
+sub_entry_hotpsot_general(){
+	case "$2" in ""|"$DMROOT."|"$DMROOT.Hotspot.General.$1"*)
+		common_execute_method_obj "$DMROOT.Hotspot.General.$1" "0"
+		common_execute_method_param "$DMROOT.Hotspot.General.$1.Enabled" "1" \
+				"Hotspot_Get_Bool $1 enabled enabled disabled" \
+				"Hotspot_Set_Bool $1.enabled 1 0" "xsd:boolean" "1"
+		common_execute_method_param "$DMROOT.Hotspot.General.$1.Signup" "1" \
+				"Hotspot_Get_Bool $1 registerusers enabled disabled" "" "xsd:boolean" "1"
+		list_foreach "$OPTION_LIST" hotspot_entry $1
+		return 0
+		;;
+	esac
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+hotspot_browse_instances(){
+	config_foreach sub_entry_hotpsot_general chilli $1
+}
diff --recursive --unified --new-file --no-dereference --exclude .gitver upstream/ext/openwrt/scripts/functions/mobile/cellular src/ext/openwrt/scripts/functions/mobile/cellular
--- upstream/ext/openwrt/scripts/functions/mobile/cellular	1970-01-01 00:00:00.000000000 +0000
+++ src/ext/openwrt/scripts/functions/mobile/cellular	2026-03-25 10:23:48.000000000 +0000
@@ -0,0 +1,1061 @@
+#!/bin/sh
+# Copyright (C) 2015 PIVA Software <www.pivasoftware.com>
+# 	Author: MOHAMED Kallel <mohamed.kallel@pivasoftware.com>
+
+#common_execute_method_param "$parameter" "$permission" "$get_cmd" "$set_cmd" "xsd:$type" "$forcedinform"
+#  $forcedinform should be set to 1 if the parameter is included in the inform message otherwise empty
+#  Default of $type = string
+
+#############################
+#   Entry point functuons   #
+#############################
+
+prefix_list="$prefix_list $DMROOT.Cellular."
+entry_execute_method_list="$entry_execute_method_list entry_execute_method_root_Cellular"
+entry_execute_method_list_forcedinform="$entry_execute_method_list_forcedinform  entry_execute_method_root_Cellular"
+
+####################
+#  Device.Cellular #
+####################
+
+entry_execute_method_root_Cellular() {
+	case "$1" in ""|"$DMROOT."|"$DMROOT.Cellular."*)
+		common_execute_method_obj "$DMROOT.Cellular." "0"
+		common_execute_method_param "$DMROOT.Cellular.RoamingEnabled" "1" \
+			"get_roaming_enabled" "set_roaming_enabled" "xsd:boolean"
+		common_execute_method_param "$DMROOT.Cellular.RoamingStatus" "0" \
+			"get_roaming" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Cellular.InterfaceNumberOfEntries" "0" \
+			"echo $(ubus list gsm.modem* | wc -l)" "" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.Cellular.AccessPointNumberOfEntries" "0" \
+			"get_ap_noe" "" "xsd:unsignedInt"
+		common_execute_method_obj "$DMROOT.Cellular.Interface." "0" \
+			"" "" "count_cellular_iface_obj $1"
+		common_execute_method_obj "$DMROOT.Cellular.AccessPoint." "1" \
+			"add_cellular_ap" "" "count_cellular_ap_obj $1"
+		return 0;
+		;;
+	esac
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+get_roaming_enabled_sim() {
+	local sec="$1"
+	local ret="$2"
+
+	config_get deny_roaming "$sec" deny_roaming
+	[ "$deny_roaming" = "1" ] && eval "$ret=0"
+}
+
+get_roaming_enabled() {
+	local enabled=1
+
+	config_load "simcard"
+	config_foreach get_roaming_enabled_sim sim enabled
+
+	echo "$enabled"
+}
+
+set_roaming_enabled_sim() {
+	local sec="$1"
+	local input="$2"
+	local ret="$3"
+
+	json_load "$(ubus call api put '{"path":"/sim_cards/config/'$sec'",
+		     "body":{"data":{"deny_roaming":"'$input'"}}}')"
+	json_select http_body
+	json_get_var success success
+	[ "$success" = "0" ] && eval "$ret=7"
+}
+
+set_roaming_enabled() {
+	local input="$1"
+	local res=0
+
+	# invert input
+	if [ "$input" = "true" ]; then
+		input=0
+	elif [ "$input" = "false" ]; then
+		input=1
+	elif [ "$input" != "0" -a "$input" != "1" ]; then
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+
+	config_load "simcard"
+	config_foreach set_roaming_enabled_sim sim "$input" res
+
+	[ "$res" = "0" ] && ubus call mobifd reload >/dev/null 2>&1
+
+	return "$res"
+}
+
+get_roaming() {
+	local i=1
+	local ifaces="$(ubus list gsm.modem*)"
+
+	for iface in $ifaces; do
+		json_load "$(ubus call $iface get_net_reg_stat_all)"
+		json_get_var status status
+		[ "$status" = "Registered, home" ] || \
+		[ "$status" = "SMS only, home network" ] && {
+			echo "Home"
+			return 0
+		}
+	done
+
+	echo "Roaming"
+}
+
+get_ap_noe() {
+	local res=0
+
+	json_load "$(ubus call api get '{"path":"/interfaces/config"}')"
+	json_select http_body
+	json_select data
+	json_get_keys keys
+	for var in $keys; do
+		json_select "$var"
+		json_get_var proto proto
+		[ "$proto" = "wwan" ] && res=$(($res + 1))
+		json_select ..
+	done
+
+	echo "$res"
+}
+
+##############################
+#  Device.Cellular.Interface #
+##############################
+
+count_cellular_iface_obj() {
+	local i=1
+	local ifaces="$(ubus list gsm.modem*)"
+
+	for iface in $ifaces; do
+		json_load "$(ubus call $iface info)"
+		json_get_var usb_id usb_id
+		sub_entry_cellular_iface "$1" "$i" "$iface" "$usb_id"
+		i=$((i + 1))
+	done
+}
+
+sub_entry_cellular_iface() {
+	local i="$2"
+	local gsm_ubus="$3"
+	local usb_id="$4"
+
+	case_param "$1" belongto "$DMROOT.Cellular.Interface.$i." && {
+		common_execute_method_obj "$DMROOT.Cellular.Interface.$i." "0"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.Status" "0" \
+			"get_iface_status $gsm_ubus $usb_id" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.Name" "0" \
+			"echo $usb_id" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.LowerLayers" "0" \
+			"" "" "xsd:string[]"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.IMEI" "0" \
+			"get_iface_value $gsm_ubus info imei" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.SupportedAccessTechnologies" "0" \
+			"get_iface_supported_at $gsm_ubus" "" "xsd:string[]"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.PreferredAccessTechnology" "1" \
+			"get_iface_pref_at $gsm_ubus $usb_id" "set_iface_pref_at $gsm_ubus $usb_id" "xsd:string"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.CurrentAccessTechnology" "0" \
+			"get_iface_curr_at $gsm_ubus" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.NetworkRequested" "1" \
+			"get_iface_network_req $gsm_ubus $usb_id" \
+			"set_iface_network_req $gsm_ubus $usb_id" "xsd:string"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.NetworkInUse" "0" \
+			"get_iface_value $gsm_ubus get_network_info opernum" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.RSSI" "0" \
+			"get_iface_value $gsm_ubus get_signal_query rssi" "" "xsd:int"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.RSRP" "0" \
+			"get_iface_value $gsm_ubus get_signal_query rsrp" "" "xsd:int"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.RSRQ" "0" \
+			"get_iface_value $gsm_ubus get_signal_query rsrq" "" "xsd:int"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.Mode" "0" \
+			"get_iface_mode $gsm_ubus" "" "xsd:string"
+		common_execute_method_obj "$DMROOT.Cellular.Interface.$i.Stats." "0"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.Stats.Reset" "1" \
+			"echo 0" "set_iface_stats_reset $gsm_ubus $usb_id" "xsd:boolean"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.Stats.BytesSent" "0" \
+			"get_iface_bytes $gsm_ubus $usb_id tx" "" "xsd:unsignedLong"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.Stats.BytesReceived" "0" \
+			"get_iface_bytes $gsm_ubus $usb_id rx" "" "xsd:unsignedLong"
+		common_execute_method_obj "$DMROOT.Cellular.Interface.$i.SMS." "0"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.SMS.StorageNumberOfEntries" "0" \
+			"echo 1" "" "xsd:unsignedLong"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.SMS.MessageNumberOfEntries" "0" \
+			"get_iface_sms_message_noe $gsm_ubus $usb_id" "" "xsd:unsignedLong"
+		common_execute_method_obj "$DMROOT.Cellular.Interface.$i.SMS.Storage." "0" \
+			"" "" "count_iface_sms_storage $1 $usb_id $i"
+		common_execute_method_obj "$DMROOT.Cellular.Interface.$i.SMS.Incoming." "0"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.SMS.Incoming.StorageRef" "0" \
+			"echo $DMROOT.Cellular.Interface.$i.SMS.Storage.1" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.SMS.Incoming.CapacityLimit" "1" \
+			"get_iface_sms_incoming_limit $usb_id" \
+			"set_iface_sms_incoming_limit $usb_id" "xsd:unsignedInt"
+		common_execute_method_obj "$DMROOT.Cellular.Interface.$i.SMS.Message." "0" \
+			"" "" "count_iface_sms_message $1 $usb_id $i"
+		return 0
+	}
+
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+get_iface_status() {
+	local ubus="$1"
+	local usb_id="$2"
+
+	json_load "$(ubus call api get '{"path":"/modems/status/'$usb_id'"}')"
+	json_select http_body
+	json_select data
+	json_get_var status data_conn_state
+
+	[ "$status" = "Connected" ] && status="Up"
+	[ "$status" = "Disconnected" ] && status="Down"
+
+	echo "$status"
+}
+
+get_iface_value() {
+	local ubus="$1"
+	local method="$2"
+	local value="$3"
+
+	local found_value=$(ubus call $ubus $method 2>/dev/null | grep -w $value |
+			    sed 's/[^ ]* *//; s/["]//g; s/,$//g')
+
+	echo "$found_value"
+}
+
+get_iface_supported_at_res() {
+	[ -n "$1" ] || return
+
+	local ret="$3"
+	if [ "$1" = "4G" ]; then
+		eval "$ret=\"\${$ret},LTE\""
+	else
+		eval "$ret=\"\${$ret},\$1\""
+	fi
+}
+
+get_iface_supported_at() {
+	local ubus="$1"
+	local res="Auto"
+
+	json_load "$(ubus call $ubus info)"
+	json_for_each_item get_iface_supported_at_res service_mode_list res
+
+	# Add preferable services
+	[ "${res#*3G}" != "$res" ] && [ "${res#*2G}" != "$res" ] && res="${res},2G+3G"
+	[ "${res#*3G}" != "$res" ] && [ "${res#*LTE}" != "$res" ] && res="${res},3G+LTE"
+
+	echo "$res"
+}
+
+get_simcard_at() {
+	local sec="$1"
+	local usb_id="$2"
+	local sim_slot="$3"
+
+	config_get modem "$sec" modem
+	[ "$modem" != "$usb_id" ] && return
+
+	config_get position "$sec" position
+	[ "$position" = "$sim_slot" ] && {
+		config_get service "$sec" service
+		case "$service" in
+		"auto")
+			service="Auto"
+			;;
+		"2g")
+			service="2G"
+			;;
+		"3g")
+			service="3G"
+			;;
+		"3g_pref")
+			service="2G+3G"
+			;;
+		"lte")
+			service="LTE"
+			;;
+		"lte_pref")
+			service="3G+LTE"
+			;;
+		"nr5g_pref")
+			service="5G"
+			;;
+		*)
+			service="Auto"
+			;;
+		esac
+		echo "$service"
+	}
+}
+
+get_iface_pref_at() {
+	local ubus="$1"
+	local usb_id="$2"
+
+	json_load "$(ubus call $ubus get_sim_slot)"
+	json_get_var sim_slot index
+
+	config_load simcard
+	config_foreach get_simcard_at "sim" "$usb_id" "$sim_slot"
+}
+
+set_simcard_at() {
+	local sec="$1"
+	local usb_id="$2"
+	local sim_slot="$3"
+	local input="$4"
+
+	config_get modem "$sec" modem
+	[ "$modem" != "$usb_id" ] && return
+
+	config_get position "$sec" position
+	[ "$position" = "$sim_slot" ] && uci set simcard."$sec".service="$input"
+}
+
+set_iface_pref_at() {
+	local ubus="$1"
+	local usb_id="$2"
+	local input="$3"
+	local sim_slot=""
+	local times=0
+
+	case "$input" in
+		"Auto")
+			input="auto"
+			;;
+		"2G")
+			input="2g"
+			;;
+		"3G")
+			input="3g"
+			;;
+		"2G+3G")
+			input="3g_pref"
+			;;
+		"LTE")
+			input="lte"
+			;;
+		"3G+LTE")
+			input="lte_pref"
+			;;
+		"5G")
+			input="nr5g_pref"
+			;;
+		*)
+			return $E_INVALID_PARAMETER_VALUE
+			;;
+	esac
+
+	while [ -z "$sim_slot" ] && [ "$times" -lt 10 ]; do
+		json_load "$(ubus call $ubus get_sim_slot)"
+		json_get_var sim_slot index
+		times=$((times + 1))
+	done
+
+	[ "$times" -ge 10 ] && return $E_RESOURCES_EXCEEDED
+
+	config_load simcard
+	config_foreach set_simcard_at "sim" "$usb_id" "$sim_slot" "$input"
+
+	uci commit
+	ubus call mobifd reload >/dev/null 2>&1
+
+	return 0
+}
+
+get_iface_curr_at() {
+	local ubus="$1"
+
+	json_load "$(ubus call $ubus get_network_info)"
+	json_get_var net_mode net_mode
+
+	case "$net_mode" in
+		"WCDMA")
+			net_mode="3G"
+			;;
+		"4G")
+			net_mode="LTE"
+			;;
+		"NR5G"|"5G-NSA"|"5G-SA")
+			net_mode="5G"
+			;;
+		*)
+			;;
+	esac
+
+	[ -z "$net_mode" ] || [ "$net_mode" = "No service" ] && net_mode="Unknown"
+
+	echo "$net_mode"
+}
+
+get_simcard_opernum() {
+	local sec="$1"
+	local usb_id="$2"
+	local sim_slot="$3"
+
+	config_get modem "$sec" modem
+	[ "$modem" != "$usb_id" ] && return
+
+	config_get position "$sec" position
+	[ "$position" = "$sim_slot" ] && {
+		config_get opernum "$sec" opernum
+		echo "$opernum"
+	}
+}
+
+get_iface_network_req() {
+	local ubus="$1"
+	local usb_id="$2"
+
+	json_load "$(ubus call $ubus get_sim_slot)"
+	json_get_var sim_slot index
+
+	config_load simcard
+	config_foreach get_simcard_opernum "sim" "$usb_id" "$sim_slot"
+}
+
+set_simcard_opernum() {
+	local sec="$1"
+	local usb_id="$2"
+	local sim_slot="$3"
+	local operator="$4"
+	local input="$5"
+
+	config_get modem "$sec" modem
+	[ "$modem" != "$usb_id" ] && return
+
+	config_get position "$sec" position
+	[ "$position" = "$sim_slot" ] && {
+		uci set simcard."$sec".operator="$operator"
+		if [ -z "$input" ]; then
+			uci delete simcard."$sec".opernum
+		else
+			uci set simcard."$sec".opernum="$input"
+		fi
+	}
+}
+
+set_iface_network_req() {
+	local ubus="$1"
+	local usb_id="$2"
+	local input="$3"
+	local operator="manual"
+	local sim_slot=""
+	local times=0
+
+	[ "${#input}" -gt 64 ] && return $E_INVALID_PARAMETER_VALUE
+
+	[ -z "$input" ] && operator="auto"
+
+	while [ -z "$sim_slot" ] && [ "$times" -lt 10 ]; do
+		json_load "$(ubus call $ubus get_sim_slot)"
+		json_get_var sim_slot index
+		times=$((times + 1))
+	done
+
+	[ "$times" -ge 10 ] && return $E_RESOURCES_EXCEEDED
+
+	config_load simcard
+	config_foreach set_simcard_opernum "sim" "$usb_id" "$sim_slot" "$operator" "$input"
+
+	uci commit
+	ubus call mobifd reload >/dev/null 2>&1
+
+	return 0
+}
+
+set_iface_stats_reset_iface() {
+	local sec="$1"
+	local usb_id="$2"
+
+	config_get proto "$sec" proto
+	[ "$proto" != "wwan" ] && return
+
+	config_get modem "$sec" modem
+	[ "$modem" != "$usb_id" ] && return
+
+	ubus call api post '{"path":"/data_limit/actions/clear","body":{"data":{"interface":"'$sec'"}}}' \
+		>/dev/null 2>&1
+}
+
+set_iface_stats_reset() {
+	local ubus="$1"
+	local usb_id="$2"
+	local input="$3"
+
+	[ "$input" = "false" ] || [ "$input" = "0" ] && return 0
+	[ "$input" != "true" ] && [ "$input" != "1" ] && return $E_INVALID_PARAMETER_VALUE
+
+	config_load network
+	config_foreach set_iface_stats_reset_iface interface "$usb_id"
+}
+
+get_iface_mode() {
+	local ubus="$1"
+
+	json_load "$(ubus call $ubus get_network_info)"
+	json_get_var net_mode net_mode
+
+	case "$net_mode" in
+		"5G-SA")
+			echo "Standalone"
+			;;
+		"5G-NSA")
+			echo "NonStandalone"
+			;;
+		*)
+			echo "Unknown"
+			;;
+	esac
+
+	return 0
+}
+
+get_iface_bytes() {
+	local ubus="$1"
+	local usb_id="$2"
+	local key="$3"
+
+	json_load "$(ubus call mdcollect get '{"modem":"'$usb_id'"}')"
+	json_get_var value "$key"
+
+	echo "$value"
+}
+
+get_iface_sms_message_noe() {
