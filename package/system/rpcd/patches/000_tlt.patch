+	if (n_len < 0) {
+		return OAUTH2_ERR;
+	}
+
+	unsigned char decoded_e[4096];
+	int e_len = base64url_decode(session->jwks_e, decoded_e, sizeof(decoded_e));
+	if (e_len < 0) {
+		return OAUTH2_ERR;
+	}
+
+	BIGNUM *bn_n = BN_bin2bn(decoded_n, n_len, NULL);
+	BIGNUM *bn_e = BN_bin2bn(decoded_e, e_len, NULL);
+	if (!bn_n || !bn_e) {
+		BN_free(bn_n);
+		BN_free(bn_e);
+		return OAUTH2_ERR;
+	}
+
+	bld = OSSL_PARAM_BLD_new();
+	if (bld && OSSL_PARAM_BLD_push_BN(bld, OSSL_PKEY_PARAM_RSA_N, bn_n) &&
+	    OSSL_PARAM_BLD_push_BN(bld, OSSL_PKEY_PARAM_RSA_E, bn_e)) {
+		params = OSSL_PARAM_BLD_to_param(bld);
+	}
+	OSSL_PARAM_BLD_free(bld);
+	BN_free(bn_n);
+	BN_free(bn_e);
+
+	EVP_PKEY_CTX *ctx = EVP_PKEY_CTX_new_from_name(NULL, "RSA", NULL);
+	if (!params || !ctx || EVP_PKEY_fromdata_init(ctx) <= 0 ||
+	    EVP_PKEY_fromdata(ctx, &pkey, EVP_PKEY_PUBLIC_KEY, params) <= 0) {
+		EVP_PKEY_CTX_free(ctx);
+		OSSL_PARAM_free(params);
+		return OAUTH2_ERR;
+	}
+
+	EVP_PKEY_CTX_free(ctx);
+	OSSL_PARAM_free(params);
+
+	EVP_MD_CTX *ctx_md = EVP_MD_CTX_new();
+	if (!ctx_md) {
+		EVP_PKEY_free(pkey);
+		return OAUTH2_ERR;
+	}
+
+	if (!EVP_VerifyInit_ex(ctx_md, sha_alg, NULL) || !EVP_VerifyUpdate(ctx_md, header, strlen(header)) ||
+	    !EVP_VerifyUpdate(ctx_md, ".", 1) || !EVP_VerifyUpdate(ctx_md, payload, strlen(payload))) {
+		EVP_MD_CTX_free(ctx_md);
+		EVP_PKEY_free(pkey);
+		return OAUTH2_ERR;
+	}
+
+	int ret = OAUTH2_ERR;
+	if (EVP_VerifyFinal(ctx_md, decoded_signature, decoded_signature_len, pkey) == 1) {
+		ret = OAUTH2_OK;
+	}
+
+	EVP_MD_CTX_free(ctx_md);
+	EVP_PKEY_free(pkey);
+	return ret;
+}
+
+static int verify_jwt_alg(_oauth2_session *session, const char *alg, const char *kid, char *header,
+                          char *payload, unsigned char *decoded_signature, int decoded_signature_len)
+{
+	if (oauth2_get_jwk_by_kid(session, kid) != OAUTH2_OK) {
+		return OAUTH2_ERR;
+	}
+
+	if (alg && !strcmp(alg, "RS256")) {
+		return verify_jwt_alg_rs(EVP_sha256(), session, header, payload, decoded_signature,
+		                         decoded_signature_len);
+	}
+	if (alg && !strcmp(alg, "RS384")) {
+		return verify_jwt_alg_rs(EVP_sha384(), session, header, payload, decoded_signature,
+		                         decoded_signature_len);
+	}
+	if (alg && !strcmp(alg, "RS512")) {
+		return verify_jwt_alg_rs(EVP_sha512(), session, header, payload, decoded_signature,
+		                         decoded_signature_len);
+	}
+	return OAUTH2_ERR;
+}
+
+static int validate_jwt_token(_oauth2_session *session)
+{
+	int ret      = OAUTH2_ERR;
+	char *header = NULL, *payload = NULL, *signature = NULL;
+	if(!session->id_token) {
+		return ret;
+	}
+
+	char *token_copy          = strdup(session->id_token);
+	if (!token_copy) {
+		return ret;
+	}
+
+	json_object *header_json  = NULL;
+	json_object *payload_json = NULL;
+
+	char *saveptr = NULL;
+	header        = strtok_r(token_copy, ".", &saveptr);
+	payload       = strtok_r(NULL, ".", &saveptr);
+	signature     = strtok_r(NULL, ".", &saveptr);
+	if (!header || !payload || !signature) {
+		free(token_copy);
+		return ret;
+	}
+
+	size_t header_len                = strlen(header);
+	size_t payload_len               = strlen(payload);
+	size_t signature_len             = strlen(signature);
+
+	unsigned char *decoded_header    = calloc(BASE64_DECODED_BUFSIZE(header_len), sizeof(unsigned char));
+	unsigned char *decoded_payload   = calloc(BASE64_DECODED_BUFSIZE(payload_len), sizeof(unsigned char));
+	unsigned char *decoded_signature = calloc(BASE64_DECODED_BUFSIZE(signature_len), sizeof(unsigned char));
+	if (!decoded_header || !decoded_payload || !decoded_signature) {
+		goto clean;
+	}
+
+	int decoded_header_len = base64url_decode(header, decoded_header, BASE64_DECODED_BUFSIZE(header_len));
+	if (decoded_header_len < 0) {
+		goto clean;
+	}
+
+	int decoded_payload_len = base64url_decode(payload, decoded_payload, BASE64_DECODED_BUFSIZE(payload_len));
+	if (decoded_payload_len < 0) {
+		goto clean;
+	}
+
+	int decoded_signature_len =
+	    base64url_decode(signature, decoded_signature, BASE64_DECODED_BUFSIZE(signature_len));
+	if (decoded_signature_len < 0) {
+		goto clean;
+	}
+
+	header_json  = json_tokener_parse((const char *)decoded_header);
+	payload_json = json_tokener_parse((const char *)decoded_payload);
+	if (!header_json || !payload_json) {
+		goto clean;
+	}
+
+	json_object *iss_obj;
+	if (!json_object_object_get_ex(payload_json, "iss", &iss_obj) ||
+		!json_object_get_string(iss_obj) ||
+	    strcmp(json_object_get_string(iss_obj), session->issuer) != 0) {
+		goto clean;
+	}
+
+	json_object *aud_obj;
+	if (!json_object_object_get_ex(payload_json, "aud", &aud_obj) ||
+		!json_object_get_string(aud_obj) ||
+	    strcmp(json_object_get_string(aud_obj), session->client_id) != 0) {
+		goto clean;
+	}
+
+	json_object *exp_obj;
+	if (json_object_object_get_ex(payload_json, "exp", &exp_obj)) {
+		time_t current_time = time(NULL);
+		uint64_t exp_time   = json_object_get_int64(exp_obj);
+		if (exp_time < (uint64_t)current_time) {
+			goto clean;
+		}
+	} else {
+		goto clean;
+	}
+
+	json_object *username_obj;
+	if (json_object_object_get_ex(payload_json, "preferred_username", &username_obj)) {
+		const char *username = json_object_get_string(username_obj);
+		if (username && username[0] != '\0') {
+			session->username = strdup(username);
+		}
+	}
+
+	json_object *alg_obj;
+	if (!json_object_object_get_ex(header_json, "alg", &alg_obj)) {
+		goto clean;
+	}
+
+	const char *alg = json_object_get_string(alg_obj);
+	if (!alg) {
+		goto clean;
+	}
+
+	json_object *kid_obj;
+	if (!json_object_object_get_ex(header_json, "kid", &kid_obj)) {
+		goto clean;
+	}
+
+	const char *kid = json_object_get_string(kid_obj);
+	if (!kid) {
+		goto clean;
+	}
+
+	ret = verify_jwt_alg(session, alg, kid, header, payload, decoded_signature, decoded_signature_len);
+
+clean:
+	if (header_json)
+		json_object_put(header_json);
+	if (payload_json)
+		json_object_put(payload_json);
+	free(token_copy);
+	free(decoded_header);
+	free(decoded_payload);
+	free(decoded_signature);
+	return ret;
+}
+
+void oauth2_init_session(_oauth2_session *session)
+{
+	session->response_type          = NULL;
+	session->oidc_endpoint          = NULL;
+	session->client_id              = NULL;
+	session->client_secret          = NULL;
+	session->redirect_uri           = NULL;
+	session->scope                  = NULL;
+	session->state                  = NULL;
+	session->code                   = NULL;
+	session->token_endpoint         = NULL;
+	session->authorization_endpoint = NULL;
+	session->userinfo_endpoint      = NULL;
+	session->jwks_uri               = NULL;
+	session->authorization_url      = NULL;
+	session->id_token               = NULL;
+	session->access_token           = NULL;
+	session->username               = NULL;
+	session->issuer                 = NULL;
+	session->jwks_n                 = NULL;
+	session->jwks_e                 = NULL;
+	session->token_type             = OAUTH2_TOKEN_UNKNOWN;
+}
+
+static void oauth2_set_str_parameter(_oauth2_session *session, unsigned int option, char *value)
+{
+	if (!value) {
+		return;
+	}
+
+	switch (option) {
+	case OAUTH2_OPT_OIDC_ENDPOINT:
+		session->oidc_endpoint = strdup(value);
+		break;
+	case OAUTH2_OPT_CLIENT_ID:
+		session->client_id = strdup(value);
+		break;
+	case OAUTH2_OPT_CLIENT_SECRET:
+		session->client_secret = strdup(value);
+		break;
+	case OAUTH2_OPT_REDIRECT_URI:
+		session->redirect_uri = strdup(value);
+		break;
+	case OAUTH2_OPT_SCOPE:
+		session->scope = strdup(value);
+		break;
+	case OAUTH2_OPT_STATE:
+		session->state = strdup(value);
+		break;
+	case OAUTH2_OPT_CODE:
+		session->code = strdup(value);
+		break;
+	default:
+		break;
+	}
+}
+
+static void oauth2_set_int_parameter(_oauth2_session *session, unsigned int option, unsigned int value)
+{
+	switch (option) {
+	case OAUTH2_OPT_RESPONSE_TYPE: {
+		switch (value) {
+		case OAUTH2_RESPONSE_TYPE_CODE:
+			session->response_type = "code";
+			break;
+		default:
+			break;
+		}
+		break;
+	}
+	default:
+		break;
+	}
+}
+
+static int oauth2_add_session_tokens(_oauth2_session *session, const char *id_token, const char *access_token,
+                                     const char *token_type)
+{
+	int ret = OAUTH2_OK;
+	if (!session->id_token && id_token && id_token[0] != '\0') {
+		session->id_token = strdup(id_token);
+		ret               = validate_jwt_token(session);
+	}
+
+	if (!session->access_token && access_token && access_token[0] != '\0') {
+		session->access_token = strdup(access_token);
+	}
+
+	if (token_type && !strcmp(token_type, "Bearer")) {
+		session->token_type = OAUTH2_TOKEN_BEARER;
+	} else {
+		session->token_type = OAUTH2_TOKEN_UNKNOWN;
+	}
+
+	return ret;
+}
+
+void oauth2_set_parameter_list(_oauth2_session *session, ...)
+{
+	va_list args;
+	va_start(args, session);
+
+	unsigned int option = 0;
+	while ((option = va_arg(args, unsigned int)) != OAUTH2_OPT_NONE) {
+		switch (option) {
+		case OAUTH2_OPT_OIDC_ENDPOINT:
+		case OAUTH2_OPT_CLIENT_ID:
+		case OAUTH2_OPT_CLIENT_SECRET:
+		case OAUTH2_OPT_REDIRECT_URI:
+		case OAUTH2_OPT_STATE:
+		case OAUTH2_OPT_SCOPE:
+		case OAUTH2_OPT_CODE: {
+			char *value = va_arg(args, char *);
+			oauth2_set_str_parameter(session, option, value);
+			break;
+		}
+		case OAUTH2_OPT_RESPONSE_TYPE: {
+			unsigned int value = va_arg(args, unsigned int);
+			oauth2_set_int_parameter(session, option, value);
+			break;
+		}
+		default:
+			break;
+		}
+	}
+
+	va_end(args);
+}
+
+int oauth2_get_openid_config(_oauth2_session *session)
+{
+	CURL *curl;
+	CURLcode res;
+	long http_code;
+	char *url                  = session->oidc_endpoint;
+	struct memory_struct chunk = { 0 };
+
+	if (!url || url[0] == '\0') {
+		return OAUTH2_ERR;
+	}
+
+	if (session->token_endpoint || session->authorization_endpoint || session->jwks_uri ||
+	    session->userinfo_endpoint) {
+		return OAUTH2_ERR;
+	}
+
+	curl_global_init(CURL_GLOBAL_ALL);
+	curl = curl_easy_init();
+	if (!curl) {
+		return OAUTH2_ERR;
+	}
+
+	curl_easy_setopt(curl, CURLOPT_URL, url);
+	curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, write_callback);
+	curl_easy_setopt(curl, CURLOPT_WRITEDATA, (void *)&chunk);
+	res = curl_easy_perform(curl);
+	if (res != CURLE_OK) {
+		_log(L_DEBUG, "%s(%d): Failed to get response from oauth2 openid endpoint", __FUNCTION__,
+		     __LINE__);
+		curl_easy_cleanup(curl);
+		curl_global_cleanup();
+		free(chunk.memory);
+		return OAUTH2_ERR;
+	}
+
+	curl_easy_getinfo(curl, CURLINFO_RESPONSE_CODE, &http_code);
+	if (http_code != 200) {
+		_log(L_DEBUG, "%s(%d): Incorrect response gotten from oauth2 openid endpoint: %s",
+		     __FUNCTION__, __LINE__, chunk.memory);
+		curl_easy_cleanup(curl);
+		curl_global_cleanup();
+		free(chunk.memory);
+		return OAUTH2_ERR;
+	}
+
+	curl_easy_cleanup(curl);
+	curl_global_cleanup();
+
+	struct json_object *root_obj, *token_endpoint_obj, *authorization_endpoint_obj, *jwks_uri_obj,
+	    *userinfo_endpoint_obj, *issuer_obj;
+	root_obj = json_tokener_parse(chunk.memory);
+	if (root_obj == NULL) {
+		free(chunk.memory);
+		return OAUTH2_ERR;
+	}
+
+	json_object_object_get_ex(root_obj, "token_endpoint", &token_endpoint_obj);
+	json_object_object_get_ex(root_obj, "authorization_endpoint", &authorization_endpoint_obj);
+	json_object_object_get_ex(root_obj, "jwks_uri", &jwks_uri_obj);
+	json_object_object_get_ex(root_obj, "userinfo_endpoint", &userinfo_endpoint_obj);
+	json_object_object_get_ex(root_obj, "issuer", &issuer_obj);
+
+	if (!token_endpoint_obj || !authorization_endpoint_obj || !jwks_uri_obj || !userinfo_endpoint_obj ||
+	    !issuer_obj) {
+		json_object_put(root_obj);
+		free(chunk.memory);
+		return OAUTH2_ERR;
+	}
+
+	const char *token_endpoint         = json_object_get_string(token_endpoint_obj);
+	const char *authorization_endpoint = json_object_get_string(authorization_endpoint_obj);
+	const char *jwks_uri               = json_object_get_string(jwks_uri_obj);
+	const char *userinfo_endpoint      = json_object_get_string(userinfo_endpoint_obj);
+	const char *issuer                 = json_object_get_string(issuer_obj);
+
+	if (!token_endpoint || !authorization_endpoint || !jwks_uri || !userinfo_endpoint || !issuer) {
+		json_object_put(root_obj);
+		free(chunk.memory);
+		return OAUTH2_ERR;
+	}
+
+	session->token_endpoint         = strdup(token_endpoint);
+	session->authorization_endpoint = strdup(authorization_endpoint);
+	session->jwks_uri               = strdup(jwks_uri);
+	session->userinfo_endpoint      = strdup(userinfo_endpoint);
+	session->issuer                 = strdup(issuer);
+
+	json_object_put(root_obj);
+	free(chunk.memory);
+
+	return OAUTH2_OK;
+}
+
+int oauth2_build_authorization_url(_oauth2_session *session)
+{
+	CURL *curl                 = NULL;
+	char *encoded_client_id    = NULL;
+	char *encoded_redirect_uri = NULL;
+	char *encoded_scope        = NULL;
+	char *encoded_state        = NULL;
+	int ret                    = OAUTH2_ERR;
+
+	if (!session->authorization_endpoint || !session->client_id || !session->redirect_uri ||
+	    !session->scope || !session->response_type || !session->state) {
+		return ret;
+	}
+	if (session->authorization_url) {
+		free(session->authorization_url);
+		session->authorization_url = NULL;
+	}
+
+	curl = curl_easy_init();
+	if (!curl) {
+		return ret;
+	}
+
+	encoded_client_id    = curl_easy_escape(curl, session->client_id, 0);
+	encoded_redirect_uri = curl_easy_escape(curl, session->redirect_uri, 0);
+	encoded_scope        = curl_easy_escape(curl, session->scope, 0);
+	encoded_state        = curl_easy_escape(curl, session->state, 0);
+
+	if (!encoded_client_id || !encoded_redirect_uri || !encoded_scope || !encoded_state) {
+		goto cleanup;
+	}
+
+	int result = asprintf(&session->authorization_url,
+	                      "%s?client_id=%s&redirect_uri=%s&scope=%s&response_type=%s&state=%s",
+	                      session->authorization_endpoint, encoded_client_id, encoded_redirect_uri,
+	                      encoded_scope, session->response_type, encoded_state);
+	if (result == -1) {
+		goto cleanup;
+	}
+	ret = OAUTH2_OK;
+
+cleanup:
+	if (encoded_client_id)
+		curl_free(encoded_client_id);
+	if (encoded_redirect_uri)
+		curl_free(encoded_redirect_uri);
+	if (encoded_scope)
+		curl_free(encoded_scope);
+	if (encoded_state)
+		curl_free(encoded_state);
+	if (curl)
+		curl_easy_cleanup(curl);
+
+	return ret;
+}
+
+int oauth2_exchange_token(_oauth2_session *session)
+{
+	CURL *curl;
+	CURLcode res;
+	long http_code;
+	char *url                  = session->token_endpoint;
+	struct memory_struct chunk = { 0 };
+	char *post_data            = NULL;
+	char *auth_header          = NULL;
+
+	if (!url || url[0] == '\0') {
+		return OAUTH2_ERR;
+	}
+
+	if (!session->code || !session->redirect_uri || !session->client_secret || !session->client_id ||
+	    !session->response_type || (session->response_type && strcmp(session->response_type, "code"))) {
+		return OAUTH2_ERR;
+	}
+
+	asprintf(&post_data,
+	         "grant_type=authorization_code&client_id=%s&client_secret=%s&redirect_uri=%s&code=%s",
+	         session->client_id, session->client_secret, session->redirect_uri, session->code);
+	if(!post_data){
+		return OAUTH2_ERR;
+	}
+
+	asprintf(&auth_header, "%s:%s", session->client_id, session->client_secret);
+	if (!auth_header) {
+		free(post_data);
+		return OAUTH2_ERR;
+	}
+
+	curl_global_init(CURL_GLOBAL_ALL);
+	curl = curl_easy_init();
+	if (!curl) {
+		free(post_data);
+		free(auth_header);
+		return OAUTH2_ERR;
+	}
+
+	curl_easy_setopt(curl, CURLOPT_URL, url);
+	curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, write_callback);
+	curl_easy_setopt(curl, CURLOPT_WRITEDATA, (void *)&chunk);
+	curl_easy_setopt(curl, CURLOPT_POSTFIELDS, post_data);
+	curl_easy_setopt(curl, CURLOPT_POSTFIELDSIZE, (long)strlen(post_data));
+
+	curl_easy_setopt(curl, CURLOPT_HTTPAUTH, CURLAUTH_BASIC);
+	curl_easy_setopt(curl, CURLOPT_USERPWD, auth_header);
+
+	struct curl_slist *headers = NULL;
+	headers = curl_slist_append(headers, "Content-Type: application/x-www-form-urlencoded");
+	if (!headers) {
+		curl_easy_cleanup(curl);
+		curl_global_cleanup();
+		free(post_data);
+		free(auth_header);
+		return OAUTH2_ERR;
+	}
+	headers = curl_slist_append(headers, "Accept: application/json");
+	if (!headers) {
+		curl_easy_cleanup(curl);
+		curl_global_cleanup();
+		curl_slist_free_all(headers);
+		free(post_data);
+		free(auth_header);
+		return OAUTH2_ERR;
+	}
+	curl_easy_setopt(curl, CURLOPT_HTTPHEADER, headers);
+
+	res = curl_easy_perform(curl);
+	free(post_data);
+	free(auth_header);
+
+	if (res != CURLE_OK) {
+		_log(L_DEBUG, "%s(%d): Failed to get response from oauth2 token endpoint", __FUNCTION__,
+		     __LINE__);
+		curl_easy_cleanup(curl);
+		curl_global_cleanup();
+		curl_slist_free_all(headers);
+		free(chunk.memory);
+		return OAUTH2_ERR;
+	}
+
+	curl_easy_getinfo(curl, CURLINFO_RESPONSE_CODE, &http_code);
+	if (http_code != 200 && http_code != 201) {
+		_log(L_DEBUG, "%s(%d): Incorrect response gotten from oauth2 token endpoint: %s",
+		     __FUNCTION__, __LINE__, chunk.memory);
+		curl_easy_cleanup(curl);
+		curl_global_cleanup();
+		curl_slist_free_all(headers);
+		free(chunk.memory);
+		return OAUTH2_ERR;
+	}
+
+	curl_easy_cleanup(curl);
+	curl_global_cleanup();
+	curl_slist_free_all(headers);
+
+	struct json_object *root_obj, *access_token_obj, *id_token_obj, *token_type_obj;
+	root_obj = json_tokener_parse(chunk.memory);
+	if (root_obj == NULL) {
+		free(chunk.memory);
+		return OAUTH2_ERR;
+	}
+
+	json_object_object_get_ex(root_obj, "access_token", &access_token_obj);
+	json_object_object_get_ex(root_obj, "id_token", &id_token_obj);
+	json_object_object_get_ex(root_obj, "token_type", &token_type_obj);
+
+	const char *access_token = access_token_obj ? json_object_get_string(access_token_obj) : NULL;
+	const char *id_token     = id_token_obj ? json_object_get_string(id_token_obj) : NULL;
+	const char *token_type   = token_type_obj ? json_object_get_string(token_type_obj) : NULL;
+
+	if (!access_token && !id_token && !token_type) {
+		_log(L_DEBUG, "%s(%d): Failed to get either access_token, id_token or token_type",
+		     __FUNCTION__, __LINE__);
+		json_object_put(root_obj);
+		free(chunk.memory);
+		return OAUTH2_ERR;
+	}
+
+	if (oauth2_add_session_tokens(session, id_token, access_token, token_type) != OAUTH2_OK) {
+		_log(L_DEBUG, "%s(%d): Failed to get session tokens", __FUNCTION__, __LINE__);
+		json_object_put(root_obj);
+		free(chunk.memory);
+		return OAUTH2_ERR;
+	}
+
+	json_object_put(root_obj);
+	free(chunk.memory);
+
+	return OAUTH2_OK;
+}
+
+int oauth2_get_userinfo(_oauth2_session *session)
+{
+	CURL *curl;
+	CURLcode res;
+	long http_code;
+	char *url                  = session->userinfo_endpoint;
+	struct memory_struct chunk = { 0 };
+
+	if (!url || url[0] == '\0' || !session->access_token || session->token_type != OAUTH2_TOKEN_BEARER) {
+		return OAUTH2_ERR;
+	}
+
+	char *bearer_header;
+	asprintf(&bearer_header, "Authorization: Bearer %s", session->access_token);
+	if (!bearer_header) {
+		return OAUTH2_ERR;
+	}
+
+	curl_global_init(CURL_GLOBAL_ALL);
+	curl = curl_easy_init();
+	if (!curl) {
+		free(bearer_header);
+		return OAUTH2_ERR;
+	}
+
+	curl_easy_setopt(curl, CURLOPT_URL, url);
+	struct curl_slist *headers = NULL;
+	headers = curl_slist_append(headers, bearer_header);
+	if (!headers) {
+		curl_easy_cleanup(curl);
+		curl_global_cleanup();
+		free(bearer_header);
+		return OAUTH2_ERR;
+	}
+	curl_easy_setopt(curl, CURLOPT_HTTPHEADER, headers);
+	curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, write_callback);
+	curl_easy_setopt(curl, CURLOPT_WRITEDATA, (void *)&chunk);
+	res = curl_easy_perform(curl);
+	free(bearer_header);
+
+	if (res != CURLE_OK) {
+		_log(L_DEBUG, "%s(%d): Failed to get response from oauth2 userinfo endpoint", __FUNCTION__,
+		     __LINE__);
+		curl_easy_cleanup(curl);
+		curl_global_cleanup();
+		curl_slist_free_all(headers);
+		free(chunk.memory);
+		return OAUTH2_ERR;
+	}
+
+	curl_easy_getinfo(curl, CURLINFO_RESPONSE_CODE, &http_code);
+	if (http_code != 200) {
+		_log(L_DEBUG, "%s(%d): Incorrect response gotten from oauth2 userinfo endpoint: %s",
+		     __FUNCTION__, __LINE__, chunk.memory);
+		curl_easy_cleanup(curl);
+		curl_global_cleanup();
+		curl_slist_free_all(headers);
+		free(chunk.memory);
+		return OAUTH2_ERR;
+	}
+
+	curl_easy_cleanup(curl);
+	curl_global_cleanup();
+	curl_slist_free_all(headers);
+
+	struct json_object *root_obj, *email_obj, *username_obj, *name_obj;
+	root_obj = json_tokener_parse(chunk.memory);
+	if (root_obj == NULL) {
+		free(chunk.memory);
+		return OAUTH2_ERR;
+	}
+
+	// prefered username is in JWT token for Microsoft,
+	// other providers may handle usernames differently
+	if (!session->username) {
+		json_object_object_get_ex(root_obj, "email", &email_obj);
+		json_object_object_get_ex(root_obj, "username", &username_obj);
+		json_object_object_get_ex(root_obj, "name", &name_obj);
+
+		const char *email    = email_obj ? json_object_get_string(email_obj) : NULL;
+		const char *username = username_obj ? json_object_get_string(username_obj) : NULL;
+		const char *name     = name_obj ? json_object_get_string(name_obj) : NULL;
+
+		if (email) {
+			session->username = strdup(email);
+		} else if (username) {
+			session->username = strdup(username);
+		} else if (name) {
+			session->username = strdup(name);
+		}
+	}
+
+	json_object_put(root_obj);
+	free(chunk.memory);
+
+	return OAUTH2_OK;
+}
+
+void oauth2_clean_session(_oauth2_session *session)
+{
+	if (!session)
+		return;
+
+	free(session->oidc_endpoint);
+	free(session->client_id);
+	free(session->client_secret);
+	free(session->redirect_uri);
+	free(session->scope);
+	free(session->state);
+	free(session->code);
+	free(session->token_endpoint);
+	free(session->authorization_endpoint);
+	free(session->userinfo_endpoint);
+	free(session->jwks_uri);
+	free(session->authorization_url);
+	free(session->id_token);
+	free(session->access_token);
+	free(session->username);
+	free(session->issuer);
+	free(session->jwks_n);
+	free(session->jwks_e);
+	oauth2_init_session(session);
+}
diff --recursive --unified --new-file --no-dereference --exclude .gitver upstream/oauth2_plugin.c src/oauth2_plugin.c
--- upstream/oauth2_plugin.c	1970-01-01 00:00:00.000000000 +0000
+++ src/oauth2_plugin.c	2026-04-13 09:41:33.000000000 +0000
@@ -0,0 +1,432 @@
+#include <libubox/avl-cmp.h>
+#include <libubox/blobmsg.h>
+#include <libubox/utils.h>
+#include <libubus.h>
+#include <uci.h>
+#include <string.h>
+#include <tlt_logger.h>
+
+#include <rpcd/session.h>
+#include <rpcd/session_api.h>
+#include <rpcd/oauth2.h>
+
+#define RPC_MAX_PENDING_SSO_SESSIONS 5
+
+int rpc_session_plugin_init(struct ubus_context *ctx);
+void rpc_session_plugin_deinit(struct ubus_context *ctx);
+
+enum {
+	RPC_SSO_URL,
+	RPC_SSO_PROVIDER,
+	RPC_SSO_TIMEOUT,
+	__RPC_SSO_MAX,
+};
+static const struct blobmsg_policy sso_login_policy[__RPC_SSO_MAX] = {
+	[RPC_SSO_URL]      = { .name = "redirect_url", .type = BLOBMSG_TYPE_STRING },
+	[RPC_SSO_PROVIDER] = { .name = "provider", .type = BLOBMSG_TYPE_STRING },
+	[RPC_SSO_TIMEOUT]  = { .name = "timeout", .type = BLOBMSG_TYPE_INT32 },
+};
+
+enum {
+	RPC_SSO_CALLBACK_STATE,
+	RPC_SSO_CALLBACK_CODE,
+	RPC_SSO_CALLBACK_TIMEOUT,
+	__RPC_SSO_CALLBACK_MAX,
+};
+static const struct blobmsg_policy sso_callback_policy[__RPC_SSO_CALLBACK_MAX] = {
+	[RPC_SSO_CALLBACK_STATE]   = { .name = "state", .type = BLOBMSG_TYPE_STRING },
+	[RPC_SSO_CALLBACK_CODE]    = { .name = "code", .type = BLOBMSG_TYPE_STRING },
+	[RPC_SSO_CALLBACK_TIMEOUT] = { .name = "timeout", .type = BLOBMSG_TYPE_INT32 },
+};
+
+static struct rpc_session *rpc_session_get_by_state(const char *state)
+{
+	struct rpc_session *ses;
+
+	avl_for_each_element(&sessions, ses, avl)
+	{
+		struct rpc_session_data *data = avl_find_element(&ses->data, "state", data, avl);
+		if (!data || blobmsg_type(data->attr) != BLOBMSG_TYPE_STRING) {
+			continue;
+		}
+		if (!strcmp(blobmsg_get_string(data->attr), state)) {
+			rpc_touch_session(ses);
+			return ses;
+		}
+	}
+
+	return NULL;
+}
+
+static int rpc_count_pending_sso_sessions(void)
+{
+	struct rpc_session *ses;
+	int count = 0;
+
+	avl_for_each_element(&sessions, ses, avl)
+	{
+		struct rpc_session_data *data = avl_find_element(&ses->data, "sso_provider", data, avl);
+		if (data) {
+			count++;
+		}
+	}
+
+	return count;
+}
+
+static void rpc_get_sso_provider_config(struct uci_context *uci, const char *provider,
+                                        _oauth2_session *oauth2_session)
+{
+	struct uci_package *p = NULL;
+	struct uci_section *s = NULL;
+	struct uci_element *e = NULL;
+	struct uci_ptr ptr    = { .package = "rpcd" };
+
+	if (!uci_lookup_ptr(uci, &ptr, NULL, false) && ptr.p) {
+		uci_unload(uci, ptr.p);
+		ptr.flags = 0;
+		ptr.p     = NULL;
+	}
+
+	uci_load(uci, ptr.package, &p);
+
+	if (!p) {
+		return;
+	}
+
+	uci_foreach_element (&p->sections, e) {
+		s = uci_to_section(e);
+
+		if (strcmp(s->type, "sso_provider")) {
+			continue;
+		}
+
+		if (strcmp(s->e.name, provider)) {
+			continue;
+		}
+
+		const char *enabled = uci_lookup_option_string(uci, s, "enabled");
+		if (!enabled || enabled[0] != '1') {
+			continue;
+		}
+
+		const char *oidc_endpoint = uci_lookup_option_string(uci, s, "oidc_endpoint");
+		if (oidc_endpoint) {
+			oauth2_set_parameter_list(oauth2_session, OAUTH2_OPT_OIDC_ENDPOINT, oidc_endpoint,
+			                          OAUTH2_OPT_NONE);
+		}
+		const char *client_id = uci_lookup_option_string(uci, s, "client_id");
+		if (client_id) {
+			oauth2_set_parameter_list(oauth2_session, OAUTH2_OPT_CLIENT_ID, client_id,
+			                          OAUTH2_OPT_NONE);
+		}
+		const char *client_secret = uci_lookup_option_string(uci, s, "client_secret");
+		if (client_secret) {
+			oauth2_set_parameter_list(oauth2_session, OAUTH2_OPT_CLIENT_SECRET, client_secret,
+			                          OAUTH2_OPT_NONE);
+		}
+		const char *scope = uci_lookup_option_string(uci, s, "scope");
+		if (scope) {
+			oauth2_set_parameter_list(oauth2_session, OAUTH2_OPT_SCOPE, scope, OAUTH2_OPT_NONE);
+		}
+		return;
+	}
+}
+
+static int rpc_handle_sso_login(struct ubus_context *ctx, struct ubus_object *obj,
+                                struct ubus_request_data *req, const char *method, struct blob_attr *msg)
+{
+	static struct blob_buf buf          = { 0 };
+	struct uci_context *uci             = NULL;
+	struct rpc_session *ses             = NULL;
+	struct blob_attr *tb[__RPC_SSO_MAX] = { 0 };
+	const char *redirect_uri            = NULL;
+	const char *provider                = NULL;
+	char state[RPC_SID_LEN + 1]         = { 0 };
+	int timeout                         = RPC_DEFAULT_SESSION_TIMEOUT;
+	_oauth2_session oauth2_session      = { 0 };
+	int rv                              = 0;
+
+	struct blob_buf reply_buf = { 0 };
+	blob_buf_init(&reply_buf, 0);
+
+	blobmsg_parse(sso_login_policy, __RPC_SSO_MAX, tb, blob_data(msg), blob_len(msg));
+
+	if (!tb[RPC_SSO_URL] || !tb[RPC_SSO_PROVIDER]) {
+		_log(L_DEBUG, "SSO login missing redirect URL or provider");
+		rv = UBUS_STATUS_INVALID_ARGUMENT;
+		goto out;
+	}
+
+	int pending_sessions = rpc_count_pending_sso_sessions();
+	if (pending_sessions >= RPC_MAX_PENDING_SSO_SESSIONS) {
+		_log(L_DEBUG, "SSO login rejected, too many pending SSO sessions (%d >= %d)",
+		     pending_sessions, RPC_MAX_PENDING_SSO_SESSIONS);
+		rv = UBUS_STATUS_UNKNOWN_ERROR;
+		goto out;
+	}
+
+	uci = uci_alloc_context();
+	if (!uci) {
+		_log(L_DEBUG, "SSO login failed to allocate UCI context");
+		rv = UBUS_STATUS_UNKNOWN_ERROR;
+		goto out;
+	}
+
+	redirect_uri = blobmsg_get_string(tb[RPC_SSO_URL]);
+	provider     = blobmsg_get_string(tb[RPC_SSO_PROVIDER]);
+
+	if (tb[RPC_SSO_TIMEOUT])
+		timeout = blobmsg_get_u32(tb[RPC_SSO_TIMEOUT]);
+
+	if (rpc_random(state) != 0) {
+		_log(L_DEBUG, "SSO login failed to generate state parameter");
+		rv = UBUS_STATUS_UNKNOWN_ERROR;
+		goto out;
+	}
+
+	oauth2_set_parameter_list(&oauth2_session,
+	                          OAUTH2_OPT_RESPONSE_TYPE, OAUTH2_RESPONSE_TYPE_CODE,
+	                          OAUTH2_OPT_REDIRECT_URI, redirect_uri,
+	                          OAUTH2_OPT_SCOPE, "openid email profile",
+	                          OAUTH2_OPT_STATE, state,
+	                          OAUTH2_OPT_NONE);
+
+	rpc_get_sso_provider_config(uci, provider, &oauth2_session);
+
+	if (oauth2_get_openid_config(&oauth2_session) != OAUTH2_OK) {
+		oauth2_clean_session(&oauth2_session);
+		_log(L_ERROR, "SSO login failed to get OpenID configuration for provider %s", provider);
+		rv = UBUS_STATUS_UNKNOWN_ERROR;
+		goto out;
+	}
+
+	if (oauth2_build_authorization_url(&oauth2_session) != OAUTH2_OK) {
+		oauth2_clean_session(&oauth2_session);
+		_log(L_ERROR, "SSO login failed to build authorization URL for provider %s", provider);
+		rv = UBUS_STATUS_UNKNOWN_ERROR;
+		goto out;
+	}
+
+	ses = rpc_session_create(timeout, true);
+	if (!ses) {
+		oauth2_clean_session(&oauth2_session);
+		_log(L_DEBUG, "SSO login failed to create session");
+		rv = UBUS_STATUS_UNKNOWN_ERROR;
+		goto out;
+	}
+
+	blob_buf_init(&buf, 0);
+	blobmsg_add_string(&buf, "authorization_url", oauth2_session.authorization_url);
+	rpc_session_set(ses, blob_data(buf.head));
+	blob_buf_free(&buf);
+
+	blob_buf_init(&buf, 0);
+	blobmsg_add_string(&buf, "redirect_uri", redirect_uri);
+	rpc_session_set(ses, blob_data(buf.head));
+	blob_buf_free(&buf);
+
+	blob_buf_init(&buf, 0);
+	blobmsg_add_string(&buf, "state", state);
+	rpc_session_set(ses, blob_data(buf.head));
+	blob_buf_free(&buf);
+
+	blob_buf_init(&buf, 0);
+	blobmsg_add_string(&buf, "sso_provider", provider);
+	rpc_session_set(ses, blob_data(buf.head));
+	blob_buf_free(&buf);
+
+	send_session_event(ctx, "session.created", ses->id);
+	rpc_session_to_blob(&reply_buf, ses, true, true);
+	ubus_send_reply(ctx, req, reply_buf.head);
+	oauth2_clean_session(&oauth2_session);
+
+out:
+	if (uci)
+		uci_free_context(uci);
+
+	blob_buf_free(&reply_buf);
+
+	return rv;
+}
+
+static int rpc_handle_sso_callback(struct ubus_context *ctx, struct ubus_object *obj,
+                                   struct ubus_request_data *req, const char *method, struct blob_attr *msg)
+{
+	static struct blob_buf buf                   = { 0 };
+	struct rpc_session_data *data                = NULL;
+	struct rpc_session_data *ndata               = NULL;
+	struct uci_context *uci                      = NULL;
+	struct rpc_session *ses                      = NULL;
+	struct uci_section *login                    = NULL;
+	struct blob_attr *tb[__RPC_SSO_CALLBACK_MAX] = { 0 };
+	const char *state                            = NULL;
+	const char *redirect_uri                     = NULL;
+	const char *provider                         = NULL;
+	int timeout                                  = RPC_DEFAULT_SESSION_TIMEOUT;
+	_oauth2_session oauth2_session               = { 0 };
+	int rv                                       = 0;
+
+	struct blob_buf reply_buf = { 0 };
+	blob_buf_init(&reply_buf, 0);
+
+	blobmsg_parse(sso_callback_policy, __RPC_SSO_CALLBACK_MAX, tb, blob_data(msg), blob_len(msg));
+
+	if (!tb[RPC_SSO_CALLBACK_CODE] || !tb[RPC_SSO_CALLBACK_STATE]) {
+		_log(L_DEBUG, "SSO callback missing code or state");
+		rv = UBUS_STATUS_INVALID_ARGUMENT;
+		goto out;
+	}
+
+	state = blobmsg_get_string(tb[RPC_SSO_CALLBACK_STATE]);
+	if (tb[RPC_SSO_CALLBACK_TIMEOUT])
+		timeout = blobmsg_get_u32(tb[RPC_SSO_CALLBACK_TIMEOUT]);
+
+	ses = rpc_session_get_by_state(state);
+	if (!ses) {
+		_log(L_DEBUG, "SSO callback session not found for state %s", state);
+		rv = UBUS_STATUS_NOT_FOUND;
+		goto out;
+	}
+
+	uci = uci_alloc_context();
+	if (!uci) {
+		_log(L_DEBUG, "SSO callback failed to allocate UCI context");
+		rv = UBUS_STATUS_UNKNOWN_ERROR;
+		goto out;
+	}
+
+	data = avl_find_element(&ses->data, "redirect_uri", data, avl);
+	if (!data || blobmsg_type(data->attr) != BLOBMSG_TYPE_STRING) {
+		_log(L_DEBUG, "SSO callback missing redirect_uri in session data");
+		rv = UBUS_STATUS_PERMISSION_DENIED;
+		goto out;
+	}
+	redirect_uri = blobmsg_get_string(data->attr);
+
+	data = avl_find_element(&ses->data, "sso_provider", data, avl);
+	if (!data || blobmsg_type(data->attr) != BLOBMSG_TYPE_STRING) {
+		_log(L_DEBUG, "SSO callback missing provider in session data");
+		rv = UBUS_STATUS_PERMISSION_DENIED;
+		goto out;
+	}
+	provider = blobmsg_get_string(data->attr);
+
+	oauth2_set_parameter_list(&oauth2_session,
+	                          OAUTH2_OPT_RESPONSE_TYPE, OAUTH2_RESPONSE_TYPE_CODE,
+	                          OAUTH2_OPT_REDIRECT_URI, redirect_uri,
+	                          OAUTH2_OPT_CODE, blobmsg_get_string(tb[RPC_SSO_CALLBACK_CODE]),
+	                          OAUTH2_OPT_NONE);
+
+	rpc_get_sso_provider_config(uci, provider, &oauth2_session);
+
+	if (oauth2_get_openid_config(&oauth2_session) != OAUTH2_OK) {
+		_log(L_ERROR, "SSO callback failed to get OpenID configuration for provider %s", provider);
+		rv = UBUS_STATUS_UNKNOWN_ERROR;
+		goto clean_oauth;
+	}
+
+	if (oauth2_exchange_token(&oauth2_session) != OAUTH2_OK) {
+		_log(L_ERROR, "SSO callback failed to exchange token for provider %s", provider);
+		rv = UBUS_STATUS_UNKNOWN_ERROR;
+		goto clean_oauth;
+	}
+
+	if (oauth2_get_userinfo(&oauth2_session) != OAUTH2_OK) {
+		_log(L_ERROR, "SSO callback failed to get userinfo for provider %s", provider);
+		rv = UBUS_STATUS_UNKNOWN_ERROR;
+		goto clean_oauth;
+	}
+
+	if (!oauth2_session.username || oauth2_session.username[0] == '\0') {
+		_log(L_ERROR, "SSO callback failed to get username in userinfo for provider %s", provider);
+		send_session_event(ctx, "session.destroyed", ses->id);
+		rpc_session_destroy(ses);
+		rv = UBUS_STATUS_PERMISSION_DENIED;
+		goto clean_oauth;
+	}
+
+	free(ses->username);
+	ses->username = strdup(oauth2_session.username);
+	if (!ses->username) {
+		send_session_event(ctx, "session.destroyed", ses->id);
+		rpc_session_destroy(ses);
+		rv = UBUS_STATUS_UNKNOWN_ERROR;
+		goto clean_oauth;
+	}
+
+	login = rpc_login_test_login(uci, oauth2_session.username, NULL, NULL);
+	if (!login) {
+		_log(
+		    L_ERROR,
+		    "SSO callback for provider %s succeeded, but local account for user \"%s\" was not found",
+		    provider, oauth2_session.username);
+		send_session_event(ctx, "session.destroyed", ses->id);
+		rpc_session_destroy(ses);
+		rv = UBUS_STATUS_PERMISSION_DENIED;
+		goto clean_oauth;
+	}
+
+	avl_remove_all_elements(&ses->data, data, avl, ndata) free(data);
+
+	blob_buf_init(&buf, 0);
+	blobmsg_add_string(&buf, "username", oauth2_session.username);
+	rpc_session_set(ses, blob_data(buf.head));
+	blob_buf_free(&buf);
+
+	if (login->e.name) {
+		blob_buf_init(&buf, 0);
+		blobmsg_add_string(&buf, "group", login->e.name);
+		rpc_session_set(ses, blob_data(buf.head));
+		blob_buf_free(&buf);
+	}
+	ses->timeout = timeout;
+	rpc_touch_session(ses);
+
+	rpc_login_setup_acls(ses, login);
+	rpc_session_to_blob(&reply_buf, ses, true, true);
+	ubus_send_reply(ctx, req, reply_buf.head);
+
+clean_oauth:
+	oauth2_clean_session(&oauth2_session);
+out:
+	if (uci)
+		uci_free_context(uci);
+
+	blob_buf_free(&reply_buf);
+
+	return rv;
+}
+
+static const struct ubus_method oauth2_methods[] = {
+    UBUS_METHOD("sso_login", rpc_handle_sso_login, sso_login_policy),
+	UBUS_METHOD("sso_callback", rpc_handle_sso_callback, sso_callback_policy),
+};
+
+static struct ubus_object_type oauth2_type =
+	UBUS_OBJECT_TYPE("luci-rpc-oauth2", oauth2_methods);
+
+static struct ubus_object oauth2_object = {
+	.name = "session.oauth2",
+	.type = &oauth2_type,
+	.methods = oauth2_methods,
+	.n_methods = ARRAY_SIZE(oauth2_methods),
+};
+
+int rpc_session_plugin_init(struct ubus_context *ctx)
+{
+	int rv = ubus_add_object(ctx, &oauth2_object);
+	if (rv) {
+		_log(L_CRIT, "Failed to register OAuth2 plugin object: %s", ubus_strerror(rv));
+		return rv;
+	}
+
+	_log(L_INFO, "OAuth2 plugin registered successfully");
+	return 0;
+}
+
+void rpc_session_plugin_deinit(struct ubus_context *ctx)
+{
+	_log(L_INFO, "Unregistering OAuth2 plugin");
+	ubus_remove_object(ctx, &oauth2_object);
+}
diff --recursive --unified --new-file --no-dereference --exclude .gitver upstream/plugin.c src/plugin.c
--- upstream/plugin.c	2021-03-11 00:17:58.000000000 +0000
+++ src/plugin.c	2026-04-13 09:41:33.000000000 +0000
@@ -17,8 +17,18 @@
  */
 
 #include <rpcd/plugin.h>
+#include <pwd.h>
+#include <grp.h>
+#include <libubox/ustream.h>
+#include <sys/capability.h>
+
+#define RPC_FILE_MAX_SIZE		(4096 * 64)
 
 static struct blob_buf buf;
+static bool child_process = false;
+static int rpc_response_fd = -1;
+static LIST_HEAD(create_callbacks);
+static LIST_HEAD(destroy_callbacks);
 
 struct rpc_plugin_lookup_context {
 	uint32_t id;
@@ -26,6 +36,62 @@
 	bool found;
 };
 
+struct rpc_lib_plugin_context {
+	struct ubus_context *context;
+	struct ubus_request_data request;
+	struct uloop_timeout timeout;
+	struct uloop_process process;
+	struct ustream_fd opipe_rpcd;
+	struct ustream_fd epipe_rpcd;
+	struct ustream_fd response_fd;
+	struct blob_buf resp_buf;
+	int stat;
+};
+
+typedef int (*ubus_send_reply_fn_t)(struct ubus_context *ctx,
+                                   struct ubus_request_data *req,
+                                   struct blob_attr *msg);
+
+static ubus_send_reply_fn_t orig_ubus_send_reply = NULL;
