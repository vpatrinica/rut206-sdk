-static int strtoint(const char *s, int minVal, int maxVal) {
-  char *ptr;
-  if (!*s) {
-    fatal("[config] Missing numeric value!");
-  }
-  long l = strtol(s, &ptr, 10);
-  if (*ptr || l < minVal || l > maxVal) {
-    fatal("[config] Range error on numeric value \"%s\"!", s);
-  }
-  return l;
-}
