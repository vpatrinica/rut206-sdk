diff --recursive --unified --new-file --no-dereference --exclude .gitver upstream/ext/openwrt/scripts/functions/tr143/tr143 src/ext/openwrt/scripts/functions/tr143/tr143
--- upstream/ext/openwrt/scripts/functions/tr143/tr143	1970-01-01 00:00:00.000000000 +0000
+++ src/ext/openwrt/scripts/functions/tr143/tr143	2026-03-25 10:23:48.000000000 +0000
@@ -0,0 +1,391 @@
+#!/bin/sh
+# Copyright (C) 2015 PIVA Software <www.pivasoftware.com>
+# 	Author: MOHAMED Kallel <mohamed.kallel@pivasoftware.com>
+
+#common_execute_method_param "$parameter" "$permission" "$get_cmd" "$set_cmd" "xsd:$type" "$forcedinform"
+#  $forcedinform should be set to 1 if the parameter is included in the inform message otherwise empty
+#  Default of $type = string
+
+#############################
+#   Entry point functuons   #
+#############################
+
+prefix_list="$prefix_list $DMROOT.IP.Diagnostics.DownloadDiagnostics."
+prefix_list="$prefix_list $DMROOT.IP.Diagnostics.UploadDiagnostics."
+entry_execute_method_list="$entry_execute_method_list entry_execute_method_root_IPDiagnostics"
+entry_execute_method_list_forcedinform="$entry_execute_method_list_forcedinform  entry_execute_method_root_IPDiagnostics"
+
+g_download_diagnostics_file="/var/run/easycwmp/tr143_download_diagnostics"
+g_upload_diagnostics_file="/var/run/easycwmp/tr143_upload_diagnostics"
+
+init_download_diagnostics_file() {
+	[ -e "$g_download_diagnostics_file" ] && return
+
+	echo -e "state None\n\
+interface Device.IP.Interface.2\n\
+url \n\
+dscp 0\n\
+rom_time 0000-00-00T00:00:00.000000Z\n\
+bom_time 0000-00-00T00:00:00.000000Z\n\
+eom_time 0000-00-00T00:00:00.000000Z\n\
+test_bytes 0\n\
+total_bytes 0\n\
+connections 1\n\
+duration 0"> "$g_download_diagnostics_file"
+}
+
+init_upload_diagnostics_file() {
+	[ -e "$g_upload_diagnostics_file" ] && return
+
+	echo -e "state None\n\
+interface Device.IP.Interface.2\n\
+url \n\
+dscp 0\n\
+file_len 1\n\
+rom_time 0000-00-00T00:00:00.000000Z\n\
+bom_time 0000-00-00T00:00:00.000000Z\n\
+eom_time 0000-00-00T00:00:00.000000Z\n\
+test_bytes 0\n\
+total_bytes 0\n\
+connections 1\n\
+duration 0"> "$g_upload_diagnostics_file"
+}
+
+entry_execute_method_root_IPDiagnostics() {
+	[ ! -d "/tmp/tr143" ] && {
+		mkdir /tmp/tr143
+		chown easycwmp:easycwmp /tmp/tr143
+	}
+
+	init_download_diagnostics_file
+	init_upload_diagnostics_file
+
+	case "$1" in ""|"$DMROOT."|"$DMROOT.IP."|"$DMROOT.IP.Diagnostics"*)
+		common_execute_method_obj "$DMROOT.IP.Diagnostics." "0"
+		common_execute_method_obj "$DMROOT.IP.Diagnostics.DownloadDiagnostics." "0" "" "" \
+			"sub_entry_DownloadDiagnostics $1"
+		common_execute_method_obj "$DMROOT.IP.Diagnostics.UploadDiagnostics." "0" "" "" \
+			"sub_entry_UploadDiagnostics $1"
+		return 0;
+		;;
+	esac
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+sub_entry_DownloadDiagnostics() {
+	case_param "$1" belongto "$DMROOT.IP.Diagnostics.DownloadDiagnostics." && {
+		common_execute_method_param "$DMROOT.IP.Diagnostics.DownloadDiagnostics.DiagnosticsState" "1" \
+			"get_download_diagnostics_value state" "set_download_diagnostics_state" "xsd:string"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.DownloadDiagnostics.Interface" "1" \
+			"get_download_diagnostics_value interface" "set_download_diagnostics_iface" "xsd:string"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.DownloadDiagnostics.DownloadURL" "1" \
+			"get_download_diagnostics_value url" "set_download_diagnostics_url" "xsd:string"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.DownloadDiagnostics.DSCP" "1" \
+			"get_download_diagnostics_value dscp" "set_download_diagnostics_dscp" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.DownloadDiagnostics.ROMTime" "0" \
+			"get_download_diagnostics_value rom_time" "" "xsd:dateTime"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.DownloadDiagnostics.BOMTime" "0" \
+			"get_download_diagnostics_value bom_time" "" "xsd:dateTime"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.DownloadDiagnostics.EOMTime" "0" \
+			"get_download_diagnostics_value eom_time" "" "xsd:dateTime"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.DownloadDiagnostics.TestBytesReceived" "0" \
+			"get_download_diagnostics_value test_bytes" "" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.DownloadDiagnostics.TotalBytesReceived" "0" \
+			"get_download_diagnostics_value total_bytes" "" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.DownloadDiagnostics.DownloadTransports" "0" \
+			"echo HTTP,FTP" "" "xsd:string[]"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.DownloadDiagnostics.NumberOfConnections" "1" \
+			"get_download_diagnostics_value connections" "set_download_diagnostics_connections" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.DownloadDiagnostics.TimeBasedTestDuration" "1" \
+			"get_download_diagnostics_value duration" "set_download_diagnostics_duration" "xsd:unsignedInt"
+		return 0
+	}
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+sub_entry_UploadDiagnostics() {
+	case_param "$1" belongto "$DMROOT.IP.Diagnostics.UploadDiagnostics." && {
+		common_execute_method_param "$DMROOT.IP.Diagnostics.UploadDiagnostics.DiagnosticsState" "1" \
+			"get_upload_diagnostics_value state" "set_upload_diagnostics_state" "xsd:string"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.UploadDiagnostics.Interface" "1" \
+			"get_upload_diagnostics_value interface" "set_upload_diagnostics_iface" "xsd:string"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.UploadDiagnostics.UploadURL" "1" \
+			"get_upload_diagnostics_value url" "set_upload_diagnostics_url" "xsd:string"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.UploadDiagnostics.DSCP" "1" \
+			"get_upload_diagnostics_value dscp" "set_upload_diagnostics_dscp" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.UploadDiagnostics.TestFileLength" "1" \
+			"get_upload_diagnostics_value file_len" "set_upload_diagnostics_file_len" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.UploadDiagnostics.ROMTime" "0" \
+			"get_upload_diagnostics_value rom_time" "" "xsd:dateTime"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.UploadDiagnostics.BOMTime" "0" \
+			"get_upload_diagnostics_value bom_time" "" "xsd:dateTime"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.UploadDiagnostics.EOMTime" "0" \
+			"get_upload_diagnostics_value eom_time" "" "xsd:dateTime"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.UploadDiagnostics.TestBytesSent" "0" \
+			"get_upload_diagnostics_value test_bytes" "" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.UploadDiagnostics.TotalBytesSent" "0" \
+			"get_upload_diagnostics_value total_bytes" "" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.UploadDiagnostics.UploadTransports" "0" \
+			"echo HTTP,FTP" "" "xsd:string[]"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.UploadDiagnostics.NumberOfConnections" "1" \
+			"get_upload_diagnostics_value connections" "set_upload_diagnostics_connections" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.IP.Diagnostics.UploadDiagnostics.TimeBasedTestDuration" "1" \
+			"get_upload_diagnostics_value duration" "set_upload_diagnostics_duration" "xsd:unsignedInt"
+		return 0
+	}
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+#######################################
+#   Data model parameters functions   #
+#######################################
+
+#
+# DownloadDiagnostics
+#
+
+get_download_diagnostics_value() {
+	local key="$1"
+	local value=""
+
+	value=$(grep "$key" "$g_download_diagnostics_file" | awk '{print $2}')
+
+	echo "$value"
+}
+
+set_download_diagnostics_value() {
+	local key="$1"
+	local value="$2"
+	local script="/usr/libexec/download_diagnostics_init.sh"
+
+	sed -i "s|^$key .*|$key $value|" \
+		$g_download_diagnostics_file
+
+	# Terminate test
+	local pid_list=$(pgrep -f download_diagnostics_init.sh)
+
+	for pid in $pid_list; do
+		kill "$pid" 2>/dev/null
+	done
+
+	local pid_list=$(pgrep -f download_diagnostics.sh)
+
+	for pid in $pid_list; do
+		kill "$pid" 2>/dev/null
+	done
+
+	# Terminate curl command
+	pid_list=$(pgrep -f curl)
+
+	for pid in $pid_list; do
+		kill "$pid" 2>/dev/null
+	done
+
+	local state=$(get_download_diagnostics_value state)
+	[ ! -f "$script" ] && script="/usr/local$script"
+
+	if [ "$state" == "Requested" ]; then
+		# Run Download Diagnostics test
+		"$script" &
+	else
+		[ "$key" != "state" ] && sed -i "s/^state .*/state None/" \
+						 $g_download_diagnostics_file
+	fi
+}
+
+set_download_diagnostics_state() {
+	local input="$1"
+
+	[ "$input" != "Requested" ] && return $E_INVALID_PARAMETER_VALUE
+
+	set_download_diagnostics_value "state" "$input"
+}
+
+set_download_diagnostics_iface() {
+	local input="$1"
