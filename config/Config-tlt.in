	detail
		Device, manufactoring information, MQTT, Lua script
	detail if MOBILE_SUPPORT
		\, GSM, Mobile usage
	detail if WIFI_SCANNER_SUPPORT
		\, WiFi Scanner
	detail if BLUETOOTH_SUPPORT
		\, Bluetooth
	detail if DLMS_SUPPORT
		\, DLMS
	detail if DNP3_SUPPORT
		\, DNP3
	detail if MBUS_SUPPORT
		\, M-Bus
	detail if IMPULSE_COUNTER_SUPPORT
		\, Impulse Counter
	detail if IO_MODBUS_SUPPORT
		\, Modbus, Modbus alarms
	detail if OPCUA_SUPPORT
		\, OPC UA
	detail if DATA_SENDER_ADVANCED_SUPPORT && MOBILE_SUPPORT
		\, SMS
	detail if DATA_SENDER_ADVANCED_SUPPORT && IO_SUPPORT
		\, I/O
	detail if DATA_SENDER_ADVANCED_SUPPORT && GPS_SUPPORT
		and GPS
	detail
		data inputs; HTTP, MQTT
	detail if DATA_SENDER_ADVANCED_SUPPORT && MOBILE_SUPPORT
		\, SMS
	detail if DATA_SENDER_ADVANCED_SUPPORT
		\, FTP, SMTP, Socket, Lua script
	detail if AZURE_SUPPORT
		and Azure IoT Hub
	detail
		servers

