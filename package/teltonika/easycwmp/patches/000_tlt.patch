diff --recursive --unified --new-file --no-dereference --exclude .gitver upstream/ext/openwrt/scripts/functions/wireless/wifi src/ext/openwrt/scripts/functions/wireless/wifi
--- upstream/ext/openwrt/scripts/functions/wireless/wifi	1970-01-01 00:00:00.000000000 +0000
+++ src/ext/openwrt/scripts/functions/wireless/wifi	2026-03-25 10:23:48.000000000 +0000
@@ -0,0 +1,1336 @@
+#!/bin/sh
+# Copyright (C) 2016 MOHAMED Kallel <mohamed.kallel@yahoo.fr>
+
+#common_execute_method_param "$parameter" "$permission" "$get_cmd" "$set_cmd" "xsd:$type" "$forcedinform"
+#  $forcedinform should be set to 1 if the parameter is included in the inform message otherwise empty
+#  Default of $type = string
+
+#############################
+#   Entry point functions   #
+#############################
+
+prefix_list="$prefix_list $DMROOT.WiFi."
+entry_execute_method_list="$entry_execute_method_list entry_execute_method_root_WiFi"
+
+UCI_SHOW_X="/sbin/uci -qX ${UCI_CONFIG_DIR:+-c $UCI_CONFIG_DIR} show"
+
+################
+#  Device.WiFi #
+################
+
+entry_execute_method_root_WiFi() {
+	case "$1" in ""|"$DMROOT."|"$DMROOT.WiFi."*)
+		common_execute_method_obj "$DMROOT.WiFi." "0"
+		common_execute_method_obj "$DMROOT.WiFi.Radio." "0" "" "" "wifi_radio_browse_instances $1"
+		common_execute_method_obj "$DMROOT.WiFi.SSID." "1" "add_wifi_iface" "" "wifi_ssid_browse_instances $1"
+		common_execute_method_param "$DMROOT.WiFi.AccessPointNumberOfEntries" "0" \
+			"get_wifi_ap_noe" "" "xsd:unsignedInt"
+		common_execute_method_obj "$DMROOT.WiFi.AccessPoint." "1" \
+			"add_wifi_ap" "" "count_wifi_ap_obj $1"
+		return 0
+		;;
+	esac
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+get_wifi_ap_noe() {
+	json_load "$(ubus call api get '{"path":"/wireless/interfaces/config"}')"
+	json_select http_body
+	json_select data
+	json_get_keys keys
+
+	keys="${keys##* }"
+	if [ -n "$keys" ]; then
+		echo "$keys"
+	else
+		echo "0"
+	fi
+}
+
+sub_entry_WiFi_Radio() {
+	local j="$2"
+	local radio="$3"
+	case_param "$1" belongto "$DMROOT.WiFi.Radio.$j." && {
+		common_execute_method_obj "$DMROOT.WiFi.Radio.$j." "0"
+		common_execute_method_param  "$DMROOT.WiFi.Radio.$j.Enable" "1" "wifi_radio_get_Enable $radio" "wifi_radio_set_Enable $radio" "xsd:boolean"
+		common_execute_method_param  "$DMROOT.WiFi.Radio.$j.Status" "0" "wifi_radio_get_Status $radio"
+		common_execute_method_param  "$DMROOT.WiFi.Radio.$j.Name" "0" "wifi_radio_get_Name $radio"
+		common_execute_method_param  "$DMROOT.WiFi.Radio.$j.SupportedFrequencyBands" "0" "wifi_radio_get_FrequencyBands $radio"
+		common_execute_method_param  "$DMROOT.WiFi.Radio.$j.OperatingFrequencyBand" "0" "wifi_radio_get_FrequencyBands $radio"
+		common_execute_method_param  "$DMROOT.WiFi.Radio.$j.ChannelsInUse" "0" "wifi_radio_get_ChannelsInUse $radio"
+		common_execute_method_param  "$DMROOT.WiFi.Radio.$j.Channel" "1" "wifi_radio_get_Channel $radio" "wifi_radio_set_Channel $radio" "xsd:unsignedInt"
+		common_execute_method_param  "$DMROOT.WiFi.Radio.$j.AutoChannelSupported" "0" "echo 1" "" "xsd:boolean"
+		common_execute_method_param  "$DMROOT.WiFi.Radio.$j.AutoChannelEnable" "1" "wifi_radio_get_AutoChannelEnable $radio" "wifi_radio_set_AutoChannelEnable $radio" "xsd:boolean"
+		common_execute_method_param  "$DMROOT.WiFi.Radio.$j.OperatingStandards" "1" "wifi_radio_get_OperatingStandards $radio" "wifi_radio_set_OperatingStandards $radio"
+		return 0
+	}
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+sub_entry_WiFi_SSID() {
+	local j="$2"
+	local iface="$3"
+	case_param "$1" belongto "$DMROOT.WiFi.SSID.$j." && {
+		common_execute_method_obj "$DMROOT.WiFi.SSID.$j." "1" "" "del_wifi_iface $iface"
+		common_execute_method_param  "$DMROOT.WiFi.SSID.$j.Enable" "1" "wifi_ssid_get_Enable $iface" "wifi_ssid_set_Enable $iface" "xsd:boolean"
+		common_execute_method_param  "$DMROOT.WiFi.SSID.$j.Status" "0" "wifi_ssid_get_Status $iface"
+		common_execute_method_param  "$DMROOT.WiFi.SSID.$j.Name" "0" "wifi_ssid_get_Name $iface"
+		common_execute_method_param  "$DMROOT.WiFi.SSID.$j.LowerLayers" "0" "wifi_ssid_get_LowerLayers $iface" ""
+		common_execute_method_param  "$DMROOT.WiFi.SSID.$j.SSID" "1" "wifi_ssid_get_SSID $iface" "wifi_ssid_set_SSID $iface"
+		common_execute_method_param  "$DMROOT.WiFi.SSID.$j.X_IPInterface" "0" "wifi_ssid_get_X_IPInterface $iface" ""
+		return 0
+	}
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+wifi_radio_get_max_instance() {
+	local max=`$UCI_SHOW_X wireless | grep "wifi_radio_instance" | cut -d'=' -f2 | sed 's/[^0-9]*//g' | sort -nru | head -1`
+	echo ${max:-0}
+}
+
+wifi_iface_get_max_instance() {
+	local max=`$UCI_SHOW_X wireless | grep "wifi_iface_instance" | cut -d'=' -f2 | sed 's/[^0-9]*//g' | sort -nru | head -1`
+	echo ${max:-0}
+}
+
+wifi_radio_update_instance() {
+	local radio="$1"
+	local instance=`$UCI_GET $radio.wifi_radio_instance`
+	if [ -z "$instance" ]; then
+		instance=`wifi_radio_get_max_instance`
+		$UCI_SET $radio.wifi_radio_instance=$((++instance))
+		$UCI_COMMIT
+	fi
+	echo $instance
+}
+
+wifi_iface_update_instance() {
+	local iface="$1"
+	local instance=`$UCI_GET $iface.wifi_iface_instance`
+	if [ -z "$instance" ]; then
+		instance=`wifi_iface_get_max_instance`
+		$UCI_SET $iface.wifi_iface_instance=$((++instance))
+		$UCI_COMMIT
+	fi
+	echo $instance
+}
+
+wifi_radio_browse_instances() {
+	local radio radios=`$UCI_SHOW_X wireless | grep "wireless\..*=wifi-device" | cut -d "=" -f 1`
+	for radio in $radios; do
+		local j=`wifi_radio_update_instance $radio`
+		sub_entry_WiFi_Radio  "$1" "$j" "$radio"
+	done
+}
+
+wifi_ssid_browse_instances() {
+	local iface ifaces=`$UCI_SHOW_X wireless | grep "wireless\..*=wifi-iface" | cut -d "=" -f 1`
+	for iface in $ifaces; do
+		local j=`wifi_iface_update_instance $iface`
+		sub_entry_WiFi_SSID  "$1" "$j" "$iface"
+	done
+}
+
+add_wifi_iface() {
+	local instance=`wifi_iface_get_max_instance`
+	local section=`$UCI_ADD  wireless wifi-iface`
+	$UCI_SET wireless.$section.wifi_iface_instance=$((++instance))
+	$UCI_COMMIT
+	echo $instance
+}
+
+del_wifi_iface() {
+	local iface="$1"
+	$UCI_DELETE $iface
+	$UCI_COMMIT
+	return 0
+}
+
+wifi_radio_get_Enable() {
+	local val=`$UCI_GET $1.disabled`
+	[ "$val" = "1" ] && echo "0" || echo "1"
+}
+
+wifi_radio_set_Enable() {
+	local ret
+	common_set_bool "$1.disabled" "$2" "" "1"
+	ret=$?
+	return $ret
+}
+
+wifi_radio_get_Status() {
+	local device=${1#*.}
+	local res up
+
+	res=`ubus call network.wireless status`
+	if [ "$res" != "" ]; then
+		json_init
+		json_load "$res" >&2
+		json_select "$device" >&2
+		json_get_var up up >&2
+	fi
+	[ "$up" = "1" ] && echo Up || echo Down
+}
+
+wifi_radio_get_Name() {
+	echo ${1#*.}
+}
+
+wifi_radio_get_FrequencyBands() {
+	local phy="phy${1#*radio}"
+	local freq=`iw phy $phy info | grep  "MHz.*dBm" | head -1 | awk '{print $2}'`
+	[ "${freq#24}" = "$freq" ] && echo "5GHz" || echo "2.4GHz"
+}
+
+wifi_radio_get_ChannelsInUse() {
+	local freq="`iw phy phy0 info | grep  MHz.*dBm | awk -F'[][]' '{print $2}' |  tr '\n' ','`"
+	echo ${freq%,}
+}
+
+wifi_radio_get_Channel() {
+	local channel phy freq
+
+	channel=`$UCI_GET $1.channel`
+	[ "$channel" != "" -a "$channel" != "auto" ] && { echo $channel; return; }
+
+	phy="phy${1#*radio}"
+	freq=`iw phy $phy info | grep  "MHz.*dBm" | head -1 | awk '{print $2}'`
+	if [ "${freq#24}" != "$freq" ]; then
+		channel=`iw dev | grep "channel.*(24.*MHz)" | head -1 | awk '{print $2}'`
+	else
+		channel=`iw dev | grep "channel" | grep -v "channel.*(24.*MHz)" | head -1 | awk '{print $2}'`
+	fi
+	echo $channel
+}
+
+wifi_radio_set_Channel() {
+	case $2 in
+		(*[^0-9]*|'') return $E_INVALID_PARAMETER_VALUE;;
+	esac
+
+	[ "$2" -lt 1 -o "$2" -gt 255 ] && return $E_INVALID_PARAMETER_VALUE
+
+	$UCI_SET $1.channel=$2
+}
+
+wifi_radio_get_AutoChannelEnable() {
+	local en=`$UCI_GET $1.channel`
+	[ "$en" = "" -o "$en" = "auto" ] && echo 1 || echo 0
+}
+
+wifi_radio_set_AutoChannelEnable() {
+	local val=`echo "$2" | tr '[A-Z]' '[a-z]'`
+	if [ "$val" = "1" -o "$val" = "true" ]; then
+		$UCI_SET $1.channel=auto
+	else
+		local channel=`wifi_radio_get_Channel $1`
+		$UCI_SET $1.channel=$channel
+	fi
+}
+
+wifi_radio_get_OperatingStandards() {
+	local val=`$UCI_GET $1.hwmode`
+	echo ${val#11}
+}
+
+wifi_radio_set_OperatingStandards() {
+	local band="$(wifi_radio_get_FrequencyBands $1)"
+
+	if [ "$band" = "2.4GHz" ]; then
+		case "$2" in
+			b|g|n|ax|be) ;;
+			*) return $E_INVALID_PARAMETER_VALUE ;;
+		esac
+	elif [ "$band" = "5GHz" ]; then
+		case "$2" in
+			a|n|ac|ax|be) ;;
+			*) return $E_INVALID_PARAMETER_VALUE ;;
+		esac
+	elif [ "$band" = "6GHz" ]; then
+		case "$2" in
+			ax|be) ;;
+			*) return $E_INVALID_PARAMETER_VALUE ;;
+		esac
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+
+	$UCI_SET $1.hwmode=11$2
+}
+
+wifi_ssid_get_Enable() {
+	local val=`$UCI_GET $1.disabled`
+	[ "$val" = "1" ] && echo "0" || echo "1"
+}
+
+wifi_ssid_set_Enable() {
+	local ret
+	common_set_bool "$1.disabled" "$2" "" "1"
+	ret=$?
+	return $ret
+}
+
+wifi_ssid_get_Status() {
+	local name=`wifi_ssid_get_Name $1`
+	[ "$name" != "" ] && echo Up || echo Down
+}
+
+wifi_ssid_get_Name() {
+	local iface=$1
+	local res ifname section device e i=0
+
+	device=`$UCI_GET $1.device`
+	[ "$device" = "" ] && return 0
+	res=`ubus call network.wireless status`
+	[ "$res" = "" ] && return 0
+	json_init
+	json_load "$res"
+	json_select "$device"
+	json_select "interfaces"
+	while [ 1 ]; do
+		let i++
+		json_select "$i"  >&2
+		e=$?
+		[ "$e" != 0 ] && break
+		json_get_var section section >&2
+		[ "$section" != "${iface#*.}" ] && { json_select ".." >&2; continue; }
+		json_get_var ifname ifname >&2
+		echo $ifname
+		break;
+	done
+}
+
+wifi_ssid_get_LowerLayers() {
+	local device=`$UCI_GET $1.device`
+	local instance=`$UCI_GET wireless.$device.wifi_radio_instance`
+	[ "$instance" != "" ] && echo "$DMROOT.WiFi.Radio.$instance."
+}
+
+# wifi_ssid_set_LowerLayers() {
+# 	local tmp=${2#$DMROOT.WiFi.Radio.}
+# 	[ "$tmp" = "$2" ] && return
+# 	local instance=${tmp%.}
+# 	[ "$tmp" = "$instance" ] && return
+# 	local device=`$UCI_SHOW_X wireless | grep "wifi_radio_instance=$instance" | cut -d'.' -f2`
+# 	$UCI_SET $1.device=$device
+# }
+
+wifi_ssid_get_SSID() {
+	local ssid=`$UCI_GET $1.ssid`
+	echo $ssid
+}
+
+wifi_ssid_set_SSID() {
+	[ -z "$2" ] || [ "${#2}" -gt 64 ] && return $E_INVALID_PARAMETER_VALUE
+	$UCI_SET $1.ssid=$2
+}
+
+wifi_ssid_get_X_IPInterface() {
+	local network=`$UCI_GET $1.network`
+	local instance=`$UCI_GET network.$network.ip_int_instance`
+	[ "$instance" != "" ] && echo "$DMROOT.IP.Interface.$instance."
+}
+
+# wifi_ssid_set_X_IPInterface() {
+# 	local tmp=${2#$DMROOT.IP.Interface.}
+# 	[ "$tmp" = "$2" ] && return
+# 	local instance=${tmp%.}
+# 	[ "$tmp" = "$instance" ] && return
+# 	local network=`$UCI_SHOW_X network | grep "ip_int_instance=$instance" | cut -d'.' -f2`
+# 	$UCI_SET $1.network=$network
+# }
+
+############################
+#  Device.WiFi.AccessPoint #
+############################
+
+add_wifi_ap() {
+	json_load "$(ubus call api post '{
+		     "path":"/wireless/interfaces/config",
+		     "body":{
+			"data":{
+			    "mode":"ap",
+			    "ssid":"default"
+			}
+		     }}')"
+	json_select http_body
+	json_get_var success success
+	[ "$success" != "1" ] && return $E_INVALID_PARAMETER_VALUE
+
+	json_load "$(ubus call api get '{"path":"/wireless/interfaces/config"}')"
+	json_select http_body
+	json_select data
+	json_get_keys keys
+
+	keys="${keys##* }"
+	if [ -n "$keys" ]; then
+		echo "$keys"
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+delete_wifi_ap() {
+	local id="$1"
+
+	json_load "$(ubus call api delete '{"path":"/wireless/interfaces/config/'$id'"}')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+count_wifi_ap_obj() {
+	local i=1
+	local ifaces="$(ubus call api get '{"path":"/wireless/interfaces/config"}' | \
+			  jsonfilter -e '@.http_body.data[*]')"
+
+	OLD_IFS="$IFS"
+	IFS=$'\n'
+	for table in $ifaces; do
+		IFS="$OLD_IFS"
+		sub_entry_wifi_ap "$1" "$i" "$table"
+		i=$((i + 1))
+		IFS=$'\n'
+	done
+	IFS="$OLD_IFS"
+}
+
+sub_entry_wifi_ap() {
+	local i="$2" 
+	local table="$3"
+
+	case_param "$1" belongto "$DMROOT.WiFi.AccessPoint.$i." && {
+		local id="$(echo "$table" | jsonfilter -e '@.id')"
+		local enabled="$(echo "$table" | jsonfilter -e '@.enabled')"
+		local hidden="$(echo "$table" | jsonfilter -e '@.hidden')"
+		local wmm="$(echo "$table" | jsonfilter -e '@.wmm')"
+		local isolate="$(echo "$table" | jsonfilter -e '@.isolate')"
+		local macfilter="$(echo "$table" | jsonfilter -e '@.macfilter')"
+		local maclist="$(echo "$table" | jsonfilter -e '@.maclist[*]')"
+
+		local status="Disabled"
+		[ "$enabled" = "1" ] && status="Enabled"
+
+		if [ "$hidden" = "1" ]; then
+			hidden="0"
+		else
+			hidden="1"
+		fi
+
+		[ -z "$wmm" ] && wmm=0
+		[ -z "$isolate" ] && isolate=0
+
+		case "$macfilter" in
+			allow) macfilter="Allow" ;;
+			deny) macfilter="Deny" ;;
+			*) macfilter="Disabled" ;;
+		esac
+
+		maclist="$(echo "$maclist" | tr '\n' ',' | sed 's/,$//')"
+
+		common_execute_method_obj "$DMROOT.WiFi.AccessPoint.$i." "1" "" "delete_wifi_ap $id"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.Enable" "1" \
+			"echo $enabled" "set_wifi_ap_boolean $id enabled" "xsd:boolean"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.Status" "0" \
+			"echo $status" "" "xsd:string"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.SSIDReference" "0" \
+			"echo Device.WiFi.SSID.$i" "" "xsd:string"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.SSIDAdvertisementEnabled" "1" \
+			"echo $hidden" "set_wifi_ap_ssidadvert $id" "xsd:boolean"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.WMMCapability" "0" \
+			"echo 1" "" "xsd:boolean"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.UAPSDCapability" "0" \
+			"echo 1" "" "xsd:boolean"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.WMMEnable" "1" \
+			"echo $wmm" "set_wifi_ap_boolean $id wmm" "xsd:boolean"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.IsolationEnable" "1" \
+			"echo $isolate" "set_wifi_ap_boolean $id isolate" "xsd:boolean"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.MACAddressControlEnabled" "1" \
+			"echo $macfilter" "set_wifi_ap_macaddrcontrol $id" "xsd:string"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.AllowedMACAddress" "1" \
+			"echo $maclist" "set_wifi_ap_allowedmac $id" "xsd:string[]"
+
+		# .Security
+		local device="$(echo "$table" | jsonfilter -e '@.device[0]')"
+		local encrypt_modes="$(ubus call api get '{"path":"/wireless/devices/options/'$device'"}' | \
+				       jsonfilter -e '@.http_body.data.features.encryption' | \
+				       sed 's/[[:space:]]//g')"
+		local encryption="$(echo "$table" | jsonfilter -e '@.encryption')"
+		local cipher="$(echo "$table" | jsonfilter -e '@.cipher')"
+		local wpa_group_rekey="$(echo "$table" | jsonfilter -e '@.wpa_group_rekey')"
+		local auth_server="$(echo "$table" | jsonfilter -e '@.auth_server')"
+		local auth_port="$(echo "$table" | jsonfilter -e '@.auth_port')"
+		local ieee80211w="$(echo "$table" | jsonfilter -e '@.ieee80211w')"
+
+		case "$encryption" in
+			none)
+				encryption="None"
+				ieee80211w="0"
+				;;
+			owe)
+				encryption="OWE"
+				ieee80211w="2"
+				;;
+			psk)
+				encryption="WPA-Personal"
+				[ -z "$ieee80211w" ] && ieee80211w="0"
+				;;
+			psk2)
+				encryption="WPA2-Personal"
+				[ -z "$ieee80211w" ] && ieee80211w="0"
+				;;
+			psk-mixed)
+				encryption="WPA-WPA2-Personal"
+				[ -z "$ieee80211w" ] && ieee80211w="0"
+				;;
+			sae)
+				encryption="WPA3-Personal"
+				ieee80211w="2"
+				;;
+			sae-mixed)
+				encryption="WPA3-Personal-Transition"
+				ieee80211w="2"
+				;;
+			wpa)
+				encryption="WPA-Enterprise"
+				[ -z "$ieee80211w" ] && ieee80211w="0"
+				;;
+			wpa2)
+				encryption="WPA2-Enterprise"
+				[ -z "$ieee80211w" ] && ieee80211w="0"
+				;;
+			wpa3)
+				encryption="WPA3-Enterprise"
+				ieee80211w="2"
+				;;
+			*)
+				encryption="Unknown"
+				ieee80211w="0"
+				;;
+		esac
+
+		case "$cipher" in
+			auto|tkip+ccmp) cipher="TKIP,AES" ;;
+			tkip) cipher="TKIP" ;;
+			ccmp) cipher="AES" ;;
+			*) cipher="Unknown" ;;
+		esac
+
+		case "$ieee80211w" in
+			0) ieee80211w="Disabled" ;;
+			1) ieee80211w="Optional" ;;
+			2) ieee80211w="Required" ;;
+		esac
+
+		common_execute_method_obj "$DMROOT.WiFi.AccessPoint.$i.Security." "0"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.Security.ModesSupported" "0" \
+			"get_wifi_ap_security_modes $encrypt_modes" "" "xsd:string[]"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.Security.ModeEnabled" "1" \
+			"echo $encryption" "set_wifi_ap_security_mode $id" "xsd:string"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.Security.EncryptionMode" "1" \
+			"echo $cipher" "set_wifi_ap_security_encryption $id $encryption" "xsd:string[]"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.Security.PreSharedKey" "1" \
+			"" "set_wifi_ap_security_presharedkey $id" "xsd:hexBinary"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.Security.KeyPassphrase" "1" \
+			"" "set_wifi_ap_security_keypass $id" "xsd:string"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.Security.RekeyingInterval" "1" \
+			"echo $wpa_group_rekey" "set_wifi_ap_value $id wpa_group_rekey" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.Security.RadiusServerIPAddr" "1" \
+			"echo $auth_server" "set_wifi_ap_value $id auth_server" "xsd:string"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.Security.RadiusServerPort" "1" \
+			"echo $auth_port" "set_wifi_ap_value $id auth_port" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.Security.RadiusSecret" "1" \
+			"" "set_wifi_ap_value $id auth_secret" "xsd:string"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.Security.MFPConfig" "1" \
+			"echo $ieee80211w" "set_wifi_ap_security_mfpconfig $id" "xsd:string"
+
+		# .Interworking
+		local hotspot="$(ubus call api get '{"path":"/hotspot2/config/'$id'"}' | \
+				 jsonfilter -e '@.http_body.data')"
+		local interworking="$(echo "$hotspot" | jsonfilter -e '@.interworking')"
+		local access_network_type="$(echo "$hotspot" | jsonfilter -e '@.access_network_type')"
+		local internet="$(echo "$hotspot" | jsonfilter -e '@.internet')"
+		local venue_group="$(echo "$hotspot" | jsonfilter -e '@.venue_group')"
+		local venue_type="$(echo "$hotspot" | jsonfilter -e '@.venue_type')"
+		local hessid="$(echo "$hotspot" | jsonfilter -e '@.hessid')"
+
+		case "$access_network_type" in
+			0) access_network_type="PrivateNetwork" ;;
+			1) access_network_type="PrivateNetworkWithGuestAccess" ;;
+			2) access_network_type="ChargeablePublicNetwork" ;;
+			3) access_network_type="FreePublicNetwork" ;;
+			4) access_network_type="PersonalDeviceNetwork" ;;
+			5) access_network_type="EmergencyServicesOnlyNetwork" ;;
+			14) access_network_type="TestOrExperimental" ;;
+			*) access_network_type="Wildcard" ;;
+		esac
+
+		[ -z "$internet" ] && internet="0"
+
+		case "$venue_group" in
+			1) venue_group="Assembly" ;;
+			2) venue_group="Business" ;;
+			3) venue_group="Educational" ;;
+			4) venue_group="Factory-Industrial" ;;
+			5) venue_group="Institutional" ;;
+			6) venue_group="Mercantile" ;;
+			7) venue_group="Residential" ;;
+			8) venue_group="Storage" ;;
+			9) venue_group="Utility-Miscellaneous" ;;
+			10) venue_group="Vehicular" ;;
+			11) venue_group="Outdoor" ;;
+			*) venue_group="Unspecified" ;;
+		esac
+
+		common_execute_method_obj "$DMROOT.WiFi.AccessPoint.$i.Interworking." "0"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.Interworking.Enable" "1" \
+			"echo $interworking" "set_wifi_ap_interwork_boolean $id interworking" "xsd:boolean"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.Interworking.AccessNetworkType" "1" \
+			"echo $access_network_type" "set_wifi_ap_interwork_accessnettype $id" "xsd:string"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.Interworking.InternetAvailable" "1" \
+			"echo $internet" "set_wifi_ap_interwork_boolean $id internet" "xsd:boolean"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.Interworking.VenueGroup" "1" \
+			"echo $venue_group" "set_wifi_ap_interwork_venuegroup $id" "xsd:string"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.Interworking.VenueType" "1" \
+			"get_wifi_ap_interwork_venuetype $venue_group $venue_type" \
+			"set_wifi_ap_interwork_venuetype $id $venue_group" "xsd:string"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.Interworking.HESSID" "1" \
+			"echo $hessid" "set_wifi_ap_hotspot2_value $id hessid" "xsd:string"
+
+		# .ANQP
+		local ipaddr_type_availability="$(echo "$hotspot" | \
+						  jsonfilter -e '@.ipaddr_type_availability')"
+		local roaming_consortium="$(echo "$hotspot" | jsonfilter -e '@.roaming_consortium[*]')"
+		local domain_name="$(echo "$hotspot" | jsonfilter -e '@.domain_name[*]')"
+		local network_auth_type="$(echo "$hotspot" | jsonfilter -e '@.network_auth_type')"
+
+		case "$ipaddr_type_availability" in
+			0) ipaddr_type_availability="NotAvailable" ;;
+			1) ipaddr_type_availability="PublicIPv4" ;;
+			2) ipaddr_type_availability="PortRestrictedIPv4" ;;
+			3) ipaddr_type_availability="SingleNATIPv4" ;;
+			4) ipaddr_type_availability="DoubleNATIPv4" ;;
+			5) ipaddr_type_availability="PortRestrictSingleNATIPv4" ;;
+			6) ipaddr_type_availability="PortRestrictDoubleNATIPv4" ;;
+			*) ipaddr_type_availability="Unknown" ;;
+		esac
+
+		roaming_consortium="$(echo "$roaming_consortium" | tr '\n' ',' | sed 's/,$//')"
+		domain_name="$(echo "$domain_name" | tr '\n' ',' | sed 's/,$//')"
+		network_auth_type="${network_auth_type#?}"
+
+		common_execute_method_obj "$DMROOT.WiFi.AccessPoint.$i.ANQP." "0"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.ANQP.IPv4AddressAvailability" "1" \
+			"echo $ipaddr_type_availability" "set_wifi_ap_anqp_ipv4addravailability $id" \
+			"xsd:string"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.ANQP.RoamingConsortiumOIs" "1" \
+			"echo $roaming_consortium" "set_wifi_ap_hotspot2_array_value $id roaming_consortium" \
+			"xsd:string[]"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.ANQP.Domains" "1" \
+			"echo $domain_name" "set_wifi_ap_hotspot2_array_value $id domain_name" "xsd:string[]"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.ANQP.NetworkAuthTypes" "1" \
+			"echo $network_auth_type" "set_wifi_ap_anqp_networkauthtype $id" "xsd:string"
+
+		# .AssociatedDevice
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.AssociatedDeviceNumberOfEntries" "0" \
+			"get_wifi_ap_assocdevice_noe $id" "" "xsd:unsignedInt"
+		common_execute_method_obj "$DMROOT.WiFi.AccessPoint.$i.AssociatedDevice." "0" \
+			"" "" "count_wifi_ap_assocdevice_obj $1 $i $id"
+		return 0;
+	}
+	return $E_INVALID_PARAMETER_NAME;
+}
