+static void process_ajax_request(struct client *cl, const char *post_data)
+{
+	char *session_key = NULL;
+	char *keys	  = NULL;
+	char *width_str	  = NULL;
+	char *height_str  = NULL;
+	char *root_url	  = NULL;
+
+	if (!cl) {
+		goto cleanup;
+	}
+
+	parse_url_args(cl, post_data, &session_key, &keys, &width_str, &height_str, &root_url);
+
+	int width  = safe_atoi(width_str, 80);
+	int height = safe_atoi(height_str, 24);
+
+	int session_is_new;
+	struct Session *session = findSession(session_key, NULL, &session_is_new, cl);
+
+	if (!session) {
+		send_empty_response(cl);
+		goto cleanup;
+	}
+
+	if (session->done || session->cleanup || session->dead_without_client) {
+		
+		send_empty_response(cl);
+
+		cleanup_session_pty(session);
+		
+		if (session->client == cl) {
+			session->client = NULL;
+		}
+		
+		session->done = 1;
+		session->cleanup = 1;
+		addToGraveyard(session, 5);
+		goto cleanup;
+	}
+
+	if (session_is_new && numSessions() > max_sessions) {
+		show_error_message_fmt(session, cl, "Maximum Sessions Reached", width, height,
+		                       "The maximum number of concurrent sessions (%d) has been reached. Please try again later.",
+		                       max_sessions);
+		goto cleanup;
+	}
+
+	if (session_is_new) {
+		if (!cli_enabled) {
+			show_error_message_fmt(session, cl, "CLI Disabled", width, height,
+			                       "The command line interface has been disabled by the administrator.");
+			goto cleanup;
+		}
+
+		if (forkLauncher() < 0) {
+			show_error_message_fmt(session, cl, "Failed to Launch Shell", width, height,
+			                       "An error occurred while trying to launch the shell. Please try again later.");
+			goto cleanup;
+		}
+
+		session->client	  = cl;
+		session->useLogin = 1;
+		session->port	  = get_request_port(cl);
+		struct Service *service = getService("/", serviceTable);
+
+		if (launchChild(service, session, root_url ? root_url : "/bin/sh") < 0) {
+			if (session->client == cl) {
+				session->client = NULL;
+			}
+			ops->client_error(cl, 500, "Internal Error", "Failed to launch shell");
+			goto cleanup;
+		}
+
+		send_json_response(cl, session->sessionKey, "");
+		goto cleanup;
+	}
+
+	if (width > 0 && height > 0 && (width != session->width || height != session->height)) {
+		session->width	= width;
+		session->height = height;
+		
+		if (session->pty >= 0) {
+			struct winsize ws;
+			ws.ws_row = height;
+			ws.ws_col = width;
+			ws.ws_xpixel = 0;
+			ws.ws_ypixel = 0;
+			ioctl(session->pty, TIOCSWINSZ, &ws);
+		}
+	}
+
+	if (keys && keys[0]) {
+		size_t keys_len = SAFE_STRLEN(keys, 4096);
+		if (keys_len % 2 == 0 && session->pty >= 0) {
+			char *key_codes = calloc(keys_len / 2, sizeof(char));
+			if (key_codes) {
+				for (size_t i = 0; i < keys_len; i += 2) {
+					char hex[3] = { keys[i], keys[i + 1], 0 };
+					char *endptr;
+					long val = strtol(hex, &endptr, 16);
+					if (endptr != hex + 2) {
+						val = 0;
+					}
+					key_codes[i / 2] = (char)val;
+				}
+
+				ssize_t written = write(session->pty, key_codes, keys_len / 2);
+				if (written < 0 && errno == EAGAIN) {
+					char bell = '\x07';
+					complete_pending_request(session, &bell, 1, 4096);
+				}
+				free(key_codes);
+			}
+		}
+
+		send_json_response(cl, session->sessionKey, "");
+		goto cleanup;
+	}
+
+	// Check if we have buffered data first
+	if (session->len > 0 && session->buffered) {
+		session->client = cl;
+		complete_pending_request(session, session->buffered, session->len, 4096);
+
+		goto cleanup;
+	}
+
+	session->client = cl;
+	struct dispatch *d = &cl->dispatch;
+	struct shell_dispatch_data *dd = (struct shell_dispatch_data *)d->req_data;
+	if (dd) {
+		dd->session = session;
+	}
+cleanup:
+	SAFE_FREE(session_key);
+	SAFE_FREE(keys);
+	SAFE_FREE(width_str);
+	SAFE_FREE(height_str);
+	SAFE_FREE(root_url);
+}
