-#endif
-	}
-
-	if (!sym_change_count)
-		sym_clear_all_valid();
-
-	/* Force write of all non-duplicate symbols. */
-
-	/* Write out everything by default. */
-	for(menu = rootmenu.list; menu; menu = next_menu(menu))
-		if (menu->sym) menu->sym->flags |= SYMBOL_FORCEWRITE;
-
-	menu = rootmenu.list;
-	while (menu) {
-		sym = menu->sym;
