+int _modbus_check_if_broadcast(modbus_t *ctx, int slave, int function)
+{
+    if (ctx->bc &&
+	slave == MODBUS_BROADCAST_ADDRESS &&
+	(function == MODBUS_FC_WRITE_SINGLE_COIL ||
+	function == MODBUS_FC_WRITE_MULTIPLE_COILS ||
+	function == MODBUS_FC_WRITE_SINGLE_REGISTER ||
+	function == MODBUS_FC_WRITE_MULTIPLE_REGISTERS ||
+	function == MODBUS_FC_MASK_WRITE_REGISTER ||
+	function == MODBUS_FC_WRITE_AND_READ_REGISTERS)) {
+
+	if (ctx->debug) {
+	    printf("Broadcast request, no response expected.\n");
+	}
+
+	return 1;
+    }
+
+    return 0;
+}
