+#!/bin/sh
+
+. /usr/share/libubox/jshn.sh
+
+# Get a list of params
+CONFIG_FILE="/var/run/easycwmp/tr143_download_diagnostics"
+SCRIPT="/usr/libexec/download_diagnostics.sh"
+
+cleanup() {
+	local state="$1"
+	local port="$2"
+	local dscp_id="$3"
+	local interface="$4"
+
+	rm /var/run/easycwmp/tr143_dd_result* >/dev/null 2>&1
+
+	# Remove DSCP
+	ubus call api delete '{"path":"/firewall/traffic_rules/config/'$dscp_id'"}' >/dev/null 2>&1
+
+	sed -i "s/^state .*/state $state/" "$CONFIG_FILE"
+
+	# Send '8 DIAGNOSTICS COMPLETE' message
+	ubus call tr069 inform '{"event":"8 DIAGNOSTICS COMPLETE"}'
+}
+
+compare_time() {
+	local ts1="$1"
+	local ts2="$2"
+	local earliest="$3"
+
+	# Remove 'Z' and split
+	ts1_base=$(echo "$ts1" | cut -d'.' -f1 | sed 's/T/ /')
+	ts1_micro=$(echo "$ts1" | cut -d'.' -f2 | tr -d 'Z')
+	ts2_base=$(echo "$ts2" | cut -d'.' -f1 | sed 's/T/ /')
+	ts2_micro=$(echo "$ts2" | cut -d'.' -f2 | tr -d 'Z')
+
+	# Convert base to seconds since epoch
+	ts1_sec=$(date -d "$ts1_base" +"%s")
+	ts2_sec=$(date -d "$ts2_base" +"%s")
+
+	# Compare
+	if [ "$ts1_sec" -lt "$ts2_sec" ] ||
+	   { [ "$ts1_sec" -eq "$ts2_sec" ] &&
+	   [ "$ts1_micro" -lt "$ts2_micro" ]; }; then
+		if [ "$earliest" -eq 1 ]; then
+			echo "$ts1"
+		else
+			echo "$ts2"
+		fi
+	else
+		if [ "$earliest" -eq 1 ]; then
+			echo "$ts2"
+		else
+			echo "$ts1"
+		fi
+	fi
+}
+
+# If test configuration is changed during testing, to keep 'Requested'
+# status delay test execution
+sleep 5
+
+interface=$(grep "^interface" "$CONFIG_FILE" | awk '{print $2}')
+url=$(grep "^url" "$CONFIG_FILE" | awk '{print $2}')
+dscp=$(grep "^dscp" "$CONFIG_FILE" | awk '{print $2}')
+connections=$(grep "^connections" "$CONFIG_FILE" | awk '{print $2}')
+duration=$(grep "^duration" "$CONFIG_FILE" | awk '{print $2}')
+
+# Validate URL a little bit
+[ -z "$url" ] && {
+	logger "[TR-069] DownloadDiagnostics: no URL provided"
+	sed -i "s/^state .*/state Error_InitConnectionFailed/" "$CONFIG_FILE"
+	return
+}
+
+command="/usr/sbin/easycwmp"
+[ ! -f "$command" ] && command="/usr/local$command"
+json_load "$($command get $interface.Name)"
+json_get_var iface value
+[ -z "$iface" ] && {
+	logger "[TR-069] DownloadDiagnostics: No interface $interface name found"
+	sed -i "s/^state .*/state Error_InitConnectionFailed/" "$CONFIG_FILE"
+	return
+}
+
+# if interface is mobile interface
+proto="$(uci get network.$iface.proto)"
+if [ "$proto" == "wwan" ]; then
+	json_load "$(ubus call network.interface."$iface"_4 status)" >/dev/null 2>&1
+	json_get_var iface l3_device >/dev/null 2>&1
+	[ -z "$iface" ] && {
+		json_load "$(ubus call network.interface."$iface"_6 status)" >/dev/null 2>&1
+		json_get_var iface l3_device >/dev/null 2>&1
+	}
