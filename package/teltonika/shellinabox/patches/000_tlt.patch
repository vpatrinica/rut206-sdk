+static int get_request_port(struct client *cl)
+{
+	if (!cl)
+		return 0;
+
+	if (cl->srv_addr.family == AF_INET) {
+		struct sockaddr_in *sin = (struct sockaddr_in *)&cl->srv_addr;
+		return sin->sin_port;
+	} else if (cl->srv_addr.family == AF_INET6) {
+		struct sockaddr_in6 *sin6 = (struct sockaddr_in6 *)&cl->srv_addr;
+		return sin6->sin6_port;
+	}
+
+	return 0;
+}
