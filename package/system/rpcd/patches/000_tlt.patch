+#!/bin/sh
+
+. /lib/functions.sh
+
+CONFIG="rpcd"
+PAM_CONFIG="pam"
+PAM_COMMIT=0
+SECTION_COUNT=1
+SECTION_PREFIX="login"
+
+rename_section() {
+	local section="$1"
+	echo "$section" | grep -q "^cfg" || return
+
+	local new_section="${SECTION_PREFIX}${SECTION_COUNT}"
+	uci_rename "$CONFIG" "$section" "$new_section"
+
+	local users="$(uci_get "$PAM_CONFIG" "$CONFIG" "users")"
+	for user in $users; do
+		if [ "$user" = "$section" ]; then
+			uci_remove_list "$PAM_CONFIG" "$CONFIG" "users" "$user"
+			uci_add_list "$PAM_CONFIG" "$CONFIG" "users" "$new_section"
+			PAM_COMMIT=1
+		fi
+	done
+
+	SECTION_COUNT=$((SECTION_COUNT + 1))
+}
+
+config_load "$CONFIG"
+config_foreach rename_section "login"
+
+uci_commit "$CONFIG"
+[ $PAM_COMMIT -eq 1 ] && uci_commit "$PAM_CONFIG"
