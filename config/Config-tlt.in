config CORE_NETWORK_PACKAGES
	bool
	default y
	maintainer "Networks/Networks1"
	label "Network"
	imply PACKAGE_ip-full
	imply PACKAGE_udhcpc
	imply PACKAGE_kmod-br-netfilter if AP_DEVICE
	imply PACKAGE_vuci-app-network-ui if !AP_DEVICE
	imply PACKAGE_vuci-app-network-tap-ui if AP_DEVICE
	imply PACKAGE_vuci-app-network-devices-api
	detail
		Network Protocols: IPv4, IPv6, ARP, IPsec, PPP
		Transport Protocols: TCP, UDP, ICMP, GRE, ESP, RIP, OSPF, BGP, IPsec
		VLAN: Tagged
		Interfaces: Static IP, DHCP client, DHCPv6 client, IPv6 SLAAC
	detail if ADVANCED_NETWORK
		Network Protocols: \, IP NAT
		VLAN: \, untagged
		Interfaces: \, PPPoE client, IPv6 prefix management, WAN, LAN

config ADVANCED_NETWORK
	bool "Network"
	maintainer "Networks/Networks1"
	depends on !AP_DEVICE
	default y
	label "Network"
	imply PACKAGE_vuci-app-ports-settings-ui if PORT_LINK
	imply PACKAGE_ethtool-tiny if ETHTOOL_TINY
	imply PACKAGE_ethtool if !ETHTOOL_TINY
	imply BUSYBOX_DEFAULT_ARPING
	imply PACKAGE_vuci-app-dhcp-ui
	imply PACKAGE_odhcpd-ipv6only
	imply PACKAGE_vuci-app-routes-ui
	imply PACKAGE_vuci-app-dns-ui
	imply PACKAGE_vuci-app-vlan-ui
	imply PACKAGE_vuci-app-network-devices-ui if DSA_SUPPORT
	detail
		Status: LAN networks, DHCP leases, Firewall rules and policies, IPv4/IPv6 routes, ARP table, IPv6 neighours
		Routing: Static routing, policy based routing, routing rules
		DHCPv4: Status, server mode, relay mode, custom DHCP options, static leases
		DHCPv6: Status, server mode, statless mode, statefull mode, relay mode, hybrid mode, Router advertisement service, NDP proxy, static leases
		DNS: Caching DNS server, DNS forwardings, rebind protection, static DNS entries
		Bridging: Multiple bridges, STP, IGMP snooping (Multicast)
	detail if PORT_LINK
		Ports Control: View, enable, disable, auto-configuration control, transmission speed control
	detail if FRR_SUPPORT || FRR8_SUPPORT
		Routing: \, dynamic routing


