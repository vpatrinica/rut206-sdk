+##############################################
+#  Device.Cellular.Interface.{i}.SMS.Storage #
+##############################################
+
+count_iface_sms_storage() {
+	local usb_id="$2"
+	local i="$3"
+	local j=1
+	local storages="$(ubus call api get '{"path":"/messages/storage/status"}' | \
+			  jsonfilter -e '@.http_body.data[*]')"
+
+	OLD_IFS="$IFS"
+	IFS=$'\n'
+	for table in $storages; do
+		IFS="$OLD_IFS"
+		[ "$(echo "$table" | jsonfilter -e '@.modem_id')" = "$usb_id" ] && {
+			sub_entry_cellular_iface_sms_storage "$1" "$j" "$i" "$usb_id" "$table"
+			j=$((j + 1))
+		}
+		IFS=$'\n'
+	done
+	IFS="$OLD_IFS"
+}
+
+sub_entry_cellular_iface_sms_storage() {
+	local j="$2"
+	local i="$3"
+	local usb_id="$4"
+	local table="$5"
+
+	case_param "$1" belongto "$DMROOT.Cellular.Interface.$i.SMS.Storage.$j." && {
+		local used="$(echo "$table" | jsonfilter -e '@.used')"
+		local total="$(echo "$table" | jsonfilter -e '@.total')"
+
+		local capacity=0
+		local storage="0"
+		if [ -z "$used" ] || [ -z "$total" ] || [ "$used" = "N/A" ] || [ "$total" = "N/A" ]; then
+			capacity="N/A"
+		else
+			[ "$used" -lt "$total" ] && storage="1"
+			capacity=$((total - used))
+		fi
+
+		common_execute_method_obj "$DMROOT.Cellular.Interface.$i.SMS.Storage.$j." "0"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.SMS.Storage.$j.Location" "1" \
+			"get_iface_sms_storage_location $usb_id $j" \
+			"set_iface_sms_storage_location $usb_id $j" "xsd:string"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.SMS.Storage.$j.Capacity" "0" \
+			"echo $total" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.SMS.Storage.$j.StorageAvailable" "0" \
+			"echo $storage" "" "xsd:boolean"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.SMS.Storage.$j.AvailableCapacity" "0" \
+			"echo $capacity" "" "xsd:string"
+		return 0
+	}
+
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+get_iface_sms_storage_location() {
+	local usb_id="$1"
+	local j="$2"
+	local i=1
+
+	json_load "$(ubus call api get '{"path":"/messages/storage/config"}')"
+	json_select http_body
+	json_select data
+	json_get_keys keys
+	for var in $keys; do
+		json_select "$var"
+		json_get_var modem_id modem_id
+		[ "$modem_id" = "$usb_id" ] && {
+			[ "$i" = "$j" ] && {
+				json_get_var msg_storage msg_storage
+				echo "$msg_storage"
+				return 0
+			}
+			i=$((i + 1))
+		}
+		json_select ..
+	done
+}
+
+set_iface_sms_storage_location() {
+	local usb_id="$1"
+	local j="$2"
+	local input="$3"
+	local i=1
+
+	json_load "$(ubus call api get '{"path":"/messages/storage/config"}')"
+	json_select http_body
+	json_select data
+	json_get_keys keys
+	for var in $keys; do
+		json_select "$var"
+		json_get_var modem_id modem_id
+		[ "$modem_id" = "$usb_id" ] && {
+			[ "$i" = "$j" ] && {
+				json_get_var id id
+				break
+			}
+			i=$((i + 1))
+		}
+		json_select ..
+	done
+
+	json_load "$(ubus call api put \
+		     '{"path":"/messages/storage/config/'$id'","body":{"data":{"msg_storage":"'$input'"}}}')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+##############################################
+#  Device.Cellular.Interface.{i}.SMS.Message #
+##############################################
+
+count_iface_sms_message() {
+	local usb_id="$2"
+	local i="$3"
+	local j=1
+	local messages="$(ubus call api get '{"path":"/messages/status"}' | \
+			  jsonfilter -e '@.http_body.data.*')"
+
+	OLD_IFS="$IFS"
+	IFS=$'\n'
+	for table in $messages; do
+		IFS="$OLD_IFS"
+		[ "$(echo "$table" | jsonfilter -e '@.modem_id')" = "$usb_id" ] && {
+			sub_entry_cellular_iface_sms_message "$1" "$j" "$i"
+			j=$((j + 1))
+		}
+		IFS=$'\n'
+	done
+	IFS="$OLD_IFS"
+}
+
+sub_entry_cellular_iface_sms_message() {
+	local j="$2"
+	local i="$3"
+
+	case_param "$1" belongto "$DMROOT.Cellular.Interface.$i.SMS.Message.$j." && {
+		common_execute_method_obj "$DMROOT.Cellular.Interface.$i.SMS.Message.$j." "0"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.SMS.Message.$j.Sender" "0" \
+			"get_iface_sms_message_value sender" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.SMS.Message.$j.TimeStamp" "0" \
+			"get_iface_sms_message_time" "" "xsd:dateTime"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.SMS.Message.$j.Text" "0" \
+			"get_iface_sms_message_value message" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Cellular.Interface.$i.SMS.Message.$j.Status" "0" \
+			"get_iface_sms_message_value status" "" "xsd:string"
+		return 0
+	}
+
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+get_iface_sms_message_value() {
+	local key="$1"
+
+	echo "$table" | jsonfilter -e '@.'$key''
+}
+
+get_iface_sms_message_time() {
+	echo "$table" | jsonfilter -e '@.date' | sed 's/[[:space:]]/T/g'
+}
+
+################################
+#  Device.Cellular.AccessPoint #
+################################
+
+add_cellular_ap() {
+	local i=0
+
+	json_load_file "/etc/board.json"
+	json_select modems
+	json_get_keys keys
+	for var in $keys; do
+		json_select "$var"
+		json_get_var id id
+		break
+	done
+
+	if [ "${keys##* }" = "1" ]; then
+		json_load "$(ubus call api post '{"path":"/interfaces/config","body":
+			     {"data":{"area_type":"wan","proto":"wwan","sim":"1"}}}')"
+	else
+		json_load "$(ubus call api post '{"path":"/interfaces/config","body":
+			     {"data":{"area_type":"wan","proto":"wwan","modem":"'$id'","sim":"1"}}}')"
+	fi
+	json_select http_body
+	json_get_var success success
+	[ "$success" = "0" ] && return $E_INVALID_PARAMETER_VALUE
+
+	json_load "$(ubus call api get '{"path":"/interfaces/config"}')"
+	json_select http_body
+	json_select data
+	json_get_keys keys
+	for var in $keys; do
+		json_select "$var"
+		json_get_vars proto id
+		[ "$proto" = "wwan" ] && i=$((i + 1))
+		json_select ..
+	done
+
+	echo "$i"
+}
+
+delete_cellular_ap() {
+	local iface="$1"
+
+	json_load "$(ubus call api delete '{"path":"/interfaces/config/'$iface'"}')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+count_cellular_ap_obj() {
+	local i=1
+	local ifaces="$(ubus call api get '{"path":"/interfaces/config"}' | \
+			jsonfilter -e '@.http_body.data.*')"
+
+	OLD_IFS="$IFS"
+	IFS=$'\n'
+	for table in $ifaces; do
+		IFS="$OLD_IFS"
+		[ "$(echo "$table" | jsonfilter -e '@.proto')" = "wwan" ] && {
+			sub_entry_cellular_ap "$1" "$i" "$table"
+			i=$((i + 1))
+		}
+		IFS=$'\n'
+	done
+	IFS="$OLD_IFS"
+}
+
+sub_entry_cellular_ap() {
+	local i="$2"
+	local table="$3"
+
+	case_param "$1" belongto "$DMROOT.Cellular.AccessPoint.$i." && {
+		local iface="$(echo "$table" | jsonfilter -e '@.id')"
+		local enabled="$(echo "$table" | jsonfilter -e '@.enabled')"
+		local modem="$(echo "$table" | jsonfilter -e '@.modem')"
+		local pdptype="$(echo "$table" | jsonfilter -e '@.pdptype')"
+		local sim="$(echo "$table" | jsonfilter -e '@.sim')"
+
+		if [ -n "$enabled" -a "$enabled" -eq 1 ]; then
+			enabled="true"
+		else
+			enabled="false"
+		fi
+
+		case "$pdptype" in
+			"ip")
+				pdptype="4"
+				;;
+			"ipv6")
+				pdptype="6"
+				;;
+			"ipv4v6"|*)
+				pdptype="-1"
+				;;
+		esac
+
+		common_execute_method_obj "$DMROOT.Cellular.AccessPoint.$i." "1" \
+			"" "delete_cellular_ap $iface" ""
+		common_execute_method_param "$DMROOT.Cellular.AccessPoint.$i.Enable" "1" \
+			"echo $enabled" "set_ap_enable $iface" "xsd:boolean"
+		common_execute_method_param "$DMROOT.Cellular.AccessPoint.$i.Name" "0" \
+			"echo $iface" "" "xsd:string"
+		common_execute_method_param "$DMROOT.Cellular.AccessPoint.$i.APN" "1" \
+			"get_ap_apn $iface" "set_ap_apn $iface" "xsd:string"
+		common_execute_method_param "$DMROOT.Cellular.AccessPoint.$i.Username" "1" \
+			"get_ap_username $iface" "set_ap_value $iface username" "xsd:string"
+		common_execute_method_param "$DMROOT.Cellular.AccessPoint.$i.Password" "1" \
+			"echo " "set_ap_value $iface password" "xsd:string"
+		common_execute_method_param "$DMROOT.Cellular.AccessPoint.$i.Interface" "1" \
+			"get_ap_interface $modem" "set_ap_interface $iface" "xsd:string"
+		common_execute_method_param "$DMROOT.Cellular.AccessPoint.$i.IPVersion" "1" \
+			"echo $pdptype" "set_ap_ipversion $iface" "xsd:int"
+		common_execute_method_param "$DMROOT.Cellular.AccessPoint.$i.SIM" "1" \
+			"echo $sim" "set_ap_sim $iface" "xsd:unsignedInt"
+		return 0
+	}
+
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+set_ap_enable() {
+	local iface="$1"
+	local input="$2"
+
+	if [ "$input" = "true" ]; then
+		input="1"
+	elif [ "$input" = "false" ]; then
+		input="0"
+	elif [ "$input" != "0" -a "$input" != "1" ]; then
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+
+	json_load "$(ubus call api put '{"path":"/interfaces/config/'$iface'",
+		     "body":{"data":{"enabled":"'$input'"}}}')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+get_ap_apn() {
+	local iface="$1"
+
+	json_load "$(ubus call api get '{"path":"/interfaces/status/'$iface'"}')"
+	json_select http_body
+	json_select data
+	json_get_var apn apn
+
+	echo "$apn"
+}
+
+set_ap_apn() {
+	local iface="$1"
+	local input="$2"
+	local key="apn"
+	local lowercase=$(echo "$input" | tr 'A-Z' 'a-z')
+
+	[ "${#input}" -gt 100 ] && return $E_INVALID_PARAMETER_VALUE
+
+	[ -z "$input" ] || [ "$lowercase" = "auto" ] && {
+		key="auto_apn"
+		input="1"
+	}
+
+	json_load "$(ubus call api put '{"path":"/interfaces/config/'$iface'",
+		     "body":{"data":{"'$key'":"'$input'"}}}')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+get_ap_username() {
+	local iface="$1"
+
+	config_load network
+	config_get username "$iface" username
+
+	echo "$username"
+}
+
+set_ap_value() {
+	local iface="$1"
+	local key="$2"
+	local input="$3"
+
+	[ "${#input}" -gt 256 ] && return $E_INVALID_PARAMETER_VALUE
+
+	if [ -z "$input" ]; then
+		uci delete network."$iface"."$key"
+	else
+		uci set network."$iface"."$key"="$input"
+	fi
+
+	uci commit
+	ubus call mobifd reload >/dev/null 2>&1
+}
+
+get_ap_interface() {
+	local modem="$1"
+	local i=1
+	local res=""
+
+	local command="/usr/sbin/easycwmp"
+	[ ! -f "$command" ] && command="/usr/local$command"
+
+	while res="$($command get Device.Cellular.Interface.$i.Name)" &&
+	      ! echo "$res" | grep -q 'fault_code'; do
+		json_load "$res"
+		json_get_var value value
+		[ "$value" = "$modem" ] && {
+			json_get_var parameter parameter
+			echo "${parameter%.Name}"
+			return 0
+		}
+		i=$((i + 1))
+	done
+}
+
+set_ap_interface() {
+	local iface="$1"
+	local input="$2"
+
+	local command="/usr/sbin/easycwmp"
+	[ ! -f "$command" ] && command="/usr/local$command"
+
+	json_load "$($command get $input.Name)"
+	json_get_vars fault_code value  >/dev/null 2>&1
+	[ -n "$fault_code" ] && return $E_INVALID_PARAMETER_VALUE
+
+	json_load "$(ubus call api put '{"path":"/interfaces/config/'$iface'",
+		     "body":{"data":{"modem":"'$value'"}}}')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+set_ap_ipversion() {
+	local iface="$1"
+	local input="$2"
+
+	case "$input" in
+		"4")
+			input="ip"
+			;;
+		"6")
+			input="ipv6"
+			;;
+		"-1")
+			input="ipv4v6"
+			;;
+		*)
+			return $E_INVALID_PARAMETER_VALUE
+			;;
+	esac
+
+	json_load "$(ubus call api put '{"path":"/interfaces/config/'$iface'",
+		     "body":{"data":{"pdptype":"'$input'"}}}')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
+
+set_ap_sim() {
+	local iface="$1"
+	local input="$2"
+
+	json_load "$(ubus call api put '{"path":"/interfaces/config/'$iface'",
+		     "body":{"data":{"sim":"'$input'"}}}')"
+	json_select http_body
+	json_get_var success success
+	if [ "$success" = "1" ]; then
+		return 0
+	else
+		return $E_INVALID_PARAMETER_VALUE
+	fi
+}
diff --recursive --unified --new-file --no-dereference --exclude .gitver upstream/ext/openwrt/scripts/functions/mobile/mobile_information src/ext/openwrt/scripts/functions/mobile/mobile_information
--- upstream/ext/openwrt/scripts/functions/mobile/mobile_information	1970-01-01 00:00:00.000000000 +0000
+++ src/ext/openwrt/scripts/functions/mobile/mobile_information	2026-03-25 10:23:48.000000000 +0000
@@ -0,0 +1,245 @@
+#!/bin/sh
+# Copyright (C) 2015 PIVA Software <www.pivasoftware.com>
+# 	Author: MOHAMED Kallel <mohamed.kallel@pivasoftware.com>
+
+#common_execute_method_param "$parameter" "$permission" "$get_cmd" "$set_cmd" "xsd:$type" "$forcedinform"
+#  $forcedinform should be set to 1 if the parameter is included in the inform message otherwise empty
+#  Default of $type = string
+
+#############################
+#   Entry point functuons   #
+#############################
+
+prefix_list="$prefix_list $DMROOT.MobileInfo."
+entry_execute_method_list="$entry_execute_method_list entry_execute_method_root_MobileInfo"
+entry_execute_method_list_forcedinform="$entry_execute_method_list_forcedinform  entry_execute_method_root_MobileInfo"
+MDCOLLECTCTL_BIN=/usr/bin/mdcollectdctl
+current_sim="1"
+# Structure --- <Value name represented in easycwmp log;ubus method name;lookup value from method response>
+PARAM_LIST="RSSI;get_signal_query;rssi ConnState;info;usb_id NetState;get_net_reg_stat_all;status ICCID;get_iccid;iccid \
+IMSI;get_imsi;imsi RSCP;get_signal_query;rscp ECIO;get_signal_query;ecio RSRP;get_signal_query;rsrp SINR;get_signal_query;sinr RSRQ;get_signal_query;rsrq \
+CellID;get_net_reg_stat_all;ci Operator;get_service_provider;full_name OperatorNum;get_network_info;opernum ConnType;get_network_info;net_mode \
+Model;info;model Manufacturer;info;manuf Serial;get_serial;serial Revision;get_firmware;firmware IMEI;info;imei SimState;get_pin_state;state_id \
+PinState;get_pin_state;state Temperature;get_temperature;temperature_value PCI;info;pcid LAC;get_net_reg_stat_all;lac \
+TAC;get_net_reg_stat_all;tac EARFCN;info;earfcn NeighbourCells;get_neighbour_cells;unparsed"
+
+MODEMS=""
+
+get_modems(){
+
+	local modem_objs=$(ubus list gsm.*)
+	for i in $modem_objs
+	do
+		MODEMS=${MODEMS:+$MODEMS }"${i//[!0-9]/}"
+	done
+
+}
+
+get_usb_id() {
+
+	local modem_num="$1"
+	local usb_id="$(ubus call gsm.modem$modem_num info 2>/dev/null | grep usb_id | sed 's/.* //g')"
+
+	echo "${usb_id:1:-2}"
+
+}
+
+get_conn_state() {
+
+	local modem_id=$1
+
+	json_init
+	json_load "$(ubus call network.interface dump)"
+
+	json_is_a interface array || {
+		return 5
+	}
+
+	json_select interface
+	json_get_keys keys
+
+	for var in $keys; do
+		json_select "$var"
+		json_get_var interface interface
+		json_get_var data data
+		json_get_var up up
+		json_get_var modem_main modem
+
+		[ -z "$data" ] || [ -z "$up" ] || [ "$up" -eq 0 ] && {
+			json_select ..
+			continue
+		}
+
+		json_select data
+		json_get_var modem_data modem
+		json_select ..
+
+		[ "$modem_main" != "$modem_id" ] && [ "$modem_data" != "$modem_id" ] && {
+			json_select ..
+			continue
+		}
+
+		json_get_var method method
+		json_select ipv4-address
+		json_select 1 >/dev/null 2>&1
+		json_get_var ipv4 address
+		json_select ..
+
+		[ -n "$method" -a "$method" = "bridge" ] || [ "$ipv4" ] && {
+			return 1
+		}
+
+		json_select ..
+	done
+
+	return 0
+}
+
+
+get_modem_value() {
+
+	local modem_num="$1"
+	local method="$2"
+	local value="$3"
+	local parameter_name="$4"
+
+	local found_value=$(ubus call gsm.modem$modem_num $method 2>/dev/null | grep -w $value | sed 's/[^ ]* *//; s/["]//g; s/,$//g')
+
+	case "$parameter_name" in
+		"SimState")
+			case "$found_value" in
+				"1"|"3"|"4"|"5"|"6"|"7"|"8"|"11")
+					found_value="Inserted"
+				;;
+				*)
+					found_value="Not inserted"
+				;;
+			esac
+		;;
+		"ConnState")
+			get_conn_state "$found_value"
+			found_value=$?
+			case "$found_value" in
+				1)
+					found_value="Connected"
+					;;
+				0)
+					found_value="Not connected"
+					;;
+				*)
+					found_value="Unknown"
+					;;
+			esac
+		;;
+		"NeighbourCells")
+			found_value=$(echo $found_value | tr -d '\\')
+		;;
+	esac
+
+	echo "$found_value"
+
+}
+
+list_foreach(){
+	[ "$#" -ge 2 ] || return 0
+	local list=$1; shift
+	local callback=$1; shift
+
+	for element in $list
+	do
+		$callback $element $@
+	done
+}
+
+entry_execute_method_root_MobileInfo() {
+	case "$1" in ""|"$DMROOT."|"$DMROOT.MobileInfo."*)
+		common_execute_method_obj "$DMROOT.MobileInfo." "0"
+		common_execute_method_obj "$DMROOT.MobileInfo.Modem." "0" "" "" "mobileinfo_browse_modems $1"
+
+		return 0;
+		;;
+	esac
+	return $E_INVALID_PARAMETER_NAME;
+}
+
+sub_entry_modem_info(){
+	name=$(echo $1 | awk 'BEGIN { FS = ";" }; {print $1}')
+	method=$(echo $1 | awk 'BEGIN { FS = ";" }; {print $2}')
+	value=$(echo $1 | awk 'BEGIN { FS = ";" }; {print $3}')
+
+	local usb_id="$2"
+	local modem_num="$3"
+
+	local modem_value=$(get_modem_value "$modem_num" "$method" "$value" "$name")
+
+	[ -n "$name" -a -n "$method" ] && {
+		common_execute_method_param "$DMROOT.MobileInfo.Modem.$usb_id.$name" "0"\
+		 	"echo $modem_value" "" "" "1"
+	}
+}
+
+sub_entry_modem() {
+	local modem sim=1
+	local modem_num="$1"
+
+	modem=$(get_usb_id "$modem_num")
+
+	case_param "$2" belongto "$DMROOT.MobileInfo.Modem.$modem." && {
+		common_execute_method_obj "$DMROOT.MobileInfo.Modem.$modem." "0"
+		list_foreach "$PARAM_LIST" sub_entry_modem_info $modem $modem_num
+		common_execute_method_param "$DMROOT.MobileInfo.Modem.$modem.SentToday" "0" \
+			"get_sent_today $modem $sim" "" "" "1"
+		common_execute_method_param "$DMROOT.MobileInfo.Modem.$modem.ReceivedToday" "0" \
+			"get_received_today $modem $sim" "" "" "1"
+		common_execute_method_param "$DMROOT.MobileInfo.Modem.$modem.SentThisMonth" "0" \
+			"get_sent_month $modem $sim" "" "" "1"
+		common_execute_method_param "$DMROOT.MobileInfo.Modem.$modem.ReceivedThisMonth" "0" \
+			"get_received_month $modem $sim" "" "" "1"
+
+		return 0
+	}
+	return "$E_INVALID_PARAMETER_NAME"
+}
+
+mobileinfo_browse_modems() {
+	#We're not using json_for_each_item here, cus json is overwrited by system.
+	[ -n "$MODEMS" ] || get_modems
+
+	list_foreach "$MODEMS" sub_entry_modem "$1"
+}
+
+get_sent_today() {
+	json_load "$(ubus call mdcollect get \
+		 '{"modem": "'$1'", "sim": '$2', "period": "day", "current": false}')"
+	json_get_var sent_today tx
+
+	echo "$sent_today"
+}
+
+get_received_today() {
+	json_load "$(ubus call mdcollect get \
+		'{"modem": "'$1'", "sim": '$2', "period": "day", "current": false}')"
+	json_get_var received_today rx
+
+	echo "$received_today"
+}
+
+get_sent_month() {
+	json_load "$(ubus call mdcollect get \
+		'{"modem": "'$1'", "sim": '$2', "period": "month", "current": false}')"
+	json_get_var sent_month tx 
+
+	echo "$sent_month"
+}
+
+get_received_month() {
+	json_load "$(ubus call mdcollect get \
+		'{"modem": "'$1'", "sim": '$2', "period": "month", "current": false}')"
+	json_get_var received_month rx
+
+	echo "$received_month"
+}
+
+#######################################
+#   Data model parameters functions   #
+#######################################
