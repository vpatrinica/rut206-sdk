-static int SSL_server_test(
-        const char *testname, 
-        const char *openssl_option, 
-        const char *device_cert, 
-        const char *product_cert, 
-        const char *private_key,
-        const char *ca_cert,
-        const char *password,
-        int axolotls_option)
-{
-    int server_fd, ret = 0;
-    SSL_CTX *ssl_ctx = NULL;
-    struct sockaddr_in client_addr;
