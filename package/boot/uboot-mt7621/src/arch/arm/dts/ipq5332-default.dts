#include "ipq5332.dtsi"

/ {
	config_name = "config@default";

	aliases {
		serial0 = &blsp1_uart0_console;
	};

	chosen {
		stdout-path = &blsp1_uart0_console;
	};

	soc: soc {
		tlmm: pinctrl@1000000 {
			sdhci_pinmux: mmc {
				emmc_data {
					pins = "GPIO_8", "GPIO_9", "GPIO_10",
						"GPIO_11";
					function = "sdc";
					drive-strength = <DRIVE_STRENGTH_8MA>;
					bias-pull-up;
				};

				emmc_cmd{
					pins = "GPIO_12";
					function = "sdc";
					drive-strength = <DRIVE_STRENGTH_8MA>;
					bias-pull-up;
				};

				emmc_clk{
					pins = "GPIO_13";
					function = "sdc";
					drive-strength = <DRIVE_STRENGTH_8MA>;
					bias-disable;
				};
			};

			serial_pinmux: uart {
				data {
					pins = "GPIO_18", "GPIO_19";
					function = "blsp0_uart0";
					drive-strength = <DRIVE_STRENGTH_8MA>;
					bias-pull-up;
				};
			};

			blsp1_spi_pinmux: blsp1_spi_pins {
				blsp0_spi_clk {
					pins = "GPIO_14";
					function = "blsp0_spi";
					drive-strength = <DRIVE_STRENGTH_8MA>;
					bias-disable;
				};

				blsp0_spi_mosi {
					pins = "GPIO_15";
					function = "blsp0_spi";
					drive-strength = <DRIVE_STRENGTH_8MA>;
					bias-disable;
				};

				blsp0_spi_miso {
					pins = "GPIO_16";
					function = "blsp0_spi";
					drive-strength = <DRIVE_STRENGTH_8MA>;
					bias-disable;
				};

				blsp0_spi_cs {
					pins = "GPIO_17";
					function = "blsp0_spi";
					drive-strength = <DRIVE_STRENGTH_8MA>;
					bias-pull-up;
				};

			};

			mdio_pinmux: mdio {
				mdc {
					pins = "GPIO_27";
					function = "mdc_1";
					drive-strength = <DRIVE_STRENGTH_8MA>;
					bias-disable;
				};

				mdio {
					pins = "GPIO_28";
					function = "mdio_1";
					drive-strength = <DRIVE_STRENGTH_8MA>;
					bias-pull-up;
				};
			};

			phy_rst_pinmux: phy_rst {
				qti_8x8x_rst {
					pins = "GPIO_51";
					bias-pull-up;
				};
			};
		};

		watchdog: non-sec@b017000 {
			status = "okay";
		};

		blsp1_uart0_console: serial@78af000 {
			pinctrl-names = "default";
			pinctrl-0 = <&serial_pinmux>;
			status = "okay";
		};

		blsp1_spi: spi@78b5000 {
			pinctrl-names = "default";
			pinctrl-0 = <&blsp1_spi_pinmux>;
			cs-gpios = <&tlmm 17 0>;
			force-cs;
			status = "okay";
		};

		mmc: sdhci@7800000 {
			pinctrl-names = "default";
			pinctrl-0 = <&sdhci_pinmux>;
			status = "okay";
		};
	};
};
