+#############################################
+#  Device.WiFi.AccessPoint.AssociatedDevice #
+#############################################
+
+get_wifi_ap_assocdevice_noe() {
+	local id="$1"
+
+	json_load "$(ubus call api get '{"path":"/wireless/interfaces/status/'$id'"}')"
+	json_select http_body
+	json_select data
+	json_get_var ifname ifname
+	echo "$ifname" | grep -q "wlan" && {
+		echo "1"
+		return 0
+	}
+
+	json_select ifname
+	json_get_keys keys
+	keys="${keys##* }"
+	if [ -n "$keys" ]; then
+		echo "$keys"
+	else
+		echo "0"
+	fi
+}
+
+count_wifi_ap_assocdevice_obj() {
+	local i="$2"
+	local id="$3"
+	local j=1
+
+	local ifnames="$(ubus call api get '{"path":"/wireless/interfaces/status/'$id'"}' | \
+			 jsonfilter -e '@.http_body.data.ifname[*]')"
+
+	if [ -z "$ifnames" ]; then
+		ifnames="$(ubus call api get '{"path":"/wireless/interfaces/status/'$id'"}' | \
+			   jsonfilter -e '@.http_body.data.ifname')"
+		sub_entry_wifi_ap_assocdevice "$1" "$i" "$j" "$ifnames"
+	else
+		for ifname in $ifnames; do
+			sub_entry_wifi_ap_assocdevice "$1" "$i" "$j" "$ifname"
+			j=$((j + 1))
+		done
+	fi
+}
+
+sub_entry_wifi_ap_assocdevice() {
+	local i="$2"
+	local j="$3"
+	local ifname="$4"
+
+	case_param "$1" belongto "$DMROOT.WiFi.AccessPoint.$i.AssociatedDevice.$j." && {
+		local iwinfo="$(ubus call iwinfo assoclist '{"device":"'$ifname'"}' | \
+				jsonfilter -e '@.results[0]')"
+		local mac="$(echo "$iwinfo" | jsonfilter -e '@.mac')"
+		local frequency="$(ubus call iwinfo info '{"device":"'$ifname'"}' | \
+				   jsonfilter -e '@.frequency')"
+		local ht="$(echo "$iwinfo" | jsonfilter -e '@.rx.ht')"
+		local vht="$(echo "$iwinfo" | jsonfilter -e '@.rx.vht')"
+		local he="$(echo "$iwinfo" | jsonfilter -e '@.rx.he')"
+		local eht="$(echo "$iwinfo" | jsonfilter -e '@.rx.eht')"
+		local authorized="$(echo "$iwinfo" | jsonfilter -e '@.authorized')"
+		local rx_rate="$(echo "$iwinfo" | jsonfilter -e '@.rx.rate')"
+		local tx_rate="$(echo "$iwinfo" | jsonfilter -e '@.tx.rate')"
+		local connected_time="$(echo "$iwinfo" | jsonfilter -e '@.connected_time')"
+		local signal_avg="$(echo "$iwinfo" | jsonfilter -e '@.signal_avg')"
+		local noise="$(echo "$iwinfo" | jsonfilter -e '@.noise')"
+		local rx_mhz="$(echo "$iwinfo" | jsonfilter -e '@.rx.mhz')"
+		local tx_mhz="$(echo "$iwinfo" | jsonfilter -e '@.tx.mhz')"
+		local tx_bytes="$(echo "$iwinfo" | jsonfilter -e '@.tx.bytes')"
+		local rx_bytes="$(echo "$iwinfo" | jsonfilter -e '@.rx.bytes')"
+		local tx_packets="$(echo "$iwinfo" | jsonfilter -e '@.tx.packets')"
+		local rx_packets="$(echo "$iwinfo" | jsonfilter -e '@.rx.packets')"
+
+		local operating_standard=""
+		if [ "$ht" = "true" ]; then
+			operating_standard="n"
+		elif [ "$vht" = "true" ]; then
+			operating_standard="ac"
+		elif [ "$he" = "true" ]; then
+			operating_standard="ax"
+		elif [ "$eht" = "true" ]; then
+			operating_standard="be"
+		elif [ "$(echo "$frequency" | cut -c1)" = "2" ]; then
+			# when everything is false on 2.4GHz
+			operating_standard="g"
+		elif [ "$(echo "$frequency" | cut -c1)" = "5" ]; then
+			# when everything is false on 5GHz
+			operating_standard="a"
+		fi
+
+		[ -n "$connected_time" ] && {
+			local now=$(date +%s)
+			connected_time=$((now - connected_time))
+			connected_time=$(date -u -d "@$connected_time" +"%Y-%m-%dT%H:%M:%SZ")
+		}
+
+		local max_bw="$rx_mhz"
+		[ -z "$max_bw" ] || [ "$max_bw" -lt "$tx_mhz" ] && max_bw="$tx_mhz"
+		if [ -z "$max_bw" ]; then
+			max_bw="Unknown"
+		else
+			max_bw="${max_bw}MHz"
+		fi
+
+		[ -z "$rx_rate" ] && rx_rate="0"
+		[ -z "$tx_rate" ] && tx_rate="0"
+		[ -z "$signal_avg" ] && signal_avg="0"
+		[ -z "$noise" ] && noise="0"
+		[ -z "$tx_bytes" ] && tx_bytes="0"
+		[ -z "$rx_bytes" ] && rx_bytes="0"
+		[ -z "$tx_packets" ] && tx_packets="0"
+		[ -z "$rx_packets" ] && rx_packets="0"
+
+		common_execute_method_obj "$DMROOT.WiFi.AccessPoint.$i.AssociatedDevice.$j." "0"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.AssociatedDevice.$j.MACAddress" "0" \
+			"echo $mac" "" "xsd:string"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.AssociatedDevice.$j.OperatingStandard" "0" \
+			"echo $operating_standard" "" "xsd:string"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.AssociatedDevice.$j.AuthenticationState" "0" \
+			"echo $authorized" "" "xsd:boolean"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.AssociatedDevice.$j.LastDataDownlinkRate" "0" \
+			"echo $rx_rate" "" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.AssociatedDevice.$j.LastDataUplinkRate" "0" \
+			"echo $tx_rate" "" "xsd:unsignedInt"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.AssociatedDevice.$j.AssociationTime" "0" \
+			"echo $connected_time" "" "xsd:dateTime"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.AssociatedDevice.$j.SignalStrength" "0" \
+			"echo $signal_avg" "" "xsd:int"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.AssociatedDevice.$j.Noise" "0" \
+			"echo $noise" "" "xsd:int"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.AssociatedDevice.$j.MaxSupportedBandwidth" "0" \
+			"echo $max_bw" "" "xsd:string"
+		common_execute_method_obj "$DMROOT.WiFi.AccessPoint.$i.AssociatedDevice.$j.Stats." "0"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.AssociatedDevice.$j.Stats.BytesSent" "0" \
+			"echo $tx_bytes" "" "xsd:unsignedLong"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.AssociatedDevice.$j.Stats.BytesReceived" "0" \
+			"echo $rx_bytes" "" "xsd:unsignedLong"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.AssociatedDevice.$j.Stats.PacketsSent" "0" \
+			"echo $tx_packets" "" "xsd:unsignedLong"
+		common_execute_method_param "$DMROOT.WiFi.AccessPoint.$i.AssociatedDevice.$j.Stats.PacketsReceived" "0" \
+			"echo $rx_packets" "" "xsd:unsignedLong"
+		return 0;
+	}
+	return $E_INVALID_PARAMETER_NAME;
+}
diff --recursive --unified --new-file --no-dereference --exclude .gitver upstream/ext/openwrt/scripts/unused/device_hosts src/ext/openwrt/scripts/unused/device_hosts
