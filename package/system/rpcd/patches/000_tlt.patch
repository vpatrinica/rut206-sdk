diff --recursive --unified --new-file --no-dereference --exclude .gitver upstream/files/libexec/integrity src/files/libexec/integrity
--- upstream/files/libexec/integrity	1970-01-01 00:00:00.000000000 +0000
+++ src/files/libexec/integrity	2026-04-13 09:41:33.000000000 +0000
@@ -0,0 +1,367 @@
+#!/bin/sh
+
+. /usr/share/libubox/jshn.sh
+
+DEFAULT_DIR="/usr/local/share/integrity"
+DEFAULT_DATABASE="$DEFAULT_DIR/hash.db.gz"
+DEFAULT_PRIVATE_KEY="$DEFAULT_DIR/private.key"
+DEFAULT_PUBLIC_KEY="$DEFAULT_DIR/public.key"
+
+GENERATE_PID_FILE="/tmp/integrity_generate.pid"
+
+IGNORE_PATHS="/sys /dev /proc"
+
+response() {
+	local code="$1"
+	local msg="$2"
+
+	json_init
+	json_add_string "message" "$msg"
+	json_add_boolean "success" $([ "$code" -eq 0 ] && echo "1" || echo "0")
+	json_dump
+	exit "$code"
+}
+
+generate_private_key() {
+	local private_key="$1"
+	local bits="${2:-2048}"
+	openssl genpkey -algorithm RSA -out "$private_key" -pkeyopt rsa_keygen_bits:"$bits"
+	return $?
+}
+
+generate_public_key() {
+	local private_key="$1"
+	local public_key="$2"
+	openssl pkey -in "$private_key" -pubout -out "$public_key"
+	return $?
+}
+
+generate_signature() {
+	local private_key="$1"
+	local file_to_sign="$2"
+	local signature_output="$3"
+	openssl dgst -sha256 -sign "$private_key" -out "$signature_output" "$file_to_sign"
+	return $?
+}
+
+verify_signature() {
+	local public_key="$1"
+	local file_to_verify="$2"
+	local signature_file="$3"
+	openssl dgst -sha256 -verify "$public_key" -signature "$signature_file" "$file_to_verify"
+	return $?
+}
+
+create_keypair() {
+	local private_key="$1"
+	local public_key="$2"
+	[ -e "$private_key" ] && [ -e "$public_key" ] && return 0
+	rm -f "$private_key" "$public_key"
+	generate_private_key "$private_key"
+	[ $? -ne 0 ] && return 1
+	generate_public_key "$private_key" "$public_key"
+	return $?
+}
+
+build_find_excludes() {
+	local find_args=""
+	local first=1
+	for ignore_path in $IGNORE_PATHS; do
+		# ignore both absolute and ./ variants
+		local ipath1="$ignore_path"
+		local ipath2="./${ignore_path#/}"
+		for ipath in "$ipath1" "$ipath2"; do
+			if [ $first -eq 1 ]; then
+				find_args="-path $ipath"
+				first=0
+			else
+				find_args="$find_args -o -path $ipath"
+			fi
+		done
+	done
+
+	if [ -n "$find_args" ]; then
+		echo "( $find_args ) -prune -o"
+	else
+		echo ""
+	fi
+}
+
+generate_database() {
+	local db="$1"
+	shift
+	local find_excludes=$(build_find_excludes)
+
+	for path in "$@"; do
+		local cleaned_path="${path#./}"
+		cleaned_path="${cleaned_path#/}"
+		local root_component="/${cleaned_path%%/*}"
+		for ignore_path in $IGNORE_PATHS; do
+			if [ "$root_component" = "$ignore_path" ]; then
+				continue 2
+			fi
+		done
+
+		if [ -d "$path" ]; then
+			# Skip if this path is a subdirectory of another path in the list
+			for parent_path in "$@"; do
+				[ "$path" = "$parent_path" ] && continue
+				case "$path" in
+					"$parent_path"/*) continue 2 ;;
+				esac
+			done
+
+			local dirs=$(mktemp)
+			local files=$(mktemp)
+			local hashes=$(mktemp)
+
+			find "$path" $find_excludes -type d -print0 > "$dirs"
+
+			if [ -s "$dirs" ]; then
+				cat "$dirs" | xargs -0 ls -ldn 2>/dev/null | awk '{
+					file=""; for(i=9;i<=NF;i++) file=file (i>9?" ":"") $i
+					printf "%s||%s|%s|%s|%s\n", file, $5, $1, $3, $4
+				}' >> "$db"
+			fi
+
+			find "$path" $find_excludes -type f -print0 > "$files"
+
+			if [ -s "$files" ]; then
+				cat "$files" | xargs -0 sha256sum 2>/dev/null > "$hashes"
+
+				cat "$files" | xargs -0 ls -ln 2>/dev/null | awk '
+				NR==FNR { hash[$2]=$1; next }
+				{
+					file=""; for(i=9;i<=NF;i++) file=file (i>9?" ":"") $i
+					printf "%s|%s|%s|%s|%s|%s\n", file, hash[file], $5, $1, $3, $4
+				}' "$hashes" - >> "$db"
+			fi
+
+			rm -f "$dirs" "$files" "$hashes"
+		elif [ -f "$path" ]; then
+			local sha256=$(sha256sum "$path" 2>/dev/null | awk '{print $1}')
+			ls -ln "$path" 2>/dev/null | awk -v h="$sha256" -v f="$path" '{
+				printf "%s|%s|%s|%s|%s|%s\n", f, h, $5, $1, $3, $4
+			}' >> "$db"
+		fi
+	done
+}
+
+store_file_info() {
+	local db="$1"
+	local skip_signature="$2"
+	local allow_recreate=0
+	shift 2
+
+	local pid="$(cat "$GENERATE_PID_FILE" 2>/dev/null)"
+	if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
+		response 1 "Integrity database generation is already in progress"
+	fi
+	echo $$ > "$GENERATE_PID_FILE"
+	trap 'rm -f "$GENERATE_PID_FILE"' EXIT
+
+	[ -n "$db" ] || db="$DEFAULT_DATABASE"
+	[ "$db" = "$DEFAULT_DATABASE" ] && [ -e "$db" ] && allow_recreate=1
+
+	local no_gz_db="${db%.gz}"
+	local new_db="$no_gz_db.new"
+
+	[ $# -gt 0 ] || response 1 "No directories or files specified to scan"
+
+	for path in "$@"; do
+		[ -e "$path" ] || response 1 "Path '$path' does not exist"
+	done
+
+	[ "$allow_recreate" -eq 0 ] && { [ -e "$no_gz_db" ] || [ -e "$no_gz_db.gz" ]; } && response 1 "Provided path already exists"
+
+	[ -z "$skip_signature" ] && {
+		create_keypair "$DEFAULT_PRIVATE_KEY" "$DEFAULT_PUBLIC_KEY"
+		[ $? -ne 0 ] && response 1 "Failed to create keypair"
+	}
+
+	echo "TIME|$(date +%s)" > "$new_db"
+	echo "DIRS|$*" >> "$new_db"
+
+	generate_database "$new_db" "$@"
+
+	[ -f "$new_db" ] && {
+		mv -f "$db" "$db.old"
+		mv -f "$new_db" "$no_gz_db"
+		gzip -f "$no_gz_db"
+		db="$no_gz_db.gz"
+		chmod 644 "$db" 2>/dev/null
+	}
+
+	[ -z "$skip_signature" ] && {
+		local signature_file="${db}.sig"
+		generate_signature "$DEFAULT_PRIVATE_KEY" "$db" "$signature_file"
+		[ $? -ne 0 ] && response 1 "Failed to create database signature"
+		chmod 644 "$signature_file" 2>/dev/null
+	}
+
+	[ $? -eq 0 ] && response 0 "Database created at $db" || response 1 "Failed to create database"
+}
+
+check_file_database() {
+	local db="$1"
+
+	[ -f "$db" ] || response 1 "Database file does not exist"
+
+	local original_db="$db"
+	local tmpdb=$(mktemp)
+	[ "${db##*.}" = "gz" ] && {
+		gzip -dc "$db" > "$tmpdb" 2>/dev/null
+		[ $? -ne 0 ] && {
+			rm -rf "$tmpdb"
+			response 1 "Failed to decompress database file"
+		}
+		db="$tmpdb"
+	}
+
+	head -n2 "$db" | grep -qE '^(TIME|DIRS)\|' || {
+		rm -rf "$tmpdb"
+		response 1 "Invalid database file format"
+	}
+
+	local time=$(head -n1 "$db" | cut -d'|' -f2)
+	local dirs=$(head -n2 "$db" | tail -n1 | cut -d'|' -f2)
+	[ -n "$dirs" ] || {
+		rm -rf "$tmpdb"
+		response 1 "No directories specified in database"
+	}
+	[ -n "$time" ] || {
+		rm -rf "$tmpdb"
+		response 1 "No timestamp found in database"
+	}
+
+	local current_db=$(mktemp)
+	local results=$(mktemp)
+
+	generate_database "$current_db" $dirs
+
+	tail -n +3 "$db" | awk -F'|' '
+	NR==FNR {
+		current[$1] = $2 "|" $3 "|" $4 "|" $5 "|" $6
+		exists[$1] = 1
+		next
+	}
+	{
+		file=$1; stored=$2 "|" $3 "|" $4 "|" $5 "|" $6
+		if (!(file in exists)) {
+			print "missing|" file "|" stored
+		} else if (current[file] != stored) {
+			print "modified|" file "|" stored "|" current[file]
+		}
+		delete exists[file]
+	}
+	END {
+		for (f in exists) print "new|" f "||||||" current[f]
+	}' "$current_db" - > "$results"
+
+	local signature_valid="false"
+	local signature_file="${original_db}.sig"
+	if [ -f "$signature_file" ]; then
+		verify_signature "$DEFAULT_PUBLIC_KEY" "$original_db" "$signature_file" >/dev/null 2>&1
+		[ $? -eq 0 ] && signature_valid="true"
+	fi
+
+	local response_file="$(mktemp -u /tmp/integrity.validation.XXXXXX).json"
+
+	printf '{' > "$response_file"
+	printf '"signature_valid":%s,' "$signature_valid" >> "$response_file"
+	printf '"scanned_at":"%s",' "$(date -u -d @"$time" +%Y-%m-%dT%H:%M:%SZ)" >> "$response_file"
+
+	printf '"scanned_dirs":[' >> "$response_file"
+	for dir in $dirs; do
+		printf '"%s"' "$dir"
+		if [ "$dir" != "${dirs##* }" ]; then
+			printf ','
+		fi
+	done >> "$response_file"
+	printf '],' >> "$response_file"
+
+	awk -F'|' 'BEGIN { ORS = "" }
+	{ lines[$1, ++count[$1]] = $0 }
+	END {
+		split("missing modified new", order, " ")
+		first = 1
+		for (o in order) {
+			st = order[o]
+			if (count[st] < 1) continue
+			if (!first) printf ","
+			first = 0
+			printf "\"%s\":[", st
+
+			for (i = 1; i <= count[st]; i++) {
+				split(lines[st,i], f, "|")
+				if (i > 1) printf ","
+				printf "{\"file\":\"%s\"", f[2]
+
+				if (f[3] != "" || f[4] != "" || f[5] != "" || f[6] != "" || f[7] != "") {
+					printf ",\"expected\":{"
+					sep = ""
+					if (f[3] != "") { printf "%s\"hash\":\"%s\"", sep, f[3]; sep = "," }
+					if (f[4] != "") { printf "%s\"size\":\"%s\"", sep, f[4]; sep = "," }
+					if (f[5] != "") { printf "%s\"permissions\":\"%s\"", sep, f[5]; sep = "," }
+					if (f[6] != "") { printf "%s\"owner\":\"%s\"", sep, f[6]; sep = "," }
+					if (f[7] != "") { printf "%s\"group\":\"%s\"", sep, f[7] }
+					printf "}"
+				}
+
+				if (f[8] != "" || f[9] != "" || f[10] != "" || f[11] != "" || f[12] != "") {
+					printf ",\"found\":{"
+					sep = ""
+					if (f[8] != "") { printf "%s\"hash\":\"%s\"", sep, f[8]; sep = "," }
+					if (f[9] != "") { printf "%s\"size\":\"%s\"", sep, f[9]; sep = "," }
+					if (f[10] != "") { printf "%s\"permissions\":\"%s\"", sep, f[10]; sep = "," }
+					if (f[11] != "") { printf "%s\"owner\":\"%s\"", sep, f[11]; sep = "," }
+					if (f[12] != "") { printf "%s\"group\":\"%s\"", sep, f[12] }
+					printf "}"
+				}
+
+				printf "}"
+			}
+			printf "]"
+		}
+	}' "$results" >> "$response_file"
+
+	printf '}\n' >> "$response_file"
+
+	chmod 644 "$response_file" 2>/dev/null
+
+	printf '{"success":true,"file": "%s"}\n' "$response_file"
+
+	rm -f "$current_db" "$results" "$tmpdb"
+}
+
+main() {
+	case "$1" in
+	list)
+		json_init
+		json_add_object "create_database"
+		json_add_boolean "skip_signature"
+		json_add_string "path"
+		json_add_array "dirs"
+		json_close_array
+		json_close_object
+		json_add_object "check_database"
+		json_add_string "path"
+		json_close_object
+		json_dump
+		;;
+	call)
+		case "$2" in
+		create_database)
+			read input
+			store_file_info "$(jsonfilter -s $input -e '@.path')" "$(jsonfilter -s $input -e '@.skip_signature')" $(jsonfilter -s $input -e '@.dirs[*]')
+			;;
+		check_database)
+			read input
+			check_file_database "$(jsonfilter -s $input -e '@.path')"
+			;;
+		esac
+		;;
+	esac
+}
+
+main "$@"
